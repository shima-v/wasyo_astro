# 開発(dev)環境用の公開設定サンプル。
# 実値を入れて `.env.development` にコピーして使用してください（.env.development は gitignore 済み）。
# 秘密情報（LINEチャネルトークン等）はここに置かず、GAS の Script Properties に設定します。

# GAS Web App（dev）の /exec URL
PUBLIC_RESERVE_API="https://script.google.com/macros/s/XXXXXXXX_DEV/exec"

# LINE Login（dev）チャネルID ※LINE連携を使う場合のみ
PUBLIC_LINE_LOGIN_CHANNEL_ID=""

# LINE Login のリダイレクト先（dev フロントの予約ページURL）
PUBLIC_LINE_LOGIN_REDIRECT="http://localhost:4321/reserve/"
