---
import { RESERVE_API, ENV_LABEL } from '../../data/config.js';
import EnvBadge from '../../components/EnvBadge.astro';
import SubmitOverlay from '../../components/SubmitOverlay.astro';
import TimeDialog from '../../components/TimeDialog.astro';
import '../../styles/reserve-calendar.css';

const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
const salonName = 'サロン和笑〜Violane〜';
const tel = '090-9095-6034';
// title は単一の式にする（<title> RCDATA で式＋生テキストの混在を避ける）
const pageTitle = `${ENV_LABEL}ご予約の確認・変更 | ${salonName}`;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href={`${base}favicon.jpg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <EnvBadge />
    <!-- 送信中の全面オーバーレイ（日時変更の送信中・二重送信防止）。共有部品 SubmitOverlay -->
    <SubmitOverlay message="変更を送信しています…" subtext="画面をそのままでお待ちください" />
    <!-- 開始時刻を選ぶポップアップ。共有部品 TimeDialog -->
    <TimeDialog />
    <header class="site-header">
      <a class="home-link" href={base}>‹ {salonName}</a>
      <span class="head-title">ご予約の確認</span>
    </header>

    <main class="wrap">
      <div id="loading" class="status loading"><span class="spinner" aria-hidden="true"></span><span>予約内容を読み込んでいます…</span></div>
      <div id="notfound" class="status err" hidden>
        ご予約が見つかりませんでした。リンクが正しいかご確認ください。<br />
        お困りの際はお電話（<a href={`tel:${tel}`}>{tel}</a>）でお問い合わせください。
      </div>

      <section class="card" id="detail" hidden>
        <h2>ご予約内容</h2>
        <div id="statusBadge"></div>
        <dl class="detail-dl">
          <dt>メニュー</dt><dd id="d-menu"></dd>
          <dt>日時</dt><dd id="d-when"></dd>
          <dt>料金</dt><dd id="d-price"></dd>
          <dt>お名前</dt><dd id="d-name"></dd>
        </dl>

        <div id="deadlineNote" class="note" hidden>
          変更・キャンセルは前日までにお願いいたします。期限を過ぎているため、オンラインでの変更はできません。
          お電話（<a href={`tel:${tel}`}>{tel}</a>）でご相談ください。
        </div>

        <div id="actions" class="actions" hidden>
          <button type="button" class="reserve-btn ghost" id="toggleChange">日時を変更する</button>
          <button type="button" class="reserve-btn danger" id="cancelBtn">予約をキャンセルする</button>
        </div>

        <!-- 変更 UI -->
        <div id="changeBox" class="change-box" hidden>
          <h3>新しい日時を選ぶ</h3>
          <div id="slotStatus" class="status">空き状況を確認しています…</div>
          <div id="dateList" class="date-list"></div>
          <div id="changeError" class="err-box" hidden></div>
          <button type="button" class="reserve-btn" id="confirmChange" disabled>この日時に変更する（再承認）</button>
          <p class="hint">変更後はサロンの再確認のうえ、確定のご連絡をいたします。</p>
        </div>
      </section>

      <section class="card done" id="result" hidden>
        <div class="done-mark" id="resultMark">✓</div>
        <h2 id="resultTitle"></h2>
        <p id="resultBody"></p>
        <a class="reserve-btn ghost" href={base}>トップへ戻る</a>
      </section>
    </main>

    <footer class="site-footer">
      <p>{salonName}</p>
      <p class="small">富山県高岡市野村1180-1 / <a href={`tel:${tel}`}>{tel}</a></p>
    </footer>

    <script type="application/json" id="reserve-config" set:html={JSON.stringify({ RESERVE_API, tel })}></script>
    <script>
      // 共有部品（src/lib）を import するため bundled module 化。サーバ値は JSON から読む。
      import { runExclusive } from '../../lib/submit-overlay.js';
      import { heatMark } from '../../lib/heatmap.js';
      import { openTimeDialog as openTimeDlg, renderTimeButtons } from '../../lib/time-dialog.js';

      const { RESERVE_API, tel } = JSON.parse(document.getElementById('reserve-config').textContent);

      const WD = ['日', '月', '火', '水', '木', '金', '土'];
      // 空き枠ヒートマップの閾値（index と揃える）。枠数 >= HEAT_HI_MIN を ◎、未満を ○。
      const HEAT_HI_MIN = 8;
      const $ = (s) => document.querySelector(s);
      const params = new URLSearchParams(location.search);
      const token = params.get('token') || '';
      const state = { booking: null, days: [], holidays: {}, date: null, time: null, availSet: null, calMin: null, calMax: null };
      let calMonth = null; // カレンダー表示中の月 {y, m(0始まり)}

      const esc = (s) =>
        String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const fmtYen = (n) => '¥' + Number(n).toLocaleString('ja-JP');
      const fmtDateLabel = (ymd) => {
        const [y, m, d] = ymd.split('-').map(Number);
        const dt = new Date(y, m - 1, d);
        return `${m}/${d}(${WD[dt.getDay()]})`;
      };

      async function postAction(payload) {
        const res = await fetch(RESERVE_API, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(payload),
        });
        return res.json();
      }

      function showResult(ok, title, body) {
        $('#detail').hidden = true;
        $('#resultMark').textContent = ok ? '✓' : '！';
        $('#resultTitle').textContent = title;
        $('#resultBody').textContent = body;
        $('#result').hidden = false;
        $('#result').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // ---- 初期読み込み ----
      async function load() {
        if (!token || !RESERVE_API) {
          $('#loading').hidden = true;
          $('#notfound').hidden = false;
          return;
        }
        try {
          const res = await fetch(`${RESERVE_API}?action=booking&token=${encodeURIComponent(token)}`);
          const data = await res.json();
          if (!data.ok) throw new Error('not_found');
          state.booking = data;
          renderDetail(data);
        } catch (e) {
          $('#loading').hidden = true;
          $('#notfound').hidden = false;
        }
      }

      function renderDetail(b) {
        $('#loading').hidden = true;
        $('#detail').hidden = false;
        const confirmed = b.status === 'confirmed';
        $('#statusBadge').innerHTML = confirmed
          ? '<span class="badge ok">確定済み</span>'
          : '<span class="badge pending">仮予約（確認中）</span>';
        $('#d-menu').textContent = b.menuName + (b.isFirstTime ? '（初回）' : '');
        $('#d-when').textContent = `${fmtDateLabel(b.date)} ${b.time}〜（${b.durationMin}分）`;
        $('#d-price').textContent = fmtYen(b.price);
        $('#d-name').textContent = b.name + ' 様';
        if (b.canCancel) {
          $('#actions').hidden = false;
        } else {
          $('#deadlineNote').hidden = false;
        }
      }

      // ---- キャンセル ----
      $('#cancelBtn').addEventListener('click', async () => {
        if (!confirm('このご予約をキャンセルします。よろしいですか？')) return;
        const btn = $('#cancelBtn');
        btn.disabled = true;
        const r = await postAction({ action: 'cancelBooking', token });
        if (r.ok) {
          showResult(true, 'キャンセルしました', 'ご予約をキャンセルいたしました。またのご利用をお待ちしております。');
        } else if (r.error === 'too_late') {
          btn.disabled = false;
          showResult(false, '期限切れ', 'キャンセル期限（前日まで）を過ぎています。お電話でご相談ください。');
        } else {
          btn.disabled = false;
          showResult(false, 'エラー', 'キャンセルできませんでした。時間をおいて再度お試しください。');
        }
      });

      // ---- 変更 ----
      $('#toggleChange').addEventListener('click', () => {
        const box = $('#changeBox');
        box.hidden = !box.hidden;
        if (!box.hidden && !state.days.length) loadAvailability();
      });

      function setStatusLoading(msg) {
        const s = $('#slotStatus');
        s.className = 'status loading';
        s.innerHTML = '<span class="spinner" aria-hidden="true"></span><span>' + msg + '</span>';
      }
      function setStatusText(msg, kind) {
        const s = $('#slotStatus');
        s.className = 'status' + (kind ? ' ' + kind : '');
        s.textContent = msg;
      }

      async function loadAvailability() {
        calMonth = null;
        state.date = null;
        state.time = null;
        const tdb = $('#timeDialogBody'); if (tdb) tdb.innerHTML = ''; // 時刻ポップアップの前回内容をクリア
        $('#dateList').innerHTML = '<div class="cal-skeleton" aria-hidden="true"></div>';
        setStatusLoading('空き状況を確認しています…');
        const isFirst = state.booking.isFirstTime ? '1' : '0';
        const url = `${RESERVE_API}?action=availability&menuId=${encodeURIComponent(state.booking.menuId)}&isFirstTime=${isFirst}`;
        try {
          const res = await fetch(url);
          const data = await res.json();
          if (!data.ok) throw new Error('err');
          state.days = data.days || [];
          state.holidays = data.holidays || {}; // { 'yyyy-MM-dd': '祝日名' } 祝日名の表示に使う（index と揃える）
          renderDates();
        } catch (e) {
          setStatusText('空き状況を取得できませんでした。', 'err');
          $('#dateList').innerHTML = '';
        }
      }

      function renderDates() {
        const dl = $('#dateList');
        if (!state.days.length) {
          setStatusText('ご希望の期間にネット予約の空きがありません。受付時間外・定休日（日・祝など）はお電話（' + tel + '）にてご相談ください。', 'err');
          dl.innerHTML = '';
          return;
        }
        setStatusText('新しい日付を選んでください（● 印が空きありの日）。');
        state.availSet = new Set(state.days.map((d) => d.date));
        state.calMin = state.days[0].date;
        state.calMax = state.days[state.days.length - 1].date;
        if (!calMonth) {
          const [y, m] = state.calMin.split('-').map(Number);
          calMonth = { y, m: m - 1 };
        }
        renderCalendar();
      }

      function ymIndex(ymd) { const [y, m] = ymd.split('-').map(Number); return y * 12 + (m - 1); }
      function stepMonth(c, delta) { const d = new Date(c.y, c.m + delta, 1); return { y: d.getFullYear(), m: d.getMonth() }; }

      function renderCalendar() {
        const dl = $('#dateList');
        // 各日の空き枠数マップ（date -> times.length）。ヒートマップの濃淡・記号に使う。
        const countByDate = new Map(state.days.map((d) => [d.date, d.times.length]));
        const { y, m } = calMonth;
        const firstDow = new Date(y, m, 1).getDay();
        const daysInMonth = new Date(y, m + 1, 0).getDate();
        const cur = y * 12 + m;
        const canPrev = cur > ymIndex(state.calMin);
        const canNext = cur < ymIndex(state.calMax);
        let html =
          '<div class="cal-head">' +
          `<button type="button" class="cal-nav" id="calPrev" ${canPrev ? '' : 'disabled'} aria-label="前の月">‹</button>` +
          `<span class="cal-title">${y}年${m + 1}月</span>` +
          `<button type="button" class="cal-nav" id="calNext" ${canNext ? '' : 'disabled'} aria-label="次の月">›</button>` +
          '</div><div class="cal-grid">' +
          WD.map((w, i) => `<span class="cal-wd${i === 0 ? ' sun' : ''}${i === 6 ? ' sat' : ''}">${w}</span>`).join('');
        for (let i = 0; i < firstDow; i++) html += '<span class="cal-cell empty"></span>';
        for (let day = 1; day <= daysInMonth; day++) {
          const ymd = `${y}-${String(m + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
          const dow = new Date(y, m, day).getDay();
          const dowCls = dow === 0 ? ' sun' : dow === 6 ? ' sat' : '';
          if (state.availSet.has(ymd)) {
            const active = state.date === ymd ? ' active' : '';
            // 空き枠数で濃淡＋記号を出し分け（◎=空き多い / ○=残りわずか）。共有ロジック heatMark。
            const cnt = countByDate.get(ymd) || 0;
            const { mark, cls } = heatMark(cnt, { hiMin: HEAT_HI_MIN });
            const heatCls = ' ' + cls;
            html += `<button type="button" class="cal-cell cal-day avail${heatCls}${active}${dowCls}" data-date="${ymd}" title="空き ${cnt} 枠">${day}<span class="heat-mark" aria-hidden="true">${mark}</span></button>`;
          } else {
            // 非 avail は index と揃える: 祝日は祝日名、それ以外の休業・受付外・満は ✕（凡例「✕ お休み」と整合）
            const hol = state.holidays[ymd];
            if (hol) {
              html += `<span class="cal-cell cal-day disabled holiday${dowCls}" title="${esc(hol)}">${day}<small class="hol-name">${esc(hol)}</small></span>`;
            } else {
              html += `<span class="cal-cell cal-day disabled${dowCls}">${day}<span class="cal-x" aria-hidden="true">✕</span></span>`;
            }
          }
        }
        html += '</div>';
        // 凡例（index と同一）: ◎ 空きが多い / ○ 残りわずか / ✕ お休み
        html += '<p class="cal-legend"><span>◎ 空きが多い</span><span>○ 残りわずか</span><span>✕ お休み</span></p>';
        dl.innerHTML = html;
        const prev = $('#calPrev'), next = $('#calNext');
        if (prev) prev.onclick = () => { calMonth = stepMonth(calMonth, -1); renderCalendar(); };
        if (next) next.onclick = () => { calMonth = stepMonth(calMonth, 1); renderCalendar(); };
        dl.querySelectorAll('.cal-day.avail').forEach((bn) => {
          bn.addEventListener('click', () => {
            state.date = bn.dataset.date;
            state.time = null;
            $('#confirmChange').disabled = true;
            renderCalendar();
            openTimeDialog();
          });
        });
      }

      // 選択中の日付の空き時刻を、共有の renderTimeButtons で時刻ポップアップ本体に描画する。
      function renderTimes() {
        const day = state.days.find((d) => d.date === state.date);
        if (!day) { const body = $('#timeDialogBody'); if (body) body.innerHTML = ''; return; }
        renderTimeButtons(day.times, (t) => {
          state.time = t;
          $('#confirmChange').disabled = false;
        }, { title: fmtDateLabel(state.date) + ' の開始時刻', selected: state.time });
      }

      // 時刻選択ポップアップを開く（本体を描いてから共有 openTimeDlg で showModal）。
      function openTimeDialog() {
        renderTimes();
        openTimeDlg();
      }

      $('#confirmChange').addEventListener('click', () => {
        if (!state.date || !state.time) return;
        // 送信中は全面オーバーレイを出し、二重送信を弾く（共有 runExclusive）。
        runExclusive(async () => {
          const btn = $('#confirmChange');
          btn.disabled = true;
          const r = await postAction({ action: 'changeBooking', token, date: state.date, time: state.time });
          if (r.ok) {
            showResult(true, '日時を変更しました',
              `新しい日時：${fmtDateLabel(state.date)} ${state.time}〜。サロンの再確認のうえ、確定のご連絡をいたします。`);
          } else {
            btn.disabled = false;
            const e = $('#changeError');
            e.hidden = false;
            e.textContent =
              r.error === 'slot_taken' ? 'その時間はちょうど埋まってしまいました。別の時間をお選びください。' :
              r.error === 'too_late' ? '変更期限（前日まで）を過ぎています。' :
              '変更できませんでした。別の時間をお試しください。';
          }
        }, { message: '変更を送信しています…' });
      });

      load();
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      /* display:flex 等を指定した要素でも hidden 属性が確実に効くようにする */
      [hidden] { display: none !important; }
      :root {
        --c-bg: #FDF2F5; --c-surface: #FFFFFF; --c-ink: #2C1F3A; --c-muted: #7A6080;
        --c-border: #E2D0D8; --c-purple: #8B6080; --c-purple-lt: #B09AB0; --c-purple-dk: #3E2B4A;
        --c-reserve: #8B6080; --c-reserve-hv: #3E2B4A; --c-accent: #C9A84C;
        --f-serif: 'Noto Serif JP', 'YuMincho', 'Yu Mincho', serif;
      }
      body { font-family: var(--f-serif); background: var(--c-bg); color: var(--c-ink); line-height: 1.9; font-size: 16px; }
      /* 横方向の意図しないはみ出しを切り落とす（縦スクロール・sticky は維持） */
      html, body { overflow-x: clip; }
      a { color: var(--c-purple-dk); }

      /* C6: キーボードフォーカスをゴールド輪郭で明示 */
      :focus-visible {
        outline: 2px solid var(--c-accent);
        outline-offset: 2px;
        border-radius: 2px;
      }
      .site-header {
        position: sticky; top: 0; z-index: 10;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: .7rem 1rem; background: rgba(253,242,245,.92); backdrop-filter: blur(6px);
        border-bottom: 1px solid var(--c-border);
      }
      .home-link { text-decoration: none; color: var(--c-purple-dk); font-size: .9rem; }
      .head-title { font-size: .9rem; color: var(--c-muted); }
      .wrap { max-width: 600px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }

      .status { color: var(--c-muted); font-size: .92rem; padding: .5rem 0; }
      .status.err { color: #8E2230; }
      .status.loading {
        display: flex; align-items: center; gap: .55rem;
        color: var(--c-purple-dk); font-weight: 600;
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 8px;
        padding: .65rem .8rem;
      }
      .spinner {
        width: 18px; height: 18px; flex: none;
        border: 3px solid var(--c-border); border-top-color: var(--c-purple);
        border-radius: 50%; animation: spin .8s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      /* カレンダー読み込み中スケルトンは共有 reserve-calendar.css へ移設 */

      .card {
        background: var(--c-surface); border: 1px solid var(--c-border); border-radius: 12px;
        padding: 1.1rem 1rem 1.3rem; margin-bottom: 1.25rem;
      }
      .card > h2 { font-size: 1.1rem; margin-bottom: .8rem; padding-bottom: .55rem; border-bottom: 1px solid var(--c-border); }
      .card h3 { font-size: .98rem; color: var(--c-purple-dk); margin: 1rem 0 .5rem; }

      .badge { display: inline-block; font-size: .8rem; padding: .15rem .7rem; border-radius: 14px; margin-bottom: .8rem; }
      .badge.ok { background: #E2F0E8; color: #2E7D5B; }
      .badge.pending { background: #F6EFC9; color: #8a6d1a; }

      .detail-dl { display: grid; grid-template-columns: auto 1fr; gap: .25rem .9rem; font-size: .95rem; }
      .detail-dl dt { color: var(--c-muted); white-space: nowrap; }
      .detail-dl dd { margin: 0; }

      .note {
        margin-top: 1rem; font-size: .88rem; color: var(--c-muted);
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 8px; padding: .7rem .8rem;
      }
      .hint { font-size: .8rem; color: var(--c-muted); margin-top: .5rem; }

      .actions { display: flex; flex-direction: column; gap: .6rem; margin-top: 1.2rem; }

      .reserve-btn {
        display: inline-flex; align-items: center; justify-content: center; width: 100%;
        font-family: inherit; font-size: 1rem; cursor: pointer; background: var(--c-reserve); color: #fff;
        border: none; border-radius: 24px; padding: .75rem 1.2rem; min-height: 48px; text-decoration: none;
        transition: background .15s, transform .15s;
      }
      .reserve-btn:hover { background: var(--c-reserve-hv); transform: translateY(-1px); }
      .reserve-btn:disabled { opacity: .55; cursor: default; transform: none; }
      .reserve-btn.ghost { background: transparent; color: var(--c-purple-dk); border: 1px solid var(--c-border); }
      .reserve-btn.danger { background: transparent; color: #B23A48; border: 1px solid #E3B5BC; }
      .reserve-btn.danger:hover { background: #FBEAEC; }

      .change-box { margin-top: 1.2rem; border-top: 1px dashed var(--c-border); padding-top: 1rem; }
      /* カレンダー（.cal-*）・時刻ボタン（.time-*）・空き枠ヒートマップ（.heat-*）の CSS は
         共有スタイル src/styles/reserve-calendar.css へ移設（frontmatter で import 済み）。
         時刻選択ポップアップの器は共有部品 TimeDialog.astro が担う。 */
      .err-box { background: #FBEAEC; border: 1px solid #E3B5BC; color: #8E2230; border-radius: 8px; padding: .6rem .8rem; font-size: .9rem; margin-bottom: 1rem; }

      .done { text-align: center; }
      .done-mark {
        width: 3rem; height: 3rem; margin: 0 auto .5rem; border-radius: 50%; background: var(--c-purple);
        color: #fff; font-size: 1.5rem; display: flex; align-items: center; justify-content: center;
      }
      .done p { margin: .8rem 0 1rem; }

      .site-footer { text-align: center; color: var(--c-muted); font-size: .82rem; padding: 1.5rem 1rem 2.5rem; }
      .site-footer .small { font-size: .78rem; }

      /* C5: 動きを抑える設定の利用者にはアニメ・自動スクロールを無効化 */
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </body>
</html>
