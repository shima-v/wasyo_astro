---
import { RESERVE_API, ENV_LABEL } from '../../data/config.js';
import EnvBadge from '../../components/EnvBadge.astro';

const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
const salonName = 'サロン和笑〜Violane〜';
const tel = '090-9095-6034';
// title は単一の式にする（<title> RCDATA で式＋生テキストの混在を避ける）
const pageTitle = `${ENV_LABEL}予約管理 | ${salonName}`;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href={`${base}favicon.jpg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <EnvBadge />
    <header class="site-header">
      <a class="home-link" href={base}>‹ {salonName}</a>
      <span class="head-title">予約管理</span>
    </header>

    <main class="wrap">
      <!-- 管理トークン入力ゲート（未認証時のみ表示） -->
      <section class="card" id="gate">
        <h2>管理ログイン</h2>
        <p class="gate-lead">管理トークンを入力してください。トークンはこの端末にのみ保存され、外部には送られません。</p>
        <div id="gateErr" class="status err" hidden></div>
        <div class="msg-field">
          <label for="tokenInput">管理トークン</label>
          <input type="password" id="tokenInput" autocomplete="off" inputmode="text" placeholder="管理トークン" />
        </div>
        <div class="actions">
          <button type="button" class="reserve-btn" id="gateBtn">接続する</button>
        </div>
      </section>

      <!-- 管理パネル（認証後に表示） -->
      <section id="panel" hidden>
        <div class="panel-bar">
          <button type="button" class="linkish" id="logoutBtn">トークンを消去</button>
        </div>

        <!-- メニュー（セクション切替）。モバイルでも横スクロールで全機能に到達できる -->
        <nav class="admin-menu" id="adminMenu" aria-label="管理メニュー">
          <button type="button" class="menu-btn" data-sec="pending" aria-current="true">承認待ち</button>
          <button type="button" class="menu-btn" data-sec="broadcast">一斉送信</button>
          <button type="button" class="menu-btn" data-sec="schedule">臨時営業/休業</button>
          <button type="button" class="menu-btn" data-sec="slotconfig">受付枠設定</button>
          <button type="button" class="menu-btn" data-sec="quota">LINE無料枠</button>
          <button type="button" class="menu-btn" data-sec="ownertest">オーナー通知</button>
        </nav>

        <!-- 1. 承認待ち一覧 -->
        <section class="sec" id="sec-pending">
          <div class="sec-head">
            <h2 class="section-title">承認待ちの仮予約</h2>
            <button type="button" class="reserve-btn ghost sm" id="reloadPending">再読み込み</button>
          </div>
          <div id="pendingArea"><div class="status loading"><span class="spinner" aria-hidden="true"></span><span>読み込んでいます…</span></div></div>
        </section>

        <!-- 2. 一斉送信 -->
        <section class="sec" id="sec-broadcast" hidden>
          <h2 class="section-title">臨時のお知らせを一斉送信</h2>
          <p class="lead-muted">お客様へお知らせを送信します。LINE は無料枠を消費するため、送信前に「対象と残枠を確認」で人数と残りを確かめてください。</p>

          <div class="bc-scope">
            <span class="field-label">送信対象</span>
            <label class="opt"><input type="radio" name="bcScope" value="regulars" checked /> 常連（2回以上）</label>
            <label class="opt"><input type="radio" name="bcScope" value="all" /> 全予約客</label>
          </div>

          <div class="msg-field">
            <label for="bcMessage">お知らせ本文</label>
            <textarea id="bcMessage" rows="4" placeholder="例）本日◯日は都合により臨時休業いたします。ご不便をおかけします。"></textarea>
          </div>

          <div id="bcPreviewArea"></div>

          <div class="actions row wrap-actions">
            <button class="reserve-btn ghost sm" id="bcPreview" type="button">対象と残枠を確認</button>
            <button class="reserve-btn ghost sm" id="bcTest" type="button">オーナーに試し送信</button>
            <button class="reserve-btn sm" id="bcSend" type="button" disabled>この内容で一斉送信</button>
          </div>
        </section>

        <!-- 3. 臨時営業・休業の登録 -->
        <section class="sec" id="sec-schedule" hidden>
          <h2 class="section-title">臨時営業・休業の登録</h2>
          <p class="lead-muted">臨時営業・臨時休業を登録します（営業設定＋Googleカレンダーに反映）。</p>

          <div class="bc-scope">
            <span class="field-label">種別</span>
            <label class="opt"><input type="radio" name="scKind" value="closed" checked /> 臨時休業</label>
            <label class="opt"><input type="radio" name="scKind" value="open" /> 臨時営業</label>
          </div>

          <div class="row sc-row">
            <input type="date" id="scDate" />
            <label class="opt"><input type="checkbox" id="scAllDay" checked /> 終日</label>
          </div>
          <div class="row sc-row" id="scTimeRange" hidden>
            <input type="time" id="scStart" step="1800" /><span class="tilde">〜</span><input type="time" id="scEnd" step="1800" />
          </div>

          <div class="actions">
            <button class="reserve-btn sm" id="scSend" type="button">登録する</button>
          </div>
        </section>

        <!-- 4. 受付枠設定 -->
        <section class="sec" id="sec-slotconfig" hidden>
          <div class="sec-head">
            <h2 class="section-title">受付枠設定</h2>
            <button class="reserve-btn sm" id="saveConfig" type="button">保存</button>
          </div>
          <p class="lead-muted">通常の営業日（月〜金・第2/第4土）に対する例外を設定します。保存するまで反映されません。</p>

          <h3 class="sub-title">臨時休業日（この日を終日クローズ）</h3>
          <div class="chips" id="closedDatesChips"></div>
          <div class="row sc-row">
            <input type="date" id="closedDateInput" />
            <button class="reserve-btn ghost sm" id="addClosedDate" type="button">休業日を追加</button>
          </div>

          <h3 class="sub-title">臨時営業日（休みの日を終日オープン）</h3>
          <div class="chips" id="openDatesChips"></div>
          <div class="row sc-row">
            <input type="date" id="openDateInput" />
            <button class="reserve-btn ghost sm" id="addOpenDate" type="button">営業日を追加</button>
          </div>

          <h3 class="sub-title">時間枠クローズ（特定の日の特定開始時刻だけ閉じる）</h3>
          <div id="closedSlotsArea"></div>
          <div class="row sc-row">
            <input type="date" id="slotDateInput" />
            <input type="time" id="slotTimeInput" step="1800" />
            <button class="reserve-btn ghost sm" id="addClosedSlot" type="button">枠を閉じる</button>
          </div>
        </section>

        <!-- 5. LINE無料枠 -->
        <section class="sec" id="sec-quota" hidden>
          <div class="sec-head">
            <h2 class="section-title">LINE無料枠（当月）</h2>
            <button class="reserve-btn ghost sm" id="reloadQuota" type="button">再読み込み</button>
          </div>
          <div id="quotaArea"><div class="status loading"><span class="spinner" aria-hidden="true"></span><span>読み込んでいます…</span></div></div>
        </section>

        <!-- 6. オーナー通知 接続テスト -->
        <section class="sec" id="sec-ownertest" hidden>
          <h2 class="section-title">オーナー通知の接続テスト</h2>
          <p class="lead-muted">新規予約などの「お店への通知」がどこに届くか確認します。Discord を設定していれば Discord、未設定なら LINE に届きます。</p>
          <div class="actions">
            <button class="reserve-btn sm" id="ownerTest" type="button">接続テストを送る</button>
          </div>
        </section>
      </section>
    </main>

    <footer class="site-footer">
      <p>{salonName}</p>
      <p class="small">富山県高岡市野村1180-1 / <a href={`tel:${tel}`}>{tel}</a></p>
    </footer>

    <div id="toast"></div>

    <script define:vars={{ RESERVE_API }}>
      const $ = (s) => document.querySelector(s);
      const el = (id) => document.getElementById(id);
      const TOKEN_KEY = 'wasyoAdminToken';

      function esc(s) {
        return String(s == null ? '' : s).replace(/[&<>"]/g, (c) =>
          ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      }

      function getToken() { try { return localStorage.getItem(TOKEN_KEY) || ''; } catch (_) { return ''; } }
      function setToken(t) { try { localStorage.setItem(TOKEN_KEY, t); } catch (_) {} }
      function clearToken() { try { localStorage.removeItem(TOKEN_KEY); } catch (_) {} }

      function toast(msg) {
        const t = el('toast');
        t.textContent = msg;
        t.classList.add('show');
        clearTimeout(toast._t);
        toast._t = setTimeout(() => t.classList.remove('show'), 2600);
      }

      // 管理 API は全て POST（text/plain で CORS プリフライト回避）。adminToken を毎回添付。
      async function apiPost(action, extra) {
        const payload = Object.assign({ action, adminToken: getToken() }, extra || {});
        const res = await fetch(RESERVE_API, {
          method: 'POST',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(payload),
        });
        return res.json();
      }

      // ---- 認証ゲートの出し入れ ----
      function showGate(errMsg) {
        el('panel').hidden = true;
        el('gate').hidden = false;
        const e = el('gateErr');
        if (errMsg) { e.textContent = errMsg; e.hidden = false; } else { e.hidden = true; }
        el('tokenInput').focus();
      }
      function showPanel() {
        el('gate').hidden = true;
        el('panel').hidden = false;
      }

      // forbidden（トークン不正）を検知したら token を消してゲートへ戻す
      function handleForbidden() {
        clearToken();
        showGate('管理トークンが無効です。正しいトークンを入力してください。');
      }

      // ============================================================
      // メニュー（セクション切替）
      // 選択中セクションのみ表示。初回表示時に一度だけ各セクションを遅延ロードする。
      // ============================================================
      const SECTIONS = ['pending', 'broadcast', 'schedule', 'slotconfig', 'quota', 'ownertest'];
      const loaded = {};
      function showSection(name) {
        SECTIONS.forEach((s) => {
          const secEl = el('sec-' + s);
          if (secEl) secEl.hidden = (s !== name);
        });
        document.querySelectorAll('.menu-btn').forEach((b) => {
          const on = b.getAttribute('data-sec') === name;
          if (on) b.setAttribute('aria-current', 'true'); else b.removeAttribute('aria-current');
        });
        // 各セクションの初回表示で必要なデータを一度だけ取得する
        if (!loaded[name]) {
          loaded[name] = true;
          if (name === 'pending') loadPending();
          else if (name === 'quota') loadQuota();
          else if (name === 'slotconfig') loadConfig();
        }
      }
      el('adminMenu').addEventListener('click', (e) => {
        const btn = e.target.closest('.menu-btn');
        if (!btn) return;
        showSection(btn.getAttribute('data-sec'));
      });

      // ============================================================
      // 1. 承認待ち一覧
      // ============================================================
      async function loadPending() {
        el('pendingArea').innerHTML =
          '<div class="status loading"><span class="spinner" aria-hidden="true"></span><span>読み込んでいます…</span></div>';
        let res;
        try {
          res = await apiPost('listPending');
        } catch (_) {
          el('pendingArea').innerHTML = '<div class="empty">通信に失敗しました。時間をおいて再度お試しください。</div>';
          return;
        }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        renderPending(res);
      }

      function renderPending(res) {
        const area = el('pendingArea');
        if (!res || !res.ok) { area.innerHTML = '<div class="empty">取得に失敗しました。</div>'; return; }
        const list = res.pending || [];
        if (!list.length) { area.innerHTML = '<div class="empty">承認待ちの仮予約はありません。</div>'; return; }
        area.innerHTML = list.map((p) => {
          const badges = (p.isFirstTime ? '<span class="badge first">新規</span>' : '')
            + (p.gender === 'male' ? '<span class="badge male">男性</span>' : '');
          const contact = [p.phone, p.email].filter(Boolean).map(esc).join(' / ');
          return '<div class="pcard" data-token="' + esc(p.token) + '">'
            + '<div class="pcard-title">' + esc(p.name) + ' 様' + badges + '</div>'
            + '<dl class="detail-dl">'
            + '<dt>メニュー</dt><dd>' + esc(p.menuName) + '</dd>'
            + '<dt>日時</dt><dd>' + esc(p.date) + ' ' + esc(p.time) + '</dd>'
            + (p.gender === 'male' ? '<dt>紹介者</dt><dd>' + esc(p.referrer || '（未記入）') + '</dd>' : '')
            + (contact ? '<dt>連絡先</dt><dd>' + contact + '</dd>' : '')
            + (p.note ? '<dt>ご要望</dt><dd>' + esc(p.note) + '</dd>' : '')
            + '</dl>'
            + '<textarea class="cust-msg" rows="2" placeholder="お客様へのメッセージ（任意・承認/辞退の通知に添えます）"></textarea>'
            + '<div class="actions row">'
            + '<button class="reserve-btn sm" type="button" data-act="approve">承認して確定</button>'
            + '<button class="reserve-btn sm decline" type="button" data-act="decline">辞退</button>'
            + '</div></div>';
        }).join('');
      }

      async function decide(token, approve, btn) {
        const card = btn.closest('.pcard');
        const msgEl = card.querySelector('.cust-msg');
        const message = msgEl ? msgEl.value : '';
        const btns = card.querySelectorAll('button');
        btns.forEach((b) => { b.disabled = true; });
        let res;
        try {
          res = await apiPost('adminDecision', { token, approve, message });
        } catch (_) {
          toast('通信エラー。時間をおいて再度お試しください。');
          btns.forEach((b) => { b.disabled = false; });
          return;
        }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (res && res.ok) {
          toast(approve ? '確定しました（お客様へ通知済み）' : '辞退しました（お客様へ通知済み）');
          card.parentNode.removeChild(card);
          if (!el('pendingArea').querySelector('.pcard')) {
            el('pendingArea').innerHTML = '<div class="empty">承認待ちの仮予約はありません。</div>';
          }
        } else {
          toast('失敗: ' + ((res && res.error) || '不明なエラー'));
          btns.forEach((b) => { b.disabled = false; });
        }
      }

      el('pendingArea').addEventListener('click', (e) => {
        const btn = e.target.closest('button[data-act]');
        if (!btn) return;
        const token = btn.closest('.pcard').getAttribute('data-token');
        const approve = btn.getAttribute('data-act') === 'approve';
        if (!approve && !confirm('この仮予約を辞退します。お客様へ通知されます。よろしいですか？')) return;
        decide(token, approve, btn);
      });
      el('reloadPending').addEventListener('click', loadPending);

      // ============================================================
      // 5. LINE無料枠（当月送信数）
      // ============================================================
      async function loadQuota() {
        el('quotaArea').innerHTML =
          '<div class="status loading"><span class="spinner" aria-hidden="true"></span><span>読み込んでいます…</span></div>';
        let res;
        try {
          res = await apiPost('getQuota');
        } catch (_) {
          el('quotaArea').innerHTML = '<div class="empty">取得に失敗しました。時間をおいて再度お試しください。</div>';
          return;
        }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        renderQuota(res);
      }
      function renderQuota(res) {
        const area = el('quotaArea');
        if (!res || !res.ok) { area.innerHTML = '<div class="empty">取得に失敗しました。</div>'; return; }
        if (res.used == null) {
          area.innerHTML = '<div class="empty">送信数を取得できませんでした（LINEトークン未設定の可能性）。</div>';
          return;
        }
        const pct = res.limit ? Math.round(res.used / res.limit * 100) : 0;
        const warn = pct >= 80;
        area.innerHTML = '<div class="quota-num"><strong>' + res.used + ' / ' + res.limit + ' 通</strong>'
          + '<span class="muted">（残り ' + res.available + ' 通・' + pct + '%）</span></div>'
          + (warn
            ? '<div class="empty warn">⚠ 無料枠の80%を超えています。上限を超えると追加メッセージは送信されません。</div>'
            : '');
      }
      el('reloadQuota').addEventListener('click', loadQuota);

      // ============================================================
      // 2. 一斉送信
      // ============================================================
      // 送信 confirm で使うため、直近プレビューの対象人数を保持する
      const bcCounts = { line: 0, mail: 0 };

      function bcScope() {
        const r = document.querySelector('input[name="bcScope"]:checked');
        return r ? r.value : 'regulars';
      }
      function bcMessage() { return el('bcMessage').value; }

      // 本文（プレビュー）を作る。送信後見込み used+lineCount も併記
      function renderBcPreview(res) {
        const area = el('bcPreviewArea');
        if (!res || !res.ok) { area.innerHTML = '<div class="empty">確認に失敗しました。</div>'; el('bcSend').disabled = true; return; }
        bcCounts.line = res.lineCount;
        bcCounts.mail = res.mailCount;
        const quotaStr = (res.used == null)
          ? '無料枠は取得できませんでした'
          : '今月 ' + res.used + '/' + res.limit + ' 通（残 ' + res.available + '）・送信後見込み ' + (res.used + res.lineCount);
        let head = '<div class="pcard"><div class="pcard-title">送信対象</div>'
          + '<div class="bc-count">LINE ' + res.lineCount + '人 / メール ' + res.mailCount + '人 / 届かない ' + res.unreachable + '人</div>'
          + '<div class="muted">' + esc(quotaStr) + '</div>';
        if (res.willExceed) {
          area.innerHTML = head
            + '<div class="empty warn">⚠ 残枠不足のため送信できません（LINE対象 ' + res.lineCount + '人 > 残 ' + res.available + '）。</div></div>';
          el('bcSend').disabled = true;
        } else {
          area.innerHTML = head + '</div>';
          el('bcSend').disabled = false;
        }
      }

      // 対象と残枠を確認
      el('bcPreview').addEventListener('click', async () => {
        if (!bcMessage().trim()) { toast('本文を入力してください'); return; }
        el('bcPreviewArea').innerHTML = '<div class="status loading"><span class="spinner" aria-hidden="true"></span><span>確認中…</span></div>';
        const btn = el('bcPreview'); btn.disabled = true;
        let res;
        try {
          res = await apiPost('broadcastPreview', { scope: bcScope() });
        } catch (_) {
          btn.disabled = false;
          el('bcPreviewArea').innerHTML = '<div class="empty">確認に失敗しました。時間をおいて再度お試しください。</div>';
          return;
        }
        btn.disabled = false;
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        renderBcPreview(res);
      });

      // オーナーに試し送信
      el('bcTest').addEventListener('click', async () => {
        if (!bcMessage().trim()) { toast('本文を入力してください'); return; }
        const btn = el('bcTest'); btn.disabled = true;
        let res;
        try {
          res = await apiPost('broadcastTest', { message: bcMessage() });
        } catch (_) {
          btn.disabled = false; toast('通信エラー。時間をおいて再度お試しください。'); return;
        }
        btn.disabled = false;
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (res && res.ok) toast('オーナーに試し送信しました');
        else toast('試し送信に失敗: ' + ((res && res.error) || '不明'));
      });

      // 一斉送信の実行
      el('bcSend').addEventListener('click', async () => {
        const btn = el('bcSend');
        if (!bcMessage().trim()) { toast('本文を入力してください'); return; }
        if (!confirm('LINE ' + bcCounts.line + '人・メール ' + bcCounts.mail + '人へ送信します。よろしいですか？')) return;
        btn.disabled = true;
        let res;
        try {
          res = await apiPost('broadcast', { scope: bcScope(), message: bcMessage() });
        } catch (_) {
          btn.disabled = false; toast('通信エラー。時間をおいて再度お試しください。'); return;
        }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (res && res.ok) {
          toast('送信しました（LINE ' + res.sentLine + '人 / メール ' + res.sentMail + '人）');
          // 送信後は残枠が変わるため、再確認を促して無効のまま維持
          btn.disabled = true;
        } else {
          btn.disabled = false;
          if (res && res.error === 'quota_exceeded') {
            toast('残枠不足で送信できません（必要 ' + res.need + '・残 ' + res.available + '）');
          } else {
            toast('送信に失敗: ' + ((res && res.error) || '不明'));
          }
        }
      });

      // ============================================================
      // 3. 臨時営業・休業の登録
      // ============================================================
      function scKind() {
        const r = document.querySelector('input[name="scKind"]:checked');
        return r ? r.value : 'closed';
      }
      // 時間帯入力（scTimeRange）は「終日」オフのときだけ表示
      function applyScAllDay() {
        el('scTimeRange').hidden = el('scAllDay').checked;
      }
      el('scAllDay').addEventListener('change', applyScAllDay);
      applyScAllDay();

      function scPayload() {
        return {
          kind: scKind(),
          date: el('scDate').value,
          allDay: el('scAllDay').checked,
          start: el('scStart').value,
          end: el('scEnd').value,
        };
      }
      function validateSchedule() {
        const p = scPayload();
        if (!p.date) { toast('日付を入力してください'); return false; }
        if (!p.allDay) {
          if (!p.start || !p.end) { toast('開始と終了の時刻を入力してください'); return false; }
          if (p.start >= p.end) { toast('終了は開始より後にしてください'); return false; }
        }
        return true;
      }
      function scheduleLabel(res) {
        const kindStr = res.kind === 'closed' ? '臨時休業' : '臨時営業';
        const timeStr = res.allDay ? '終日' : (res.start + '〜' + res.end);
        return kindStr + '／' + res.date + '／' + timeStr;
      }

      el('scSend').addEventListener('click', async () => {
        if (!validateSchedule()) return;
        const btn = el('scSend'); btn.disabled = true;
        const payload = scPayload();
        let res;
        try {
          res = await apiPost('setTempSchedule', payload);
        } catch (_) {
          btn.disabled = false; toast('通信エラー。時間をおいて再度お試しください。'); return;
        }
        btn.disabled = false;
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (res && res.ok) toast('登録しました（' + scheduleLabel(payload) + '）');
        else toast('登録に失敗: ' + ((res && res.error) || '不明'));
      });

      // ============================================================
      // 4. 受付枠設定
      // ============================================================
      // 取得した config を丸ごと保持し、編集対象の3キーだけを操作する。
      // これにより openWindows など未編集のキーが保存で失われない。
      let config = { closedDates: [], openDates: [], closedSlots: {} };

      async function loadConfig() {
        let res;
        try {
          res = await apiPost('getSlotConfig');
        } catch (_) { renderConfig(); return; }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (res && res.ok && res.config) {
          config = res.config;
          config.closedDates = config.closedDates || [];
          config.openDates = config.openDates || [];
          config.closedSlots = config.closedSlots || {};
        }
        renderConfig();
      }

      function dateChip(value, listName) {
        return '<span class="chip">' + esc(value)
          + '<button type="button" data-list="' + listName + '" data-val="' + esc(value) + '">×</button></span>';
      }

      function renderConfig() {
        config.closedDates.sort();
        config.openDates.sort();
        el('closedDatesChips').innerHTML = config.closedDates.length
          ? config.closedDates.map((d) => dateChip(d, 'closedDates')).join('')
          : '<span class="muted">なし</span>';
        el('openDatesChips').innerHTML = config.openDates.length
          ? config.openDates.map((d) => dateChip(d, 'openDates')).join('')
          : '<span class="muted">なし</span>';

        const dates = Object.keys(config.closedSlots).filter((d) =>
          config.closedSlots[d] && config.closedSlots[d].length).sort();
        el('closedSlotsArea').innerHTML = dates.length ? dates.map((d) => {
          const times = config.closedSlots[d].slice().sort();
          return '<div class="row slot-row"><strong class="slot-date">' + esc(d) + '</strong><div class="chips">'
            + times.map((t) =>
              '<span class="chip">' + esc(t)
              + '<button type="button" data-slot-date="' + esc(d) + '" data-slot-time="' + esc(t) + '">×</button></span>'
            ).join('') + '</div></div>';
        }).join('') : '<div class="muted">なし</div>';
      }

      // 日付チップ削除
      function removeDateChip(e) {
        const b = e.target.closest('button[data-list]'); if (!b) return;
        const list = b.getAttribute('data-list'), val = b.getAttribute('data-val');
        config[list] = config[list].filter((v) => v !== val);
        renderConfig();
      }
      el('closedDatesChips').addEventListener('click', removeDateChip);
      el('openDatesChips').addEventListener('click', removeDateChip);

      // 時間枠チップ削除
      el('closedSlotsArea').addEventListener('click', (e) => {
        const b = e.target.closest('button[data-slot-date]'); if (!b) return;
        const d = b.getAttribute('data-slot-date'), t = b.getAttribute('data-slot-time');
        config.closedSlots[d] = (config.closedSlots[d] || []).filter((v) => v !== t);
        if (!config.closedSlots[d].length) delete config.closedSlots[d];
        renderConfig();
      });

      // 追加ボタン
      el('addClosedDate').addEventListener('click', () => {
        const v = el('closedDateInput').value; if (!v) return;
        if (config.closedDates.indexOf(v) < 0) config.closedDates.push(v);
        el('closedDateInput').value = ''; renderConfig();
      });
      el('addOpenDate').addEventListener('click', () => {
        const v = el('openDateInput').value; if (!v) return;
        if (config.openDates.indexOf(v) < 0) config.openDates.push(v);
        el('openDateInput').value = ''; renderConfig();
      });
      el('addClosedSlot').addEventListener('click', () => {
        const d = el('slotDateInput').value; let t = el('slotTimeInput').value;
        if (!d || !t) { toast('日付と時刻を指定してください'); return; }
        t = t.slice(0, 5); // HH:mm
        config.closedSlots[d] = config.closedSlots[d] || [];
        if (config.closedSlots[d].indexOf(t) < 0) config.closedSlots[d].push(t);
        el('slotTimeInput').value = ''; renderConfig();
      });

      // 保存
      el('saveConfig').addEventListener('click', async () => {
        const btn = el('saveConfig'); btn.disabled = true;
        let res;
        try {
          res = await apiPost('setSlotConfig', { config });
        } catch (_) {
          btn.disabled = false; toast('通信エラー。時間をおいて再度お試しください。'); return;
        }
        btn.disabled = false;
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        toast(res && res.ok ? '保存しました' : '保存に失敗: ' + ((res && res.error) || '不明'));
      });

      // ============================================================
      // 6. オーナー通知 接続テスト
      // ============================================================
      el('ownerTest').addEventListener('click', async () => {
        const btn = el('ownerTest'); btn.disabled = true;
        let res;
        try {
          res = await apiPost('ownerChannelTest');
        } catch (_) {
          btn.disabled = false; toast('通信エラー。時間をおいて再度お試しください。'); return;
        }
        btn.disabled = false;
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (res && res.ok) toast(res.via === 'discord' ? 'Discord に接続テストを送りました' : 'LINE に接続テストを送りました（Discord未設定）');
        else toast('テストに失敗: ' + ((res && res.error) || '不明'));
      });

      // ---- ゲートのイベント配線 ----
      el('logoutBtn').addEventListener('click', () => { clearToken(); showGate(); });
      el('gateBtn').addEventListener('click', () => {
        const t = el('tokenInput').value.trim();
        if (!t) { showGate('管理トークンを入力してください。'); return; }
        setToken(t);
        el('tokenInput').value = '';
        // 認証済みの状態でパネルを開き、初期セクション（承認待ち）を表示
        Object.keys(loaded).forEach((k) => delete loaded[k]);
        showPanel();
        showSection('pending');
      });
      el('tokenInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') el('gateBtn').click(); });

      // ---- 起動 ----
      if (getToken()) { showPanel(); showSection('pending'); } else { showGate(); }
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      [hidden] { display: none !important; }
      :root {
        --c-bg: #FDF2F5; --c-surface: #FFFFFF; --c-ink: #2C1F3A; --c-muted: #7A6080;
        --c-border: #E2D0D8; --c-purple: #8B6080; --c-purple-lt: #B09AB0; --c-purple-dk: #3E2B4A;
        --c-reserve: #8B6080; --c-reserve-hv: #3E2B4A; --c-accent: #C9A84C;
        --f-serif: 'Noto Serif JP', 'YuMincho', 'Yu Mincho', serif;
      }
      body { font-family: var(--f-serif); background: var(--c-bg); color: var(--c-ink); line-height: 1.9; font-size: 16px; }
      html, body { overflow-x: clip; }
      a { color: var(--c-purple-dk); }
      :focus-visible { outline: 2px solid var(--c-accent); outline-offset: 2px; border-radius: 2px; }

      .site-header {
        position: sticky; top: 0; z-index: 10;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        padding: .7rem 1rem; background: rgba(253,242,245,.92); backdrop-filter: blur(6px);
        border-bottom: 1px solid var(--c-border);
      }
      .home-link { text-decoration: none; color: var(--c-purple-dk); font-size: .9rem; }
      .head-title { font-size: .9rem; color: var(--c-muted); }
      .wrap { max-width: 640px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }

      .status { color: var(--c-muted); font-size: .92rem; padding: .5rem 0; }
      .status.err { color: #8E2230; }
      .status.loading {
        display: flex; align-items: center; gap: .55rem;
        color: var(--c-purple-dk); font-weight: 600;
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 8px; padding: .65rem .8rem;
      }
      .spinner {
        width: 18px; height: 18px; flex: none;
        border: 3px solid var(--c-border); border-top-color: var(--c-purple);
        border-radius: 50%; animation: spin .8s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      .card {
        background: var(--c-surface); border: 1px solid var(--c-border); border-radius: 12px;
        padding: 1.1rem 1rem 1.3rem; margin-bottom: 1.25rem;
      }
      .card > h2 { font-size: 1.15rem; margin-bottom: .8rem; padding-bottom: .55rem; border-bottom: 1px solid var(--c-border); }
      .gate-lead { font-size: .9rem; color: var(--c-muted); margin-bottom: .9rem; }

      .section-title { font-size: 1.05rem; margin: 0; color: var(--c-purple-dk); }
      .sub-title { font-size: .92rem; margin: 1.1rem 0 .5rem; color: var(--c-purple-dk); }
      .lead-muted { font-size: .88rem; color: var(--c-muted); margin: .5rem 0 1rem; }
      .panel-bar { display: flex; align-items: center; justify-content: flex-end; gap: 1rem; margin-bottom: .8rem; }
      .linkish { background: none; border: none; color: var(--c-muted); font-size: .85rem; cursor: pointer; text-decoration: underline; font-family: inherit; }

      /* メニュー：横並び、狭幅では横スクロールで全項目に到達可能。選択中を強調 */
      .admin-menu {
        display: flex; gap: .5rem; overflow-x: auto; -webkit-overflow-scrolling: touch;
        padding: .2rem .1rem .6rem; margin-bottom: 1.1rem;
        border-bottom: 1px solid var(--c-border); scrollbar-width: thin;
      }
      .menu-btn {
        flex: 0 0 auto; font-family: inherit; font-size: .9rem; cursor: pointer;
        background: transparent; color: var(--c-purple-dk);
        border: 1px solid var(--c-border); border-radius: 20px;
        padding: .45rem 1rem; min-height: 42px; white-space: nowrap;
        transition: background .15s, color .15s, border-color .15s;
      }
      .menu-btn:hover { background: #FCF6FA; }
      .menu-btn[aria-current="true"] {
        background: var(--c-reserve); color: #fff; border-color: var(--c-reserve);
      }

      .sec { }
      .sec-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: .3rem; }

      .empty { color: var(--c-muted); font-size: .92rem; background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 8px; padding: .8rem; }
      .empty.warn { color: #8E2230; }
      .muted { color: var(--c-muted); font-size: .88rem; }

      .pcard { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: 12px; padding: 1rem; margin-bottom: 1rem; }
      .pcard-title { font-size: 1.05rem; font-weight: 600; margin-bottom: .6rem; }
      .bc-count { font-size: .95rem; margin-bottom: .3rem; }

      .badge { display: inline-block; font-size: .72rem; padding: .1rem .55rem; border-radius: 12px; margin-left: .4rem; vertical-align: middle; }
      .badge.first { background: #F6EFC9; color: #8a6d1a; }
      .badge.male { background: #E4E9F5; color: #3a4a7a; }

      .detail-dl { display: grid; grid-template-columns: auto 1fr; gap: .2rem .9rem; font-size: .92rem; }
      .detail-dl dt { color: var(--c-muted); white-space: nowrap; }
      .detail-dl dd { margin: 0; word-break: break-word; }

      .quota-num { font-size: 1.1rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: .5rem; margin-bottom: .5rem; }

      /* 送信対象・種別などの選択肢グループ */
      .bc-scope { display: flex; flex-wrap: wrap; align-items: center; gap: .3rem .9rem; margin-bottom: .9rem; }
      .field-label { font-size: .9rem; color: var(--c-muted); margin-right: .2rem; }
      .opt { font-size: .95rem; display: inline-flex; align-items: center; gap: .35rem; cursor: pointer; }
      .opt input { width: auto; }

      .msg-field { margin-top: .3rem; }
      .msg-field label { display: block; font-size: .9rem; color: var(--c-muted); margin-bottom: .35rem; }
      .msg-field input, .cust-msg, #bcMessage {
        width: 100%; font-family: inherit; font-size: 1rem; line-height: 1.7;
        padding: .6rem .7rem; border: 1px solid var(--c-border); border-radius: 8px;
        background: #fff; color: var(--c-ink);
      }
      .cust-msg, #bcMessage { margin-top: .5rem; resize: vertical; }
      .msg-field input:focus, .cust-msg:focus, #bcMessage:focus { border-color: var(--c-purple-lt); }

      /* 日付/時刻入力の行 */
      .sc-row { display: flex; flex-wrap: wrap; align-items: center; gap: .5rem; margin: .5rem 0; }
      .sc-row input[type="date"], .sc-row input[type="time"] {
        font-family: inherit; font-size: 1rem; line-height: 1.7;
        padding: .55rem .6rem; border: 1px solid var(--c-border); border-radius: 8px;
        background: #fff; color: var(--c-ink); min-width: 0;
      }
      .tilde { color: var(--c-muted); }
      .slot-row { align-items: center; gap: .6rem; }
      .slot-date { min-width: 6.5em; }

      /* チップ（設定済みの日付・時刻） */
      .chips { display: flex; flex-wrap: wrap; gap: .4rem; margin: .35rem 0 .2rem; }
      .chip {
        display: inline-flex; align-items: center; gap: .35rem;
        background: var(--c-bg); border: 1px solid var(--c-border);
        border-radius: 16px; padding: .2rem .35rem .2rem .7rem; font-size: .88rem;
      }
      .chip button {
        background: none; border: none; color: #b00020; cursor: pointer;
        font-size: 1.1rem; line-height: 1; padding: 0; min-width: 30px; min-height: 30px;
        border-radius: 50%; font-family: inherit;
      }
      .chip button:hover { background: rgba(176,0,32,.12); }

      .actions { display: flex; flex-direction: column; gap: .6rem; margin-top: 1rem; }
      .actions.row { flex-direction: row; }
      .actions.wrap-actions { flex-wrap: wrap; }

      .reserve-btn {
        display: inline-flex; align-items: center; justify-content: center; width: 100%;
        font-family: inherit; font-size: 1rem; cursor: pointer; background: var(--c-reserve); color: #fff;
        border: none; border-radius: 24px; padding: .7rem 1.2rem; min-height: 46px; text-decoration: none;
        transition: background .15s, transform .15s;
      }
      .reserve-btn:hover { background: var(--c-reserve-hv); transform: translateY(-1px); }
      .reserve-btn:disabled { opacity: .55; cursor: default; transform: none; }
      .reserve-btn.ghost { background: transparent; color: var(--c-purple-dk); border: 1px solid var(--c-border); }
      .reserve-btn.ghost:hover { background: #FCF6FA; }
      .reserve-btn.sm { width: auto; font-size: .9rem; padding: .5rem 1rem; min-height: 40px; }
      .reserve-btn.decline { background: #b00020; }
      .reserve-btn.decline:hover { background: #8a0019; }

      #toast {
        position: fixed; left: 50%; bottom: 1.4rem; transform: translateX(-50%) translateY(1rem);
        background: var(--c-purple-dk); color: #fff; font-size: .9rem; padding: .6rem 1.1rem; border-radius: 22px;
        opacity: 0; pointer-events: none; transition: opacity .2s, transform .2s; max-width: 90vw; text-align: center;
      }
      #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

      .site-footer { text-align: center; color: var(--c-muted); font-size: .82rem; padding: 1.5rem 1rem 2.5rem; }
      .site-footer .small { font-size: .78rem; }

      /* スマホ対応（オーナーはスマホ利用）。入力欄・ボタンを押しやすく */
      @media (max-width: 600px) {
        .wrap { padding: 1.25rem .85rem 3.5rem; }
        .menu-btn { min-height: 46px; }
        /* 入力欄は行内で幅いっぱい＋縮小可。font-size:16px は iOS Safari のフォーカス時自動ズームを防ぐ下限 */
        .sc-row input[type="date"], .sc-row input[type="time"] { flex: 1 1 40%; font-size: 16px; }
        /* 追加/枠を閉じるボタンは次行で全幅（指で押しやすく） */
        .sc-row > button { flex: 1 1 100%; }
        /* 一斉送信のアクション行：狭幅では縦積みで大きく */
        .actions.wrap-actions { flex-direction: column; }
        .actions.wrap-actions .reserve-btn.sm { width: 100%; min-height: 48px; }
        /* 承認/辞退は横並びのまま均等幅で大きく */
        .actions.row { gap: .45rem; }
        .actions.row .reserve-btn.sm { flex: 1 1 0; min-height: 48px; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.001ms !important; animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important; scroll-behavior: auto !important;
        }
      }
    </style>
  </body>
</html>
