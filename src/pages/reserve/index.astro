---
import { MENU, MENU_GROUPS, formatYen } from '../../data/menu.js';
import {
  RESERVE_API,
  BOOKING_RULES,
  GENDERS,
  CONTACT_METHODS,
  ENV_LABEL,
  LINE_LOGIN_CHANNEL_ID,
  LINE_LOGIN_REDIRECT,
  LIFF_ID,
} from '../../data/config.js';
import EnvBadge from '../../components/EnvBadge.astro';
import SubmitOverlay from '../../components/SubmitOverlay.astro';
import TimeDialog from '../../components/TimeDialog.astro';
import '../../styles/reserve-calendar.css';

const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
const salonName = 'サロン和笑〜Violane〜';
const tel = '090-9095-6034';
// title は単一の式にする（<title> RCDATA で式＋生テキストの混在を避ける）
const pageTitle = `${ENV_LABEL}ご予約 | ${salonName}`;

// コース区分ごとにメニューをまとめる
const groupOrder = ['recommend', 'simple', 'petit'];
const grouped = groupOrder.map((g) => ({
  key: g,
  group: MENU_GROUPS[g],
  items: MENU.filter((m) => m.group === g),
}));
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href={`${base}favicon.jpg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1, interactive-widget=resizes-content" />
    <meta name="robots" content="noindex" />
    <title>{pageTitle}</title>
    <meta name="description" content="サロン和笑〜Violane〜 のオンライン予約。メニューと日時を選んでお申し込みいただけます。" />
    {LIFF_ID ? <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script> : null}
    <!-- #3 ちらつき対策: LINE 認可からの復帰中（URL に code&state）は、
         本文の描画前に body へ data-line-returning を付ける。CSS で①メニュー等の
         .step を隠し、全面ローディングだけを見せる。handleLineReturn 完了で解除する。 -->
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search);
          if (p.get('code') && p.get('state')) {
            document.documentElement.setAttribute('data-line-returning', '');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <EnvBadge />
    <!-- #3 LINE復帰中の全面ローディング（data-line-returning のときだけ表示）。
         ①メニューを一切見せず、確認中の表示だけを出す。 -->
    <div id="lineReturnLoading" class="line-return-loading" aria-live="polite">
      <span class="spinner" aria-hidden="true"></span>
      <p>LINE連携を確認しています…</p>
    </div>
    <!-- 予約送信中の全面オーバーレイ（⑤で送信ボタン押下〜応答まで）。二重送信防止＋送信中の強調。共有部品 SubmitOverlay -->
    <SubmitOverlay />
    <header class="site-header">
      <a class="home-link" href={base}>‹ {salonName}</a>
      <span class="head-title">オンラインご予約</span>
    </header>

    <main class="wrap">
      <!-- 上部は1行に短縮（受付時間表・当日注意は日時ステップ／ポップアップへ移設してコンパクト化） -->
      <p class="lead">
        お申し込みは仮予約です。サロン確認後に確定のご連絡をします。
      </p>

      <!-- ステップインジケーター（ドット5つ）。全ステップで常に表示、完了時のみ非表示 -->
      <ol class="steps-indicator" aria-label="ご予約の進み具合">
        <li data-step="1" class="is-active" aria-current="step"><span class="dot"></span><span class="lbl">メニュー</span></li>
        <li data-step="2"><span class="dot"></span><span class="lbl">日時</span></li>
        <li data-step="3"><span class="dot"></span><span class="lbl">情報</span></li>
        <li data-step="4"><span class="dot"></span><span class="lbl">要望</span></li>
        <li data-step="5"><span class="dot"></span><span class="lbl">確認</span></li>
      </ol>

      <!-- 営業時間ポップアップ（ネイティブ dialog）。②日時ステップの「営業時間を見る」から開く。中身は旧 ul.hours を流用 -->
      <dialog id="hoursDialog" class="hours-dialog" aria-label="ネット予約の受付時間">
        <div class="hours-dialog-head">
          <strong>ネット予約の受付時間</strong>
          <button type="button" class="hours-close" id="hoursClose" aria-label="閉じる">×</button>
        </div>
        <ul class="hours">
          <li><span class="hours-day">月・火・金</span><span class="hours-time">10:00〜15:00 / 17:30〜19:00</span></li>
          <li><span class="hours-day">水・木</span><span class="hours-time">10:00〜15:00</span></li>
          <li><span class="hours-day">土（第2・第4のみ）</span><span class="hours-time">10:00〜19:00</span></li>
          <li class="closed"><span class="hours-day">日・祝</span><span class="hours-time">お休み（緊急対応はお電話にてお問い合わせください）</span></li>
        </ul>
      </dialog>

      <!-- 時刻選択ポップアップ（ネイティブ dialog）。②で日付をタップすると開く。共有部品 TimeDialog -->
      <TimeDialog />

      <!-- 前回メニューの確認ポップアップ（#4・時刻/営業時間ダイアログの作法を流用） -->
      <dialog id="lastMenuDialog" class="last-menu-dialog" aria-label="前回のメニューで予約">
        <div class="last-menu-dialog-head">
          <strong>前回のメニューで予約</strong>
          <button type="button" class="hours-close" id="lastMenuClose" aria-label="閉じる">×</button>
        </div>
        <div class="last-menu-dialog-body">
          <dl class="last-menu-dl">
            <dt>メニュー</dt><dd id="lm-name"></dd>
            <dt>料金</dt><dd id="lm-price"></dd>
            <dt>所要</dt><dd id="lm-duration"></dd>
          </dl>
          <button type="button" class="reserve-btn" id="lastMenuConfirm">このメニューで日時を選ぶ</button>
        </div>
      </dialog>

      <!-- STEP 1: メニュー -->
      <section class="step" id="step-menu">
        <h2 tabindex="-1"><span class="step-no">1</span> メニューを選ぶ</h2>
        <!-- 常連ウェルカムバナー（#4）。①メニューステップの中に置くので、②以降へ進むと step ごと隠れる。
             常連（LINE連携済み＋前回メニューが現行に存在）のときだけ JS で表示。 -->
        <section class="welcome-banner" id="welcomeBanner" aria-label="常連のお客様向けショートカット" hidden>
          <p class="welcome-lead" id="welcomeLead"></p>
          <button type="button" class="welcome-shortcut" id="welcomeShortcut">
            <span class="welcome-shortcut-label" id="welcomeShortcutLabel"></span>
            <span class="welcome-shortcut-arrow" aria-hidden="true">→</span>
          </button>
        </section>
        {grouped.map((g, i) => (
          <details class="menu-group" open={i === 0} name="menu-course">
            <summary class="menu-group-head">
              <span class="menu-group-title">{g.group.label}{g.group.desc ? <small>{g.group.desc}</small> : null}</span>
              <span class="menu-group-aside">
                <span class="menu-group-count">{g.items.length}件</span>
                <span class="tap-hint">タップで表示</span>
                <span class="caret" aria-hidden="true">▼</span>
              </span>
            </summary>
            <div class="menu-list">
              {g.items.map((m) => (
                <label class="menu-item">
                  <input
                    type="radio"
                    name="menu"
                    value={m.id}
                    data-name={m.name}
                    data-duration={m.durationMin}
                    data-slot={m.slotMin}
                    data-price={m.price}
                    data-firsttime={m.firstTime ? m.firstTime.label : ''}
                    data-hasfirst={m.firstTime ? '1' : '0'}
                  />
                  <span class="menu-body">
                    <span class="menu-name">{m.name}</span>
                    <span class="menu-meta">
                      {m.durationMin}分 / {formatYen(m.price)}
                      {m.firstTime ? <em class="first-tag">初回 {m.firstTime.label}・料金そのまま</em> : null}
                    </span>
                    {m.note ? <span class="menu-note">{m.note}</span> : null}
                  </span>
                </label>
              ))}
            </div>
          </details>
        ))}
      </section>

      <!-- STEP 2: 日時 -->
      <section class="step" id="step-date" hidden>
        <h2 tabindex="-1"><span class="step-no">2</span> 日時を選ぶ</h2>
        <!-- 営業時間はリンク→ポップアップに（上部から移設してコンパクト化） -->
        <p class="hours-link-row">
          <button type="button" class="hours-link" id="hoursOpen">営業時間を見る</button>
        </p>
        <!-- 当日注意は日時ステップだけに表示（上部から移設） -->
        <p class="note-today">
          ※ ネット予約は受付時間内の「開始時刻」をお選びいただけます（施術終了が受付時間を過ぎても承ります）。当日のご予約はお電話（<a href={`tel:${tel}`}>{tel}</a>）で承ります。オンラインは翌日以降・2ヶ月先までです。
        </p>
        <div id="slotStatus" class="slot-status">メニューを選ぶと空き状況を表示します。</div>
        <div id="dateList" class="date-list"></div>
      </section>

      <!-- STEP 3〜5 は 1 つの form で包む（note/consent が step をまたいでも同一 form 内に置くため）。
           送信は⑤の submit ボタンでのみ発火し、戻る/次へは type=button で誤送信を防ぐ。 -->
      <form id="reserveForm" novalidate>
      <!-- STEP 3: お客様情報（情報のみ。ご要望・同意は④へ移設） -->
      <section class="step" id="step-form" hidden>
        <h2 tabindex="-1"><span class="step-no">3</span> お客様情報</h2>
          <!-- LINE 連携（任意）。設定済み(チャネルID/redirect あり)のときだけ表示 -->
          <div class="line-link" id="lineLink" hidden>
            <!-- 未連携 -->
            <div id="lineUnlinked">
              <button type="button" class="line-btn" id="lineLinkBtn">
                <span class="line-ico" aria-hidden="true">LINE</span>
                LINEで連携してかんたん予約（任意）
              </button>
              <small class="hint">連携するとお名前が自動入力され、ご予約の確認・確定をLINEでお受け取りいただけます。電話番号・性別はご入力が必要です。</small>
            </div>
            <!-- 連携済み -->
            <div id="lineLinked" hidden>
              <p class="line-linked-badge">
                <span class="line-ico" aria-hidden="true">LINE</span>
                <span>連携済み: <strong id="lineDisplayName"></strong> さん</span>
              </p>
              <button type="button" class="line-unlink" id="lineUnlinkBtn">連携を解除 / 別の人として予約</button>
            </div>
          </div>

          <!-- 名寄せの引き継ぎ導線（入口①）。LINE連携で idToken を得たあと handoverCheck し、
               過去のご予約（媒体違い）が found:true のときだけ控えめに表示。既定は非表示・うるさくしない。 -->
          <a class="handover-hint" id="handoverHint" href={`${base}reserve/handover`} hidden>
            <span class="handover-hint__ic" aria-hidden="true">🗂</span>
            <span class="handover-hint__tx"><strong>過去のご予約履歴が見つかりました。</strong>いまお使いの LINE アカウントに引き継げます。</span>
            <span class="handover-hint__go" aria-hidden="true">›</span>
          </a>

          <!-- 再訪（保存済み）の折りたたみ表示 -->
          <div class="field known-summary" id="knownSummary" hidden>
            <div class="known-head">
              <span class="field-label">ご登録情報</span>
              <button type="button" class="known-edit" id="knownEditBtn">修正する</button>
            </div>
            <p class="known-body" id="knownBody"></p>
          </div>

          <div id="fieldsBlock">
          <div class="field">
            <label for="f-name">お名前 <span class="req">必須</span></label>
            <input type="text" id="f-name" name="name" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="f-phone">電話番号 <span class="req">必須</span></label>
            <input type="tel" id="f-phone" name="phone" inputmode="tel" autocomplete="tel" placeholder="ハイフンなしで入力してください" required />
            <small class="hint">当日のご連絡・初回／常連の判定に使用します。</small>
          </div>

          <div class="field">
            <label for="f-email">メールアドレス <span class="req" id="emailReq">必須</span></label>
            <input type="email" id="f-email" name="email" inputmode="email" autocomplete="email" required />
            <small class="hint" id="emailHint">ご予約の確認・確定・リマインドのご連絡に使用します。</small>
            <small class="hint" id="emailFromLine" hidden>※ LINE アカウントのメールアドレスを表示しています。ご予約の確認・確定・リマインドのご連絡に使用します。</small>
            <small class="hint">利用目的・管理方法の詳細は<a href={`${base}privacy/`} target="_blank" rel="noopener noreferrer">プライバシーポリシー</a>をご覧ください。</small>
          </div>

          <div class="field" id="contact-field">
            <span class="field-label">ご希望の連絡方法</span>
            <div class="radio-row">
              {CONTACT_METHODS.map((c) => (
                <label class="radio-pill">
                  <input type="radio" name="contactMethod" value={c.value} checked={c.value === 'line'} />
                  <span>{c.label}</span>
                </label>
              ))}
            </div>
            <p class="contact-line-note">
              <span class="line-ico" aria-hidden="true">LINE</span>
              <span><strong>LINEで自動連絡をご希望の場合は、上の「LINEで連携」をご利用ください。</strong>連携なしの場合はメールでお送りします。</span>
            </p>
          </div>

          <div class="field">
            <span class="field-label">性別 <span class="req">必須</span></span>
            <div class="radio-row">
              {GENDERS.map((g) => (
                <label class="radio-pill">
                  <input type="radio" name="gender" value={g.value} required />
                  <span>{g.label}</span>
                </label>
              ))}
            </div>
          </div>

          <div class="field" id="referrer-field" hidden>
            <label for="f-referrer">ご紹介者のお名前 <span class="req">必須</span></label>
            <input type="text" id="f-referrer" name="referrer" />
            <small class="hint">男性のお客様はご紹介制です。ご紹介者のお名前をご記入ください。</small>
          </div>
          </div><!-- /#fieldsBlock -->

          <div id="formError" class="form-error" hidden></div>
      </section>

      <!-- STEP 4: ご要望・同意（③から移設） -->
      <section class="step" id="step-extra" hidden>
        <h2 tabindex="-1"><span class="step-no">4</span> ご要望・ご同意</h2>

        <div class="field">
          <label for="f-note">ご要望（任意）</label>
          <textarea id="f-note" name="note" rows="3"></textarea>
        </div>

        <div class="field consent">
          <label class="check">
            <input type="checkbox" id="f-consent" required />
            <span>
              入力内容（お名前・電話番号・メールアドレス・性別・ご要望）、およびLINE連携時はLINEのユーザーID・表示名・メールアドレスを、
              予約管理・ご予約の確認／確定・リマインド等のご連絡・初回／常連判定の目的で当サロンが取得・利用することに同意します。
              メールアドレスは上記のご連絡にのみ使用し、目的外には利用しません。情報は当サロンの
              Google（予約カレンダー・顧客台帳）と通知サービス（LINE）内でのみ管理します。連携情報は次回の入力省略のため
              ご利用の端末内に保存される場合があり、「連携を解除」でいつでも削除できます。詳しくは<a href={`${base}privacy/`} target="_blank" rel="noopener noreferrer">プライバシーポリシー</a>をご覧ください。
            </span>
          </label>
        </div>

        <div id="extraError" class="form-error" hidden></div>
      </section>

      <!-- STEP 5: 確認（送信前の入力確認）。各項目群に修正リンクを置き、送信はここで行う -->
      <section class="step" id="step-confirm" hidden>
        <h2 tabindex="-1"><span class="step-no">5</span> ご予約内容の確認</h2>
        <p class="confirm-lead">内容をご確認のうえ、よろしければお申し込みください。修正は各項目の「修正」からどうぞ。</p>

        <div class="confirm-block">
          <div class="confirm-head"><span>メニュー</span><button type="button" class="confirm-edit" data-goto="step-menu">修正</button></div>
          <dl class="confirm-dl">
            <dt>メニュー</dt><dd id="cf-menu"></dd>
            <dt>料金</dt><dd id="cf-price"></dd>
          </dl>
          <p class="confirm-note" id="cf-firstnote" hidden></p>
        </div>

        <div class="confirm-block">
          <div class="confirm-head"><span>日時</span><button type="button" class="confirm-edit" data-goto="step-date">修正</button></div>
          <dl class="confirm-dl">
            <dt>日時</dt><dd id="cf-when"></dd>
          </dl>
        </div>

        <div class="confirm-block">
          <div class="confirm-head"><span>お客様情報</span><button type="button" class="confirm-edit" data-goto="step-form">修正</button></div>
          <dl class="confirm-dl">
            <dt>お名前</dt><dd id="cf-name"></dd>
            <dt>電話番号</dt><dd id="cf-phone"></dd>
            <dt>メール</dt><dd id="cf-email"></dd>
            <dt>性別</dt><dd id="cf-gender"></dd>
            <dt>連絡方法</dt><dd id="cf-contact"></dd>
            <div id="cf-referrer-row" hidden style="display:contents"><dt>ご紹介者</dt><dd id="cf-referrer"></dd></div>
          </dl>
        </div>

        <div class="confirm-block">
          <div class="confirm-head"><span>ご要望</span><button type="button" class="confirm-edit" data-goto="step-extra">修正</button></div>
          <dl class="confirm-dl">
            <dt>ご要望</dt><dd id="cf-note"></dd>
          </dl>
        </div>

        <div id="confirmError" class="form-error" hidden></div>
      </section>
      </form>

      <!-- 完了 -->
      <section class="step done" id="step-done" hidden>
        <div class="done-mark">✓</div>
        <h2>仮予約を受け付けました</h2>
        <div class="done-body" id="doneBody"></div>
        <!-- LIFF: 友だち未追加の案内（確定・リマインドのpush通知を届けるため） -->
        <div id="liffFriend" class="line-link" hidden>
          <p class="hint">確定・リマインドのご連絡をLINEでお受け取りいただくには、サロンの公式アカウントを友だち追加してください。</p>
          <a class="line-btn" href="https://lin.ee/7ZvbqEb" target="_blank" rel="noopener noreferrer">
            <span class="line-ico" aria-hidden="true">LINE</span>友だち追加する
          </a>
        </div>
        <!-- LIFF: 友だちにサロンを教える（任意） -->
        <button type="button" class="reserve-btn ghost" id="liffShareBtn" hidden>友だちにサロンを教える</button>
        <a class="reserve-btn ghost" href={base}>トップへ戻る</a>
      </section>
    </main>

    <!-- 画面下部に常時表示するナビバー（sticky）。上部ナビと同じ goBack/goNext を呼ぶ。
         完了（step-done）では JS で非表示にする。 -->
    <div class="bottom-nav" id="bottomNav">
      <div class="bottom-nav-inner">
        <button type="button" class="reserve-btn ghost nav-back" data-nav="back" disabled>← 戻る</button>
        <button type="button" class="reserve-btn nav-next" data-nav="next" disabled>次へ →</button>
      </div>
    </div>

    <footer class="site-footer">
      <p>{salonName}</p>
      <p class="small">富山県高岡市野村1180-1 / <a href={`tel:${tel}`}>{tel}</a></p>
      <p class="small"><a href={`${base}privacy/`}>プライバシーポリシー</a></p>
    </footer>

    <script type="application/json" id="reserve-config" set:html={JSON.stringify({ RESERVE_API, BOOKING_RULES, LINE_LOGIN_CHANNEL_ID, LINE_LOGIN_REDIRECT, LIFF_ID, tel })}></script>
    <script>
      // 共有部品（src/lib）を import するため bundled module 化。サーバ値は上の JSON から読む。
      // define:vars は import 不可（inline classic 化する）ため使わない。
      import { showSubmitOverlay, hideSubmitOverlay } from '../../lib/submit-overlay.js';
      import { openTimeDialog as openTimeDlg, renderTimeButtons } from '../../lib/time-dialog.js';
      import { fetchAvailabilityRaw, computeDaysForSlot } from '../../lib/availability.js';
      import { renderAvailabilityCalendar } from '../../lib/datetime-picker.js';

      const { RESERVE_API, BOOKING_RULES, LINE_LOGIN_CHANNEL_ID, LINE_LOGIN_REDIRECT, LIFF_ID, tel } = JSON.parse(document.getElementById('reserve-config').textContent);

      const WD = ['日', '月', '火', '水', '木', '金', '土'];
      // 項目3: カレンダーの空き枠ヒートマップ閾値。枠数 >= HEAT_HI_MIN を「空き多い（◎）」、
      // 1〜(HEAT_HI_MIN-1) を「残りわずか（○）」、0（非 avail）は現行のグレー（✕相当）。
      const HEAT_HI_MIN = 8;
      // raw = availabilityRaw の先読みキャッシュ { days:[{date,candidates,busy}], holidays }。null=未取得
      const state = { menu: null, date: null, time: null, days: [], availSet: null, calMin: null, calMax: null, holidays: {}, raw: null, lineUserId: '', displayName: '', inLiff: false, step: 1, maxReached: 1 };
      let rawFetching = false;   // availabilityRaw の多重取得防止
      let onRawReady = null;     // 先読み完了時に一度だけ呼ぶコールバック（メニュー選択が先行したとき用）
      let calMonth = null; // カレンダーで表示中の月 {y, m(0始まり)}
      let restoreTarget = null; // LINE 認可リダイレクト復帰時に選び直す日時 {date, time}

      // LINE 連携が使える設定か（チャネルID＋redirect が揃っているとき）
      const LINE_ENABLED = !!(LINE_LOGIN_CHANNEL_ID && LINE_LOGIN_REDIRECT);
      // LIFF（LINEアプリ内）連携が使える設定か
      const LIFF_ENABLED = !!LIFF_ID;
      const LS_KEY = 'wasyo_line_profile'; // 端末内に保存する連携プロフィール
      // 認可リダイレクト中の一時退避（state/nonce/フォーム下書き）。
      // sessionStorage はタブ/アプリ内ブラウザをまたぐと失われるため localStorage に保存し、復帰時に必ず消す。
      const OAUTH_KEY = 'wasyo_line_oauth';
      // 前回選んだメニュー id を端末に保存するキー（LINE 連携の有無を問わず全員・LS_KEY とは別）
      const LAST_MENU_KEY = 'wasyo_last_menu';
      const GENDER_LABEL = { female: '女性', male: '男性' };

      const $ = (s) => document.querySelector(s);
      const esc = (s) =>
        String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const fmtYen = (n) => '¥' + Number(n).toLocaleString('ja-JP');
      const fmtDateLabel = (ymd) => {
        const [y, m, d] = ymd.split('-').map(Number);
        const dt = new Date(y, m - 1, d);
        return `${m}/${d}(${WD[dt.getDay()]})`;
      };

      // ============================================================
      // ウィザード：ステップ遷移の単一窓口
      // target = 'step-menu' | 'step-date' | 'step-form' | 'step-extra' | 'step-confirm' | 'done'
      // ============================================================
      const WIZARD_FACES = ['step-menu', 'step-date', 'step-form', 'step-extra', 'step-confirm', 'step-done'];
      // 数値ステップ（インジケーターのドット）は step-menu..step-confirm の 1..5。done は別扱い。
      const STEP_NUM = { 'step-menu': 1, 'step-date': 2, 'step-form': 3, 'step-extra': 4, 'step-confirm': 5 };
      const LAST_STEP_NUM = 5; // done 到達時の maxReached（全ステップ通過）

      // インジケーターの状態（active/done/到達可否）を state に合わせて再描画
      function renderIndicator() {
        const ind = $('.steps-indicator');
        if (!ind) return;
        // 完了面ではインジケーター自体を隠す
        ind.hidden = state.step === 'done';
        if (ind.hidden) return;
        ind.querySelectorAll('li').forEach((li) => {
          const n = Number(li.dataset.step);
          const isActive = n === state.step;
          // 到達済み（maxReached まで）で現在地以外は「通過済み」表示にする
          const reachable = n <= state.maxReached;
          li.classList.toggle('is-active', isActive);
          li.classList.toggle('is-done', !isActive && reachable);
          if (isActive) {
            li.setAttribute('aria-current', 'step');
          } else {
            li.removeAttribute('aria-current');
          }
          if (reachable && !isActive) {
            li.setAttribute('role', 'button');
            li.setAttribute('tabindex', '0');
            li.removeAttribute('aria-disabled');
          } else if (isActive) {
            // 現在地はボタンにしない（移動先が自分自身のため）
            li.removeAttribute('role');
            li.removeAttribute('tabindex');
            li.removeAttribute('aria-disabled');
          } else {
            li.removeAttribute('role');
            li.removeAttribute('tabindex');
            li.setAttribute('aria-disabled', 'true');
          }
        });
      }

      // 現ステップで「次へ」を押せるか（未選択・未入力・未同意なら false）。
      // ①menu 選択済 / ②date+time 選択済 / ③必須充足 / ④同意チェック済 / ⑤は常に活性
      function canProceed() {
        switch (state.step) {
          case 1: return !!state.menu;
          case 2: return !!(state.date && state.time);
          case 3: return isInfoComplete(); // ③必須が埋まるまで「次へ」を活性化しない
          case 4: return $('#f-consent').checked;
          default: return true; // 5・done は disabled にしない
        }
      }

      // 上部・下部の全ナビ（[data-nav]）の活性/ラベルを現ステップに合わせて更新。
      // 戻る＝step1 で非活性。次へ＝canProceed() で活性、⑤はラベルを送信文言に。
      function refreshNavBars() {
        const isDone = state.step === 'done';
        // 完了面では下部 sticky バーを隠す（上部ナビは step 面ごと hidden で消える）
        const bottom = $('#bottomNav');
        if (bottom) bottom.hidden = isDone;
        if (isDone) return;
        const backDisabled = state.step === 1;
        const nextDisabled = !canProceed();
        const nextLabel = state.step === 5 ? 'この内容で仮予約する' : '次へ →';
        document.querySelectorAll('[data-nav="back"]').forEach((b) => { b.disabled = backDisabled; });
        document.querySelectorAll('[data-nav="next"]').forEach((b) => { b.disabled = nextDisabled; b.textContent = nextLabel; });
      }

      // 「戻る」：現ステップの1つ前へ。step1 では何もしない。
      function goBack() {
        switch (state.step) {
          case 2: showStep('step-menu'); break;
          case 3: showStep('step-date'); break;
          case 4: showStep('step-form'); break;
          case 5: showStep('step-extra'); break;
          default: break; // step1・done は戻る無し
        }
      }

      // 「次へ」：現ステップの前進条件を満たせば次へ。⑤は送信（form submit を発火）。
      // 各ステップの検証・エラー表示は従来の個別ハンドラと同じものを踏襲。
      function goNext() {
        switch (state.step) {
          case 1: // メニュー選択済で②へ（未選択なら次へは disabled 済み）
            if (state.menu) showStep('step-date');
            break;
          case 2: // 日付＋時刻が揃っていれば③へ
            if (state.date && state.time) showStep('step-form');
            break;
          case 3: // 情報系バリデーション後④へ（NG は formError に表示）
            if (validateInfo()) showStep('step-extra');
            break;
          case 4: // 同意必須で確認画面へ流し込んで⑤へ
            if (!$('#f-consent').checked) { showExtraError('内容のお取り扱いに同意のうえお進みください。'); return; }
            updateConfirm();
            showStep('step-confirm');
            break;
          case 5: // 送信（既存の submit ハンドラを発火）
            $('#reserveForm').requestSubmit();
            break;
          default: break;
        }
      }

      function showStep(target) {
        // done は数値ステップとは別扱い（最終ステップ相当）
        const isDone = target === 'done';
        const faceId = isDone ? 'step-done' : target;
        // 全ステップ面を隠して対象だけ表示
        WIZARD_FACES.forEach((id) => { const el = document.getElementById(id); if (el) el.hidden = (id !== faceId); });
        // state 更新
        state.step = isDone ? 'done' : STEP_NUM[target];
        const reachedNum = isDone ? LAST_STEP_NUM : STEP_NUM[target];
        state.maxReached = Math.max(state.maxReached, reachedNum);
        // インジケーター・上下ナビを再描画
        renderIndicator();
        refreshNavBars();
        // スクロールとフォーカス：ヘッダーが sticky なので先頭(0)へ。見出しへフォーカス
        window.scrollTo({ top: 0, behavior: 'smooth' });
        const face = document.getElementById(faceId);
        const h2 = face && face.querySelector('h2');
        if (h2) { try { h2.focus({ preventScroll: true }); } catch (_) { h2.focus(); } }
      }

      // 上部・下部ナビ（戻る／次へ）の配線：すべて goBack/goNext に一元化。
      // [data-nav] を持つ全ボタン（各ステップ上部＋画面下部 sticky）で同じ挙動。
      document.querySelectorAll('[data-nav="back"]').forEach((b) => b.addEventListener('click', goBack));
      document.querySelectorAll('[data-nav="next"]').forEach((b) => b.addEventListener('click', goNext));
      // 確認画面の「修正」リンク：該当ステップへ戻る
      document.querySelectorAll('.confirm-edit').forEach((b) => {
        b.addEventListener('click', () => { const t = b.dataset.goto; if (t) showStep(t); });
      });
      // 同意チェックの変化で④「次へ」の活性を更新
      $('#f-consent').addEventListener('change', refreshNavBars);
      // ③お客様情報の各入力変化で「次へ」(canProceed=isInfoComplete)の活性を更新。
      // input=テキスト系のキー入力、change=ラジオ（性別・連絡方法）の切替に対応。
      (function bindInfoInputs() {
        const form = $('#reserveForm');
        if (!form) return;
        const upd = () => { if (state.step === 3) refreshNavBars(); };
        ['input', 'change'].forEach((ev) => form.addEventListener(ev, upd));
      })();

      // 目的ステップ n へ「前進」してよいか（後退は常に許可）。
      // n に到達するには手前の必須をすべて満たす必要がある：
      //   ②へ=①メニュー選択済 / ③へ=②日時選択済 / ④⑤へ=③情報充足＋（⑤は④同意も）
      // maxReached の到達値だけを根拠に飛べる穴（入力を消して戻り→ドットで前進）を塞ぐ。
      function canEnterStep(n) {
        if (n <= state.step) return true; // 後退・現在地は無条件で許可（過剰ブロック回避）
        if (n >= 2 && !state.menu) return false;                 // ①未選択
        if (n >= 3 && !(state.date && state.time)) return false; // ②未選択
        if (n >= 4 && !isInfoComplete()) return false;           // ③未充足
        if (n >= 5 && !$('#f-consent').checked) return false;    // ④未同意
        return true;
      }
      // 前進ガードつきステップ移動：NG のときは最初に満たせていない手前ステップで止める。
      function goToStepGuarded(n) {
        if (n === state.step) return;
        if (canEnterStep(n)) { showStep(WIZARD_FACES[n - 1]); return; }
        // 前進不可：手前の未充足ステップへ誘導し、該当のエラーを表示
        if (!state.menu) { showStep('step-menu'); return; }
        if (!(state.date && state.time)) { showStep('step-date'); return; }
        if (!isInfoComplete()) { showStep('step-form'); validateInfo(); return; }
        if (!$('#f-consent').checked) { showStep('step-extra'); showExtraError('内容のお取り扱いに同意のうえお進みください。'); return; }
      }

      // ドット（インジケーター）クリック：到達済み（n <= maxReached）＋前進ガードを満たすときだけ移動。
      (function bindIndicator() {
        const ind = $('.steps-indicator');
        if (!ind) return;
        const go = (li) => {
          const n = Number(li.dataset.step);
          if (n > state.maxReached || n === state.step) return; // 未到達・現在地は無反応
          goToStepGuarded(n); // maxReached 到達済みでも中間ステップ未充足なら前進させない
        };
        ind.querySelectorAll('li').forEach((li) => {
          li.addEventListener('click', () => go(li));
          li.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(li); }
          });
        });
      })();

      // ============================================================
      // LINE 連携（任意）：userId・表示名の取得＋同端末での自動連携
      // ============================================================
      const randToken = () => {
        const a = new Uint8Array(16);
        crypto.getRandomValues(a);
        return Array.from(a, (b) => b.toString(16).padStart(2, '0')).join('');
      };

      // 連携状態に応じてフォーム表示を切り替える
      function applyLinkState() {
        if (!LINE_ENABLED && !LIFF_ENABLED) return; // 未設定環境では従来どおり（メール必須・LINE枠非表示）
        $('#lineLink').hidden = false;
        const linked = !!state.lineUserId;
        // OAuthの「連携する」ボタンは LINE_ENABLED のときだけ意味を持つ（LIFF専用構成では非表示）
        $('#lineUnlinked').hidden = linked || !LINE_ENABLED;
        $('#lineLinked').hidden = !linked;
        if (linked) $('#lineDisplayName').textContent = state.displayName || 'お客様';
        // メールは連携時のみ任意
        const emailInput = $('#f-email');
        emailInput.required = !linked;
        $('#emailReq').textContent = linked ? '任意' : '必須';
        $('#emailHint').textContent = linked
          ? 'LINEで確認・確定のご連絡をお送りします。メールは任意です。'
          : 'ご予約の確認・確定のご連絡をお送りします。';
        // 連携時は連絡方法は LINE 固定（フィールド非表示）
        $('#contact-field').hidden = linked;
        if (linked) {
          const lineRadio = document.querySelector('input[name="contactMethod"][value="line"]');
          if (lineRadio) lineRadio.checked = true;
        }
      }

      // 端末保存の連携プロフィールを読む
      function loadStoredProfile() {
        if (!LINE_ENABLED) return null;
        try {
          const raw = localStorage.getItem(LS_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch (_) { return null; }
      }
      // 予約成功時に連携プロフィールを保存（同意チェックは保存しない）
      function saveProfile(p) {
        try { localStorage.setItem(LS_KEY, JSON.stringify(p)); } catch (_) {}
      }
      // 連携解除：保存を消して未連携に戻す
      function clearProfile() {
        try { localStorage.removeItem(LS_KEY); } catch (_) {}
        state.lineUserId = '';
        state.displayName = '';
        $('#knownSummary').hidden = true;
        $('#fieldsBlock').hidden = false;
        applyLinkState();
      }

      // 既知項目を入力欄へ流し込む
      function fillFields(p) {
        if (p.name) $('#f-name').value = p.name;
        if (p.phone) $('#f-phone').value = p.phone;
        if (p.gender) {
          const g = document.querySelector('input[name="gender"][value="' + p.gender + '"]');
          if (g) { g.checked = true; g.dispatchEvent(new Event('change', { bubbles: true })); }
        }
        if (p.referrer) $('#f-referrer').value = p.referrer;
      }

      // 再訪（保存あり）：折りたたみ表示にして「ご要望＋同意」だけで完了できるように
      function showKnownSummary(p) {
        const parts = [p.name ? p.name + ' さん' : '', p.phone || '', GENDER_LABEL[p.gender] || ''].filter(Boolean);
        $('#knownBody').textContent = parts.join(' / ');
        $('#knownSummary').hidden = false;
        $('#fieldsBlock').hidden = true;
      }

      // 連携開始：state/nonce＋入力中フォームを退避して LINE 認可へ
      function startLineLink() {
        const oauthState = randToken();
        const draft = {
          state: oauthState,
          nonce: randToken(),
          menuId: state.menu ? state.menu.id : '',
          date: state.date || '',
          time: state.time || '',
          name: $('#f-name').value.trim(),
          phone: $('#f-phone').value.trim(),
          email: $('#f-email').value.trim(),
          gender: document.querySelector('input[name="gender"]:checked')?.value || '',
          referrer: $('#f-referrer').value.trim(),
          note: $('#f-note').value.trim(),
          // 退避漏れだった2項目も退避（連携後に同意・連絡方法を失わないため）
          consent: !!$('#f-consent').checked,
          contactMethod: document.querySelector('input[name="contactMethod"]:checked')?.value || '',
        };
        try { localStorage.setItem(OAUTH_KEY, JSON.stringify(draft)); } catch (_) {}
        const url =
          'https://access.line.me/oauth2/v2.1/authorize?response_type=code' +
          '&client_id=' + encodeURIComponent(LINE_LOGIN_CHANNEL_ID) +
          '&redirect_uri=' + encodeURIComponent(LINE_LOGIN_REDIRECT) +
          '&state=' + encodeURIComponent(oauthState) +
          '&scope=' + encodeURIComponent('profile openid') +
          '&nonce=' + encodeURIComponent(draft.nonce);
        window.location.href = url;
      }

      // 退避した下書きをフォームへ復元（menu/date/time は availability 取得後に選び直す）
      function restoreDraft(draft) {
        $('#f-name').value = draft.name || '';
        $('#f-phone').value = draft.phone || '';
        $('#f-email').value = draft.email || '';
        if (draft.gender) {
          const g = document.querySelector('input[name="gender"][value="' + draft.gender + '"]');
          if (g) { g.checked = true; g.dispatchEvent(new Event('change', { bubbles: true })); }
        }
        $('#f-referrer').value = draft.referrer || '';
        $('#f-note').value = draft.note || '';
        // 連絡方法（ラジオ）を復元：change を発火して依存挙動（未連携×LINE誘導等）と整合させる
        if (draft.contactMethod) {
          const cm = document.querySelector('input[name="contactMethod"][value="' + draft.contactMethod + '"]');
          if (cm) { cm.checked = true; cm.dispatchEvent(new Event('change', { bubbles: true })); }
        }
        // 同意チェックを復元：change を発火して④「次へ」の活性(refreshNavBars)を更新
        const consentEl = $('#f-consent');
        if (consentEl) { consentEl.checked = !!draft.consent; consentEl.dispatchEvent(new Event('change', { bubbles: true })); }
        if (draft.menuId) {
          const mr = document.querySelector('input[name="menu"][value="' + draft.menuId + '"]');
          if (mr) {
            restoreTarget = { date: draft.date || '', time: draft.time || '' };
            mr.checked = true;
            mr.dispatchEvent(new Event('change', { bubbles: true })); // → loadAvailability（restoreTarget は描画後に適用）
          }
        }
      }

      // #3 復帰ローディング（data-line-returning）を解除して本文を見せる。
      // handleLineReturn の全ての「結末」（成功→③／各失敗→③＋エラー）で必ず呼ぶ。
      function endLineReturnLoading() {
        document.documentElement.removeAttribute('data-line-returning');
      }

      // 認可からの復帰：?code&?state を検知して userId を取得
      async function handleLineReturn() {
        const params = new URLSearchParams(location.search);
        const code = params.get('code');
        const retState = params.get('state');
        if (!code || !retState) return false;
        let draft = null;
        try { draft = JSON.parse(localStorage.getItem(OAUTH_KEY) || 'null'); } catch (_) {}
        // URL からは即座に code/state を消す（再読込やプレビュー先読み対策）
        history.replaceState(null, '', location.pathname);
        try { localStorage.removeItem(OAUTH_KEY); } catch (_) {}
        if (!draft || draft.state !== retState) {
          // 失敗時も③へ戻して手入力で続行できるようにする。
          // draft があれば入力を復元してから戻す（CSRF不一致でも本人の入力は失わない）。
          // draft 自体が無い/壊れている場合は復元できないのでそのまま③へ。
          if (draft) restoreDraft(draft);
          endLineReturnLoading();
          showStep('step-form');
          showError('連携の確認に失敗しました（セキュリティ検証）。お手数ですが、もう一度お試しください。');
          return false;
        }
        try {
          const res = await fetch(RESERVE_API, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify({ action: 'lineLogin', code, redirectUri: LINE_LOGIN_REDIRECT }),
          });
          const data = await res.json();
          // API 失敗時も退避した入力を復元してから③へ戻す（入力を失わない）
          if (!data.ok || !data.lineUserId) { restoreDraft(draft); endLineReturnLoading(); showStep('step-form'); showError('LINE連携に失敗しました。お手数ですが、もう一度お試しください。'); return false; }
          state.lineUserId = data.lineUserId;
          state.displayName = data.displayName || '';
          restoreDraft(draft);
          // 名前未入力なら LINE 表示名で自動補完
          if (!$('#f-name').value.trim() && state.displayName) $('#f-name').value = state.displayName;
          applyLinkState();
          // 復帰成功：menu/date/time が復元されるので③まで到達済みにして③を表示
          state.maxReached = 3;
          endLineReturnLoading();
          showStep('step-form');
          return true;
        } catch (e) {
          // 通信例外時も退避した入力を復元してから③へ戻す（入力を失わない）
          restoreDraft(draft);
          endLineReturnLoading();
          showStep('step-form');
          showError('LINE連携の通信に失敗しました。通信環境をご確認のうえ、もう一度お試しください。');
          return false;
        }
      }

      // LIFF（LINEアプリ内）：ログイン操作なしで userId/表示名/メールを取得して自動入力
      // 成立したら true を返し、以降の OAuth/端末保存フローはスキップする。
      async function initLiff() {
        if (!LIFF_ENABLED || !window.liff) return false;
        try {
          await liff.init({ liffId: LIFF_ID });
        } catch (_) {
          return false; // 初期化失敗時は通常フロー（OAuth/手入力）へフォールバック
        }
        // LINEアプリ内でないなら LIFF は使わない（Webから来た予約客は従来フロー）
        if (!liff.isInClient()) return false;
        try {
          if (!liff.isLoggedIn()) { liff.login(); return true; } // 認可後この画面に戻る
          const idToken = liff.getIDToken();
          if (!idToken) return false;
          // userId は詐称防止のためサーバ(GAS)で id_token を検証して確定する
          const res = await fetch(RESERVE_API, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify({ action: 'liffVerify', idToken }),
          });
          const data = await res.json();
          if (!data.ok || !data.lineUserId) return false;
          state.lineUserId = data.lineUserId;
          state.displayName = data.displayName || '';
          state.inLiff = true;
          if (state.displayName && !$('#f-name').value.trim()) $('#f-name').value = state.displayName;
          if (data.email && !$('#f-email').value.trim()) {
            $('#f-email').value = data.email; // メール自動入力
            $('#emailFromLine').hidden = false; // LINEから取得した旨と利用目的を明示
          }
          applyLinkState();
          // 名寄せの引き継ぎ導線（入口①）：この idToken で軽く handoverCheck し、過去のご予約が
          // 見つかったときだけ控えめなバナーを出す（非ブロッキング・found:false は何も出さない）。
          maybeShowHandoverHint(idToken);
          return true;
        } catch (_) {
          return false;
        }
      }

      // 過去のご予約（媒体をまたいだ同一人物）の有無を非PIIで確認し、found:true のときだけ引き継ぎ導線を出す。
      // 応答は message 系と同じ「ブラウザ→GAS 直送」。氏名・連絡先は受け取らず、found の真偽だけを使う。
      async function maybeShowHandoverHint(idToken) {
        if (!idToken || !RESERVE_API) return;
        try {
          const res = await fetch(RESERVE_API, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify({ action: 'handoverCheck', idToken }),
          });
          const data = await res.json();
          // found:true のときだけ表示。false / alreadyLinked / エラーは何も出さない（うるさくしない）。
          if (data && data.ok && data.found) {
            const hint = $('#handoverHint');
            if (hint) hint.hidden = false;
          }
        } catch (_) { /* 失敗時は黙って出さない（予約フローを妨げない） */ }
      }

      // 予約成功後（LIFF時のみ）：トークへ送信／友だち追加案内／シェアボタン
      async function liffAfterBooking(data) {
        if (!state.inLiff || !window.liff) return;
        // 完了内容を本人のトークへ送る（トーク文脈からの起動時のみ有効・push枠は消費しない）
        try {
          if (liff.isApiAvailable('sendMessages')) {
            const text = '【予約を申し込みました】\n' + state.menu.name + '\n' +
              fmtDateLabel(state.date) + ' ' + state.time + '〜\nサロンの確認後、確定のご連絡をいたします。';
            await liff.sendMessages([{ type: 'text', text }]);
          }
        } catch (_) {}
        // 友だち未追加なら案内（確定/リマインドの push を届ける前提を作る）
        try {
          const fs = await liff.getFriendship();
          if (fs && fs.friendFlag === false) $('#liffFriend').hidden = false;
        } catch (_) {}
        // 友だちにサロンを教える（shareTargetPicker が使えるときだけ）
        try {
          if (liff.isApiAvailable('shareTargetPicker')) {
            const shareBtn = $('#liffShareBtn');
            shareBtn.hidden = false;
            shareBtn.addEventListener('click', () => {
              liff.shareTargetPicker([
                { type: 'text', text: 'サロン和笑〜Violane〜 のネット予約はこちら\nhttps://lin.ee/7ZvbqEb' },
              ]).catch(() => {});
            }, { once: true });
          }
        } catch (_) {}
      }

      // 初期化（連携復帰 or 端末保存からの自動連携）
      async function initLine() {
        if (!LINE_ENABLED && !LIFF_ENABLED) return;
        $('#lineLink').hidden = false;
        if (LINE_ENABLED) $('#lineLinkBtn').addEventListener('click', startLineLink);
        $('#lineUnlinkBtn').addEventListener('click', clearProfile);
        $('#knownEditBtn').addEventListener('click', () => {
          $('#knownSummary').hidden = true;
          $('#fieldsBlock').hidden = false;
        });
        // LIFF（LINEアプリ内）優先。成立したら OAuth/端末保存フローはスキップ
        if (await initLiff()) return;
        const returned = await handleLineReturn();
        if (returned) return; // 連携直後（保存値はまだ無い）
        // 再訪：端末に連携情報があれば自動で連携済み扱い＋既知項目を折りたたみ
        const saved = loadStoredProfile();
        if (saved && saved.lineUserId) {
          state.lineUserId = saved.lineUserId;
          state.displayName = saved.displayName || '';
          fillFields(saved);
          if (!$('#f-name').value.trim() && state.displayName) $('#f-name').value = state.displayName;
          applyLinkState();
          showKnownSummary(saved);
        }
      }

      // ---- メニュー選択 ----
      document.querySelectorAll('input[name="menu"]').forEach((r) => {
        r.addEventListener('change', () => {
          const el = r;
          state.menu = {
            id: el.value,
            name: el.dataset.name,
            durationMin: Number(el.dataset.duration),
            slotMin: Number(el.dataset.slot), // カレンダー占有時間＝クライアント空き判定に使う
            price: Number(el.dataset.price),
            hasFirst: el.dataset.hasfirst === '1',
            firstLabel: el.dataset.firsttime,
          };
          // メニュー変更＝下流（日時）を無効化して②へ。到達上限も②に戻す
          state.date = null;
          state.time = null;
          state.maxReached = 2;
          showStep('step-date');
          loadAvailability();
          updateSummary();
        });
      });

      // ---- 空き枠取得 ----
      function setStatusLoading(msg) {
        const status = $('#slotStatus');
        status.className = 'slot-status loading';
        status.innerHTML = '<span class="spinner" aria-hidden="true"></span><span>' + msg + '</span>';
      }
      function setStatusText(msg, kind) {
        const status = $('#slotStatus');
        status.className = 'slot-status' + (kind ? ' ' + kind : '');
        status.textContent = msg;
      }

      // 空き枠の「素材」をページ表示直後に1回だけ先読み（menuId 非依存）。
      // 以降のメニュー選択・変更・戻って再選択では追加 fetch せず state.raw から計算する。
      async function prefetchAvailabilityRaw() {
        if (rawFetching || state.raw) return;
        if (!RESERVE_API) return; // 未設定は loadAvailability 側で案内
        rawFetching = true;
        try {
          state.raw = await fetchAvailabilityRaw(RESERVE_API);
        } catch (e) {
          state.raw = null; // 失敗は次回の loadAvailability でリトライ余地を残す
        } finally {
          rawFetching = false;
          const cb = onRawReady; onRawReady = null;
          if (cb) cb(); // メニュー選択が先行して待っていれば計算を再開
        }
      }

      // 先読み素材(state.raw)から slotMin を当てはめて state.days を導出する（fetch なし）。
      // 計算本体は lib/availability.js の computeDaysForSlot（純粋関数）。ここは state への反映のみ。
      // raw 未取得時は state.holidays を触らない（従来挙動を維持）。
      function buildDaysForSlot_(slotMin) {
        if (!state.raw) { state.days = []; return; }
        const { days, holidays } = computeDaysForSlot(state.raw, slotMin);
        state.days = days;
        state.holidays = holidays; // { 'yyyy-MM-dd': '祝日名' }（カレンダー表示用）
      }

      // 選択中メニューの slotMin でクライアント計算し日付を描画する（先読み前提・追加 fetch なし）。
      function loadAvailability() {
        calMonth = null;
        state.date = null;
        state.time = null;
        if (!RESERVE_API) {
          setStatusText('予約システムが未設定です（PUBLIC_RESERVE_API）。', 'slot-empty');
          $('#dateList').innerHTML = '';
          return;
        }
        // 先読み完了済みなら即計算。未完なら「確認中…」を出し、完了コールバックで再計算する。
        if (state.raw) {
          buildDaysForSlot_(state.menu.slotMin);
          renderDates();
          return;
        }
        $('#dateList').innerHTML = '<div class="cal-skeleton" aria-hidden="true"></div>';
        setStatusLoading('空き状況を確認中…');
        // 先読みが動いていなければ起動（失敗後の再選択でも再試行）
        prefetchAvailabilityRaw();
        onRawReady = () => {
          if (!state.menu) return; // 途中でメニューが外れていたら何もしない
          if (state.raw) {
            buildDaysForSlot_(state.menu.slotMin);
            renderDates();
          } else {
            setStatusText('空き状況を取得できませんでした。時間をおいて再度お試しください。', 'slot-empty');
            $('#dateList').innerHTML = '';
          }
        };
      }

      function renderDates() {
        const dl = $('#dateList');
        if (!state.days.length) {
          setStatusText('ご希望の期間にネット予約の空きがありません。受付時間外・定休日（日・祝など）はネット予約は受け付けておりません。お電話（' + tel + '）にて対応いたします。', 'slot-empty');
          dl.innerHTML = '';
          return;
        }
        setStatusText('ご希望の日付を選んでください（● 印が空きありの日）。');
        state.availSet = new Set(state.days.map((d) => d.date));
        state.calMin = state.days[0].date;
        state.calMax = state.days[state.days.length - 1].date;
        // LINE 認可リダイレクト復帰時：退避していた日付/時刻があれば選び直す
        if (restoreTarget && restoreTarget.date && state.availSet.has(restoreTarget.date)) {
          const [ry, rm] = restoreTarget.date.split('-').map(Number);
          calMonth = { y: ry, m: rm - 1 };
          state.date = restoreTarget.date;
          renderCalendar();
          const day = state.days.find((d) => d.date === restoreTarget.date);
          if (restoreTarget.time && day && day.times.includes(restoreTarget.time)) {
            state.time = restoreTarget.time;
            // menu/date/time が揃って復元される分岐：③まで到達済みにして③を表示
            state.maxReached = 3;
            showStep('step-form');
          }
          updateSummary();
          restoreTarget = null;
          return;
        }
        restoreTarget = null;
        if (!calMonth) {
          const [y, m] = state.calMin.split('-').map(Number);
          calMonth = { y, m: m - 1 };
        }
        renderCalendar();
      }

      // カレンダー描画は共有部品 renderAvailabilityCalendar に委譲（挙動不変の抽出）。
      // 生成 HTML・クラス・前月/次月/日付クリックの配線は従来と同一。ここは state 反映と
      // ②→③ ステップ遷移などお客様フロー固有の副作用（onDayClick）だけを担う。
      function renderCalendar() {
        renderAvailabilityCalendar({
          mount: $('#dateList'),
          days: state.days,
          holidays: state.holidays,
          availSet: state.availSet,
          calMin: state.calMin,
          calMax: state.calMax,
          calMonth,
          selectedDate: state.date,
          weekdays: WD,
          heatHiMin: HEAT_HI_MIN,
          esc,
          onNav: (nm) => { calMonth = nm; renderCalendar(); },
          onDayClick: (ymd) => {
            state.date = ymd;
            state.time = null;
            // 時刻を選び直すまで③へは進めない（②に留め、次へを無効化）
            state.maxReached = 2;
            renderCalendar();
            updateSummary();
            refreshNavBars();
            openTimeDialog();
          },
        });
      }

      // 選択中の日付の空き時刻を、共有の renderTimeButtons でポップアップ本体に描画する。
      function renderTimes() {
        const day = state.days.find((d) => d.date === state.date);
        if (!day) { const body = $('#timeDialogBody'); if (body) body.innerHTML = ''; return; }
        renderTimeButtons(day.times, (t) => {
          state.time = t;
          // 時刻選択で自動前進（③へ）。maxReached=3 は showStep が更新
          updateSummary();
          showStep('step-form');
        }, { title: fmtDateLabel(state.date) + ' の開始時刻', selected: state.time });
      }

      // 時刻選択ポップアップを開く（本体を描いてから共有 openTimeDlg で showModal）。
      function openTimeDialog() {
        renderTimes();
        openTimeDlg();
      }

      // ---- フォーム挙動 ----
      // 性別が男性なら紹介者必須
      document.querySelectorAll('input[name="gender"]').forEach((r) => {
        r.addEventListener('change', () => {
          const male = document.querySelector('input[name="gender"]:checked')?.value === 'male';
          $('#referrer-field').hidden = !male;
          $('#f-referrer').required = male;
        });
      });

      // 未連携のまま「LINEで連絡を受け取る」を選んだら、上の連携ボタンへ誘導
      document.querySelectorAll('input[name="contactMethod"]').forEach((r) => {
        r.addEventListener('change', () => {
          if (r.value !== 'line' || !r.checked) return;
          if (state.lineUserId || !LINE_ENABLED) return; // 連携済み/連携不可なら何もしない
          $('#lineLink').scrollIntoView({ behavior: 'smooth', block: 'center' });
          const btn = $('#lineLinkBtn');
          btn.classList.add('attention');
          setTimeout(() => btn.classList.remove('attention'), 1600);
        });
      });

      // 旧・日時ステップの目安 summary。全項目の確認は⑤ updateConfirm が担うため要素は撤去済み。
      // 既存の呼び出し（メニュー選択・日付/時刻選択）を壊さないよう、要素が無ければ何もしない。
      function updateSummary() {
        const s = $('#summary');
        if (!s) return;
        if (!state.menu || !state.date || !state.time) { s.hidden = true; return; }
        s.hidden = false;
        $('#sum-menu').textContent = state.menu.name;
        $('#sum-when').textContent = `${fmtDateLabel(state.date)} ${state.time}〜`;
        $('#sum-price').textContent = `${fmtYen(state.menu.price)}（${state.menu.durationMin}分）`;
        const fn = $('#sum-firstnote');
        if (state.menu.hasFirst) {
          fn.hidden = false;
          fn.textContent = `初回のお客様は「${state.menu.firstLabel}」となります（料金は同額）。判定はサロンで行います。`;
        } else {
          fn.hidden = true;
        }
      }

      // ステップ別エラー表示（③=formError / ④=extraError / ⑤=confirmError）
      function showErrorIn(sel, msg) {
        const e = $(sel);
        e.textContent = msg;
        e.hidden = false;
        e.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      function showError(msg) { showErrorIn('#formError', msg); }        // ③お客様情報
      function showExtraError(msg) { showErrorIn('#extraError', msg); }  // ④ご要望・同意
      function showConfirmError(msg) { showErrorIn('#confirmError', msg); } // ⑤確認（送信）

      // ③必須充足の軽量判定（エラー表示なし）。canProceed（③次への活性）や
      // 全経路の前進ガードで使う。ロジックは validateInfo と揃える（表示のみ省く）。
      function isInfoComplete() {
        const name = $('#f-name').value.trim();
        const phone = $('#f-phone').value.trim();
        const email = $('#f-email').value.trim();
        const gender = document.querySelector('input[name="gender"]:checked')?.value || '';
        const contactMethod = document.querySelector('input[name="contactMethod"]:checked')?.value || 'email';
        const referrer = $('#f-referrer').value.trim();
        if (!name || !phone || !gender) return false;
        // 未連携で「LINEで連絡」は不可（宛先 userId が無い）
        if (!state.lineUserId && contactMethod === 'line') return false;
        // 未連携はメール必須＋形式チェック
        if (!state.lineUserId && !email) return false;
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return false;
        // 男性は紹介者必須
        if (gender === 'male' && !referrer) return false;
        return true;
      }

      // 情報系バリデーション（③「次へ」で実施）。通れば true。エラーは③に表示。
      function validateInfo() {
        $('#formError').hidden = true;
        const name = $('#f-name').value.trim();
        const phone = $('#f-phone').value.trim();
        const email = $('#f-email').value.trim();
        const gender = document.querySelector('input[name="gender"]:checked')?.value || '';
        const contactMethod = document.querySelector('input[name="contactMethod"]:checked')?.value || 'email';
        const referrer = $('#f-referrer').value.trim();
        if (!name) { showError('お名前をご入力ください。'); return false; }
        if (!phone) { showError('電話番号をご入力ください。'); return false; }
        // 未連携のまま「LINEで連絡を受け取る」は不可（宛先 userId が無く実際に送れないため）
        if (!state.lineUserId && contactMethod === 'line') {
          showError(LINE_ENABLED
            ? '「LINEで連絡を受け取る」を選ぶには、上の「LINEで連携」が必要です。連携いただくか、「メールで連絡を受け取る」をお選びください。'
            : '現在 LINE でのご連絡はご利用いただけません。「メールで連絡を受け取る」をお選びください。');
          return false;
        }
        if (!state.lineUserId && !email) { showError('メールアドレスをご入力ください。'); return false; }
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('メールアドレスの形式が正しくありません。ご確認ください。'); return false; }
        if (!gender) { showError('性別をお選びください。'); return false; }
        if (gender === 'male' && !referrer) { showError('男性のお客様はご紹介者のお名前が必須です。'); return false; }
        return true;
      }

      // ④→⑤遷移時に確認画面へ現在値を流し込む（updateSummary は日時ステップの目安・confirm は全項目）
      function updateConfirm() {
        if (!state.menu || !state.date || !state.time) return;
        $('#cf-menu').textContent = state.menu.name;
        $('#cf-price').textContent = `${fmtYen(state.menu.price)}（${state.menu.durationMin}分）`;
        const fn = $('#cf-firstnote');
        if (state.menu.hasFirst) {
          fn.hidden = false;
          fn.textContent = `初回のお客様は「${state.menu.firstLabel}」となります（料金は同額）。判定はサロンで行います。`;
        } else { fn.hidden = true; }
        $('#cf-when').textContent = `${fmtDateLabel(state.date)} ${state.time}〜`;
        $('#cf-name').textContent = $('#f-name').value.trim();
        $('#cf-phone').textContent = $('#f-phone').value.trim() || '（未入力）';
        $('#cf-email').textContent = $('#f-email').value.trim() || '（未入力）';
        const gender = document.querySelector('input[name="gender"]:checked')?.value || '';
        $('#cf-gender').textContent = GENDER_LABEL[gender] || '（未選択）';
        const contactMethod = document.querySelector('input[name="contactMethod"]:checked')?.value || 'email';
        $('#cf-contact').textContent = state.lineUserId ? 'LINE' : (contactMethod === 'line' ? 'LINE' : 'メール');
        const referrer = $('#f-referrer').value.trim();
        const male = gender === 'male';
        $('#cf-referrer-row').hidden = !male;
        $('#cf-referrer').textContent = referrer;
        $('#cf-note').textContent = $('#f-note').value.trim() || '（なし）';
      }

      // ---- 送信（⑤確認ステップの submit）----
      // 情報系の検証は③「次へ」(validateInfo)で済ませ、ここは最終ガード＋createBooking のみ。
      // エラー（slot_taken 等）は⑤に留まり confirmError に表示する（step 遷移しない）。
      $('#reserveForm').addEventListener('submit', async (ev) => {
        ev.preventDefault();
        $('#confirmError').hidden = true;

        // 最終ガード（menu/date/time/同意）。ここまで来ていれば通常は満たすが二重チェック
        if (!state.menu || !state.date || !state.time) { showConfirmError('メニューと日時をお選びください。'); return; }
        if (!$('#f-consent').checked) { showConfirmError('内容のお取り扱いに同意のうえお進みください。'); return; }

        const name = $('#f-name').value.trim();
        const phone = $('#f-phone').value.trim();
        const email = $('#f-email').value.trim();
        const gender = document.querySelector('input[name="gender"]:checked')?.value || '';
        const contactMethod = document.querySelector('input[name="contactMethod"]:checked')?.value || 'email';
        const referrer = $('#f-referrer').value.trim();
        const note = $('#f-note').value.trim();

        // 送信中は全ナビ（上部＋下部sticky）の「次へ」を無効化＋文言を「送信中…」に。
        // 完了で画面遷移する（renderDone→showStep('done')）ため、成功時は復帰不要。
        const nextBtns = Array.from(document.querySelectorAll('[data-nav="next"]'));
        const setNext = (label, disabled) => nextBtns.forEach((b) => { b.textContent = label; b.disabled = disabled; });
        setNext('送信中…', true);
        showSubmitOverlay(); // 送信中の全面オーバーレイを表示（強調＋二重送信防止）

        const payload = {
          action: 'createBooking',
          menuId: state.menu.id,
          date: state.date,
          time: state.time,
          name, phone, email, gender, contactMethod, referrer, note,
          lineUserId: state.lineUserId || '',
        };

        try {
          // CORS プリフライト回避のため text/plain で送る
          const res = await fetch(RESERVE_API, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify(payload),
          });
          const data = await res.json();
          if (!data.ok) {
            hideSubmitOverlay();
            setNext('この内容で仮予約する', false);
            return showConfirmError(errorMessage(data.error));
          }
          // 連携済みなら、次回の入力省略のため端末にプロフィールを保存（同意は保存しない）
          if (state.lineUserId) {
            saveProfile({ lineUserId: state.lineUserId, displayName: state.displayName, name, phone, gender, referrer });
          }
          // 前回選んだメニューを端末に保存（LINE 連携有無を問わず全員・LS_KEY とは別キー）。
          // 次回の来訪時に「前回選択」バッジ＋そのコース展開の目印として使う（自動選択はしない）。
          try { localStorage.setItem(LAST_MENU_KEY, state.menu.id); } catch (_) {}
          hideSubmitOverlay(); // 完了画面へ遷移する前にオーバーレイを閉じる
          renderDone(data);
          liffAfterBooking(data); // LIFF時のみ：トーク送信／友だち追加案内／シェア
        } catch (e) {
          hideSubmitOverlay();
          setNext('この内容で仮予約する', false);
          showConfirmError('送信に失敗しました。通信環境をご確認のうえ、再度お試しください。');
        }
      });

      function errorMessage(code) {
        const map = {
          slot_taken: 'ご希望の時間はちょうど埋まってしまいました。別の時間をお選びください。',
          slot_closed: 'ご希望の時間は受付対象外です。別の時間をお選びください。',
          too_soon: '当日のご予約はオンラインでは承れません。お電話でお問い合わせください。',
          too_far: '受付は2ヶ月先までです。',
          referrer_required: '男性のお客様はご紹介者のお名前が必須です。',
          missing_required: '必須項目が未入力です。',
          missing_contact: 'ご連絡先（メール）をご入力ください。',
          missing_email: 'メールアドレスをご入力ください。',
          invalid_menu: 'メニューの選択に問題があります。選び直してください。',
        };
        return map[code] || 'お申し込みを受け付けられませんでした。時間をおいて再度お試しください。';
      }

      function renderDone(data) {
        const first = data.isFirstTime;
        const html =
          `<p>下記内容で承りました。サロンの確認後、<strong>確定のご連絡</strong>をいたします。</p>` +
          `<dl class="done-dl">` +
          `<dt>メニュー</dt><dd>${esc(state.menu.name)}${first ? '（初回）' : ''}</dd>` +
          `<dt>日時</dt><dd>${esc(fmtDateLabel(state.date))} ${esc(state.time)}〜（${esc(data.durationMin)}分）</dd>` +
          `<dt>料金</dt><dd>${fmtYen(data.price)}${first ? '（初回料金を適用）' : ''}</dd>` +
          `</dl>` +
          (data.manageUrl
            ? `<p class="manage"><a class="reserve-btn manage-btn" href="${esc(data.manageUrl)}">予約内容を確認・変更する</a><small class="manage-hint">※ご予約の確認・変更・キャンセルができます。同じリンクを確認メールにも記載しています。</small></p>`
            : '');
        $('#doneBody').innerHTML = html;
        // 完了面へ集約（4面の隠し・インジケーター非表示・スクロール/フォーカスは showStep が担う）
        showStep('done');
      }

      // ---- 営業時間ポップアップ（ネイティブ dialog）----
      (function bindHoursDialog() {
        const dlg = $('#hoursDialog');
        const openBtn = $('#hoursOpen');
        const closeBtn = $('#hoursClose');
        if (!dlg || !openBtn) return;
        openBtn.addEventListener('click', () => { try { dlg.showModal(); } catch (_) { dlg.setAttribute('open', ''); } });
        if (closeBtn) closeBtn.addEventListener('click', () => dlg.close());
        // 背景（::backdrop）クリックで閉じる。Esc は dialog 既定で閉じる。
        dlg.addEventListener('click', (e) => { if (e.target === dlg) dlg.close(); });
      })();

      // 時刻選択ポップアップの閉じる配線（×ボタン・背景クリック）は TimeDialog コンポーネントが self-wire する。

      // ---- 前回選んだメニューの目印（LocalStorage・全員）----
      // 端末に保存された前回メニュー id を読み、該当ラベルに「前回選択」バッジを付け、
      // そのコース <details> を open にする（初期の先頭 open を上書き）。自動選択（checked）はしない。
      function applyLastMenuHint() {
        let id = '';
        try { id = localStorage.getItem(LAST_MENU_KEY) || ''; } catch (_) { return; }
        if (!id) return;
        const input = document.querySelector('input[name="menu"][value="' + id + '"]');
        if (!input) return; // メニュー改定で消えた id 等は何もしない
        // バッジを該当ラベルに付与（.menu-name の隣に小さく）
        const item = input.closest('.menu-item');
        const nameEl = item && item.querySelector('.menu-name');
        if (nameEl && !nameEl.querySelector('.last-badge')) {
          const badge = document.createElement('span');
          badge.className = 'last-badge';
          badge.textContent = '前回選択';
          nameEl.appendChild(badge);
        }
        // 該当コースの <details> を open にし、他は閉じる（排他 name="menu-course" と両立）
        const group = input.closest('details.menu-group');
        if (group) {
          document.querySelectorAll('details.menu-group').forEach((d) => { d.open = (d === group); });
        }
      }

      // ---- #4 常連ウェルカム＋前回メニューのショートカット ----
      // 常連判定：LINE連携プロフィールに lineUserId あり ＆ 前回メニュー id が現行 MENU に存在。
      // 前回メニュー情報は該当 radio の data-* から引く（applyLastMenuHint と同じ DOM 由来・追加データ不要）。
      function setupWelcomeBanner() {
        const saved = loadStoredProfile();
        if (!saved || !saved.lineUserId) return; // 非常連（LINE未連携）は出さない
        let lastId = '';
        try { lastId = localStorage.getItem(LAST_MENU_KEY) || ''; } catch (_) { return; }
        if (!lastId) return;
        const radio = document.querySelector('input[name="menu"][value="' + lastId + '"]');
        if (!radio) return; // メニュー改定で消えた id 等は出さない
        const m = {
          id: radio.value,
          name: radio.dataset.name || '',
          durationMin: Number(radio.dataset.duration),
          slotMin: Number(radio.dataset.slot),
          price: Number(radio.dataset.price),
          hasFirst: radio.dataset.hasfirst === '1',
          firstLabel: radio.dataset.firsttime || '',
        };
        const who = state.displayName || saved.displayName || saved.name || 'お客様';

        $('#welcomeLead').textContent = 'おかえりなさい、' + who + 'さん。いつもありがとうございます。';
        $('#welcomeShortcutLabel').textContent = '前回と同じ「' + m.name + '」で予約する';
        $('#welcomeBanner').hidden = false;

        // ショートカット押下 → 確認ポップアップ（前回メニューの名称・料金・所要）
        $('#lm-name').textContent = m.name;
        $('#lm-price').textContent = fmtYen(m.price) + '（' + m.durationMin + '分）';
        $('#lm-duration').textContent = m.durationMin + '分'
          + (m.hasFirst && m.firstLabel ? '（初回は' + m.firstLabel + '・料金そのまま）' : '');

        const dlg = $('#lastMenuDialog');
        const openDlg = () => { try { dlg.showModal(); } catch (_) { dlg.setAttribute('open', ''); } };
        $('#welcomeShortcut').addEventListener('click', openDlg);
        $('#lastMenuClose').addEventListener('click', () => dlg.close());
        dlg.addEventListener('click', (e) => { if (e.target === dlg) dlg.close(); }); // 背景クリックで閉じる

        // 「このメニューで日時を選ぶ」→ 前回メニューを選択状態にして②へ。
        // 該当 radio に change を発火すると既存のメニュー選択ハンドラ（state.menu 設定・
        // loadAvailability・showStep('step-date')）がそのまま走るため、二重実装しない。
        $('#lastMenuConfirm').addEventListener('click', () => {
          dlg.close();
          radio.checked = true;
          radio.dispatchEvent(new Event('change', { bubbles: true }));
        });
      }

      // ---- 初期化：LINE 連携（復帰 or 端末保存からの自動連携）＋空き枠の先読み（並行）----
      applyLastMenuHint();
      // #3 フェイルセーフ：handleLineReturn が呼ばれない経路（LIFF先行成立・未設定・例外）でも
      // 復帰ローディングが残らないよう、初期化完了で必ず解除する。
      // #4 常連ウェルカムは initLine 完了後に判定（displayName が state に反映済みになる）。
      // LINE 復帰直後（③到達）は①上のバナーを出さない＝そのまま③で入力を続けてもらう。
      initLine()
        .catch(() => {})
        .finally(() => {
          endLineReturnLoading();
          // ①に居るとき（＝通常来訪）だけ出す。LINE 復帰時は step が③になっているので出ない。
          if (state.step === 1) setupWelcomeBanner();
        });
      prefetchAvailabilityRaw(); // ページ表示直後にバックグラウンドで素材を1回だけ取得

      // 入力欄フォーカス時、ソフトキーボードで下部ナビが隠れないよう VisualViewport で上へ逃がす
      (function keepBottomNavAboveKeyboard() {
        const vv = window.visualViewport;
        const bn = document.getElementById('bottomNav');
        if (!vv || !bn) return;
        const adjust = () => {
          const overlap = window.innerHeight - (vv.height + vv.offsetTop);
          bn.style.transform = overlap > 1 ? 'translateY(-' + Math.round(overlap) + 'px)' : '';
        };
        vv.addEventListener('resize', adjust);
        vv.addEventListener('scroll', adjust);
      })();
    </script>

