        padding: .4rem .9rem; font-size: .9rem; cursor: pointer; min-height: 40px; line-height: 1.7;
      }
      .radio-pill input:checked + span { background: var(--c-purple); color: #fff; border-color: var(--c-purple); }
      .radio-pill input:focus-visible + span { outline: 2px solid var(--c-purple-lt); outline-offset: 2px; }

      /* LINE 連携（任意） */
      .line-link {
        background: #F4FBF6; border: 1px solid #BfE6CC; border-radius: 10px;
        padding: .85rem .9rem; margin-bottom: 1.25rem;
      }
      .line-ico {
        display: inline-flex; align-items: center; justify-content: center;
        background: #06C755; color: #fff; font-size: .68rem; font-weight: 700;
        border-radius: 5px; padding: .12rem .34rem; letter-spacing: .02em;
      }
      .line-btn {
        display: inline-flex; align-items: center; gap: .5rem; width: 100%;
        justify-content: center; font-family: inherit; font-size: .98rem; cursor: pointer;
        background: #06C755; color: #fff; border: none; border-radius: 24px;
        padding: .75rem 1.1rem; min-height: 48px; transition: background .15s, transform .15s;
      }
      .line-btn .line-ico { background: rgba(255,255,255,.22); }
      .line-btn:hover { background: #05B14C; transform: translateY(-1px); }
      .line-linked-badge { display: flex; align-items: center; gap: .5rem; font-size: .95rem; }
      .line-unlink {
        margin-top: .5rem; font-family: inherit; font-size: .82rem; color: var(--c-muted);
        background: none; border: none; text-decoration: underline; cursor: pointer; padding: .2rem 0;
      }
      .line-unlink:hover { color: var(--c-purple-dk); }

      /* 名寄せの引き継ぎ導線（入口①）。控えめなカードリンク。found:true のときだけ表示。 */
      .handover-hint {
        display: flex; align-items: center; gap: .6rem; text-decoration: none;
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 10px;
        padding: .7rem .85rem; margin-bottom: 1.25rem; color: var(--c-ink);
        transition: border-color .15s, transform .15s;
      }
      .handover-hint:hover { border-color: var(--c-purple-lt); transform: translateY(-1px); }
      .handover-hint__ic { flex: none; font-size: 1.1rem; line-height: 1; }
      .handover-hint__tx { flex: 1; font-size: .86rem; line-height: 1.6; }
      .handover-hint__tx strong { color: var(--c-purple-dk); font-weight: 700; }
      .handover-hint__go { flex: none; color: var(--c-purple); font-size: 1.2rem; }

      /* 連絡方法フィールドの「LINEで連携をご利用ください」強調 */
      .contact-line-note {
        display: flex; gap: .5rem; align-items: flex-start;
        font-size: .85rem; line-height: 1.7; color: var(--c-ink);
        background: #F4FBF6; border: 1px solid #BfE6CC; border-radius: 8px;
        padding: .55rem .7rem; margin-top: .5rem;
      }
      .contact-line-note strong { color: #05912F; font-weight: 700; }
      .contact-line-note .line-ico { flex: none; margin-top: .15rem; }

      /* 「LINEで連絡を受け取る」選択時に連携ボタンを一瞬パルスさせて誘導 */
      .line-btn.attention { animation: lineNudge 1.6s ease; }
      @keyframes lineNudge {
        0%, 100% { box-shadow: 0 0 0 0 rgba(6,199,85,0); }
        25%, 65% { box-shadow: 0 0 0 4px rgba(6,199,85,.45); }
      }

      /* 再訪：ご登録情報の折りたたみ */
      .known-summary {
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 10px; padding: .8rem .9rem;
      }
      .known-head { display: flex; align-items: center; justify-content: space-between; gap: .8rem; }
      .known-edit {
        font-family: inherit; font-size: .82rem; color: var(--c-purple-dk);
        background: none; border: 1px solid var(--c-border); border-radius: 16px;
        padding: .3rem .8rem; cursor: pointer; min-height: 36px;
      }
      .known-edit:hover { border-color: var(--c-purple-lt); }
      .known-body { margin-top: .4rem; font-size: .95rem; }

      .consent .check { display: flex; gap: .55rem; align-items: flex-start; font-weight: normal; font-size: .85rem; }
      .consent .check input { margin-top: .3rem; accent-color: var(--c-purple); flex: none; }

      .form-error {
        background: #FBEAEC; border: 1px solid #E3B5BC; color: #8E2230;
        border-radius: 8px; padding: .6rem .8rem; font-size: .9rem; margin-bottom: 1rem;
      }

      .summary {
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 10px;
        padding: .8rem .9rem; margin-bottom: 1rem;
      }
      .summary-row { display: flex; justify-content: space-between; gap: 1rem; font-size: .92rem; padding: .15rem 0; }
      .summary-row span { color: var(--c-muted); }
      .summary-note { font-size: .8rem; color: #A67C1E; font-weight: 600; margin-top: .4rem; }

      /* ⑤確認画面：項目群ごとにカード＋修正リンク（done-dl の体裁を流用） */
      .confirm-lead { font-size: .88rem; color: var(--c-muted); margin-bottom: 1rem; }
      .confirm-block {
        background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 10px;
        padding: .7rem .9rem; margin-bottom: .8rem;
      }
      .confirm-head {
        display: flex; align-items: center; justify-content: space-between;
        font-size: .82rem; font-weight: 600; color: var(--c-purple-dk);
        border-bottom: 1px dashed var(--c-border); padding-bottom: .35rem; margin-bottom: .45rem;
      }
      .confirm-edit {
        appearance: none; background: none; border: none;
        font-family: inherit; font-size: .82rem; cursor: pointer;
        color: var(--c-purple-dk); text-decoration: underline;
        padding: .5rem .6rem; margin: -.5rem -.6rem;
        min-height: 44px; display: inline-flex; align-items: center;
      }
      .confirm-edit:hover { color: var(--c-purple); }
      .confirm-dl { display: grid; grid-template-columns: 5.5em 1fr; gap: .18rem .8rem; margin: 0; font-size: .92rem; }
      .confirm-dl dt { color: var(--c-muted); white-space: nowrap; }
      .confirm-dl dd { margin: 0; overflow-wrap: anywhere; }
      .confirm-note { font-size: .8rem; color: #A67C1E; font-weight: 600; margin-top: .4rem; }
      /* design反映: 確認の送信を主役化＋情報ステップの余白詰め */
      #step-confirm .step-nav { gap: 1rem; }
      #step-form .field { margin-bottom: .8rem; }

      .reserve-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 100%; font-family: inherit; font-size: 1rem; cursor: pointer;
        background: var(--c-reserve); color: #fff; border: none; border-radius: 24px;
        padding: .8rem 1.2rem; min-height: 48px; text-decoration: none;
        box-shadow: 0 2px 6px rgba(139, 96, 128, .25); /* 項目4: ボタンに少しの影で押せる感を出す */
        transition: background .15s, transform .15s, box-shadow .15s;
      }
      .reserve-btn:hover { background: var(--c-reserve-hv); transform: translateY(-1px); box-shadow: 0 3px 10px rgba(139, 96, 128, .32); }
      .reserve-btn:disabled { opacity: .55; cursor: default; transform: none; box-shadow: none; }
      /* ghost（戻る等）は控えめの影にとどめて主役の「次へ」との差を保つ */
      .reserve-btn.ghost { background: transparent; color: var(--c-purple-dk); border: 1px solid var(--c-border); margin-top: 1rem; box-shadow: 0 1px 3px rgba(139, 96, 128, .14); }
      .reserve-btn.ghost:hover { box-shadow: 0 2px 6px rgba(139, 96, 128, .2); }

      .done { text-align: center; }
      .done-mark {
        width: 3rem; height: 3rem; margin: 0 auto .5rem; border-radius: 50%;
        background: var(--c-purple); color: #fff; font-size: 1.5rem;
        display: flex; align-items: center; justify-content: center;
      }
      .done-body { text-align: left; margin: 1rem 0; }
      .done-dl { display: grid; grid-template-columns: auto 1fr; gap: .2rem .8rem; margin: .8rem 0; font-size: .92rem; }
      .done-dl dt { color: var(--c-muted); white-space: nowrap; }
      .done-dl dd { margin: 0; }
      .manage { font-size: .88rem; background: #FCF6FA; border: 1px solid var(--c-border); border-radius: 8px; padding: .8rem; text-align: center; }
      .manage-btn { margin: 0 auto; max-width: 320px; }
      .manage-hint { display: block; font-size: .78rem; color: var(--c-muted); margin-top: .5rem; }

      .site-footer { text-align: center; color: var(--c-muted); font-size: .82rem; padding: 1.5rem 1rem 2.5rem; }
      .site-footer .small { font-size: .78rem; }

      @media (max-width: 700px) {
        .wrap { padding: 1rem .8rem 3rem; }
        /* 狭幅では日付列を全幅にし、時間/案内文をその下へ確実に折り返す */
        .hours-day { min-width: 100%; }
        /* 確認一覧の dt を少し詰めて縦の整列を保つ */
        .confirm-dl { grid-template-columns: 5em 1fr; column-gap: .6rem; }
      }

      /* ステップインジケーター（ドット）。sticky にはしない（ヘッダーが sticky のため） */
      .steps-indicator {
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .5rem;
        margin: 0 0 1.4rem;
        padding: 0;
      }
      .steps-indicator li {
        position: relative;
        flex: 1 1 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .35rem;
        text-align: center;
        color: var(--c-muted);
        font-size: .78rem;
      }
      /* ドット間のコネクタ線（各項目の左半分に伸ばし、先頭は描かない） */
      .steps-indicator li::before {
        content: '';
        position: absolute;
        top: 13px; /* ドット中心に合わせる（26px の半分） */
        right: 50%;
        width: 100%;
        height: 2px;
        background: var(--c-border);
        z-index: 0;
      }
      .steps-indicator li:first-child::before { display: none; }
      /* 到達済み（通過）まではコネクタもアクセント色に */
      .steps-indicator li.is-active::before,
      .steps-indicator li.is-done::before { background: var(--c-purple); }
      .steps-indicator .dot {
        position: relative;
        z-index: 1;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--c-surface);
        border: 2px solid var(--c-border);
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .steps-indicator .lbl { line-height: 1.4; }
      /* 現在地：紫の塗り */
      .steps-indicator li.is-active { color: var(--c-purple-dk); font-weight: 600; }
      /* 現在地：紫の塗り＋外側リングで「いまここ」を最も強調 */
      .steps-indicator li.is-active .dot {
        background: var(--c-purple);
        border-color: var(--c-purple);
        box-shadow: 0 0 0 4px rgba(139, 96, 128, .22);
      }
      /* 通過済み：紫の塗り＋白いチェックで「完了」を明示（ゴールドはアクセント専用に温存） */
      .steps-indicator li.is-done { color: var(--c-purple-dk); }
      .steps-indicator li.is-done .dot {
        background: var(--c-purple);
        border-color: var(--c-purple);
      }
      .steps-indicator li.is-done .dot::after {
        content: '✓'; color: #fff; font-size: .82rem; line-height: 1; font-weight: 700;
      }
      /* 未到達：グレーの破線＋減光で「まだ」を明示 */
      .steps-indicator li:not(.is-active):not(.is-done) .dot { border-style: dashed; }
      /* 到達済みで移動可能な項目はポインタ、未到達は不活性 */
      .steps-indicator li[role="button"] { cursor: pointer; }
      .steps-indicator li[aria-disabled="true"] { cursor: default; opacity: .7; }

      /* ナビ行（戻る／次へを2分割配置）。上部（top-nav）と下部 sticky で共用 */
      .step-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        margin-top: 1.2rem;
      }
      /* 上部ナビ（見出し直後）は下に余白をとる */
      .step-nav.top-nav { margin-top: 0; margin-bottom: 1rem; }
      /* ナビ内のボタンは全幅ではなく内容幅寄りに（横並びのため） */
      .step-nav .reserve-btn { width: auto; flex: 1 1 0; }
      /* 空のプレースホルダ（戻る無しの側）も同じ比率で場所を確保 */
      .step-nav > span { flex: 1 1 0; }
      /* ghost（戻る）は枠色を少し濃くして「押せる」ことを明示（次へとの活性差を確保） */
      .step-nav .reserve-btn.ghost { margin-top: 0; border-color: var(--c-purple-lt); color: var(--c-purple-dk); }

      /* 項目2: 画面下部に常時表示するナビバー（sticky）。スクロールしても親指位置に出す。 */
      .bottom-nav {
        position: sticky; bottom: 0; z-index: 20;
        background: rgba(253, 242, 245, .95);
        backdrop-filter: blur(6px);
        border-top: 1px solid var(--c-border);
        padding: .6rem 1rem calc(.6rem + env(safe-area-inset-bottom, 0px));
        transition: transform .15s ease; will-change: transform;
      }
      .bottom-nav-inner {
        max-width: 680px; margin: 0 auto;
        display: flex; align-items: center; gap: .8rem;
      }
      .bottom-nav-inner .reserve-btn { width: auto; flex: 1 1 0; }
      .bottom-nav-inner .reserve-btn.ghost { margin-top: 0; border-color: var(--c-purple-lt); color: var(--c-purple-dk); }

      @media (max-width: 700px) {
        /* ドット5つでもラベルが潰れないよう狭幅ではさらに小さく（ラベルは短縮済み：情報/要望/確認） */
        .steps-indicator { font-size: .66rem; gap: .2rem; }
        .steps-indicator .dot { width: 22px; height: 22px; }
        .steps-indicator li::before { top: 11px; }
        .steps-indicator .lbl { word-break: keep-all; }
        /* 送信ラベル（「この内容で仮予約する」）の折り返し回避：狭幅ではナビを縦積み */
        .step-nav { flex-direction: column; align-items: stretch; }
        .step-nav .reserve-btn { width: 100%; flex: none; }
        .step-nav > span { display: none; }
      }

      /* C5: 動きを抑える設定の利用者にはアニメ・自動スクロールを無効化 */
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
          scroll-behavior: auto !important;
        }
        /* スピナーは回転を止め、紫の弧を静的に見せる（前庭障害・動き軽減への配慮） */
        .spinner { animation: none !important; border-top-color: var(--c-purple); }
      }
    </style>
  </body>
</html>
