---
// 顧客管理ページ（/reserve/admin/customers）。P2 IA（ADR-0001 決定1）の「顧客管理」区分。
// 顧客台帳シート（LEDGER_SHEET）だけを素材にした「台帳ベース MVP」:
//   ・一覧＝氏名／タグ（新規 or 常連）／電話は常にマスク。行タップで同一ページ内の詳細パネルを開く。
//   ・詳細＝連絡先を PII 段階開示（既定マスク→[表示]で開示＋[コピー]＋放置で自動再マスク＝ADR-0001 決定3）。
//   ・来店履歴の「明細（日付＋メニュー）」は詳細を開くたびに read-only の adminListConfirmed（顧客キーで
//     突合したカレンダーの確定イベント）で取得して表示する。0件・失敗は正直に示す（作話しない）。
//
// 詳細は URL に顧客キーを載せず「在ページのパネル」で開く（のぞき見／Cookie Path 両面で有利）。
// データは read-only の GAS `adminListCustomers`（Worker 経由・requireAdminToken_ 保護）だけで賄う。
//
// 管理ページ本体はオンデマンド（prerender:false リテラル）。static 配信されると middleware の
// サーバゲートを通らないため、必ずリテラル false にして Worker を通す（ADR-0002）。
// URL は Cookie Path=/reserve/admin 制約により /reserve/admin/ 配下固定（ADR-0001 決定1）。
export const prerender = false;

import { ENV_LABEL } from '../../../data/config.js';
import EnvBadge from '../../../components/EnvBadge.astro';
import SubmitOverlay from '../../../components/SubmitOverlay.astro';
import AdminHeader from '../../../components/AdminHeader.astro';
import '../../../styles/admin.css';
import '../../../styles/admin-cabinet.css';

const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
const salonName = 'サロン和笑〜Violane〜';
const tel = '090-9095-6034';
const pageTitle = `${ENV_LABEL}顧客管理 | ${salonName}`;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href={`${base}favicon.jpg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <EnvBadge />
    <SubmitOverlay message="送信しています…" subtext="画面をそのままでお待ちください" />
    <AdminHeader base={base} salonName={salonName} title="顧客管理" back="/reserve/admin" backLabel="管理トップ" />

    <main class="wrap">
      <div class="panel-bar">
        <button type="button" class="linkish" id="logoutBtn">ログアウト</button>
      </div>

      <!-- 顧客一覧（電話は常にマスク）。行タップで在ページの詳細パネルへ -->
      <section id="listSection">
        <div class="sec-head">
          <h2 class="section-title">顧客一覧<span class="section-count" id="listCount"></span></h2>
          <div class="sec-head__actions">
            <button type="button" class="reserve-btn ghost sm" id="mergeToggle">顧客を統合</button>
            <button type="button" class="reserve-btn ghost sm" id="reloadBtn">再読み込み</button>
          </div>
        </div>
        <p class="state-cap"><b>●</b> 一覧では電話は常にマスク（のぞき見対策）</p>

        <!-- 手動マージ（統合）バー。「顧客を統合」で表示。同じお客様の重複を店主が1人にまとめる保険。 -->
        <div class="merge-bar" id="mergeBar" hidden>
          <p class="merge-bar__lead">同じお客様の重複を1人にまとめます。一覧から<b>統合元</b>（消える側）と<b>統合先</b>（残る側）の2名をタップしてください。</p>
          <div class="merge-bar__slots">
            <div class="merge-slot is-src" id="mergeSrcSlot"><span class="merge-slot__lbl">統合元</span><span class="merge-slot__nm" id="mergeSrcNm">未選択</span></div>
            <button type="button" class="merge-swap" id="mergeSwap" title="統合元と統合先を入れ替え" aria-label="統合元と統合先を入れ替え">⇄</button>
            <div class="merge-slot is-tgt" id="mergeTgtSlot"><span class="merge-slot__lbl">統合先</span><span class="merge-slot__nm" id="mergeTgtNm">未選択</span></div>
          </div>
          <div class="merge-bar__actions">
            <button type="button" class="reserve-btn sm" id="mergeRun" disabled>統合する</button>
            <button type="button" class="linkish" id="mergeCancel">やめる</button>
          </div>
        </div>

        <div class="sort-bar" id="sortBar">
          <span class="sort-bar__lbl">並び替え</span>
          <button type="button" class="sort-btn is-active" data-key="lastVisit" data-label="最終来店">最終来店 ▼</button>
          <button type="button" class="sort-btn" data-key="count" data-label="来店回数">来店回数</button>
        </div>
        <div id="listArea">
          <div class="status loading"><span class="spinner" aria-hidden="true"></span><span>読み込んでいます…</span></div>
        </div>
      </section>

      <!-- 詳細パネル（在ページ・顧客キーは URL に出さない）。行タップで描画・表示 -->
      <section id="detailSection" hidden>
        <div id="detailArea"></div>
      </section>
    </main>

    <footer class="site-footer">
      <p>{salonName}</p>
      <p class="small">富山県高岡市野村1180-1 / <a href={`tel:${tel}`}>{tel}</a></p>
    </footer>

    <!-- 汎用の確認モーダル（保存・統合の前段クッション・誤操作防止）。氏名編集・連絡先追加・統合の
         3用途で使い回す。開く実体は openConfirm()、中身（見出し／本文／警告／実行ラベル／実行処理）は
         呼び出し側が渡す。破壊的操作（統合）のときだけ警告文を出す。role="dialog"/aria-modal・Escで
         閉じる・開いたら実行ボタンへフォーカス・背景クリックで閉じる（実行中は閉じない）。 -->
    <div class="modal-overlay" id="confirmModal" hidden>
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="confirmTitle">
        <h3 id="confirmTitle" class="modal__title"></h3>
        <p class="modal__body" id="confirmBody"></p>
        <p class="modal__warn" id="confirmWarn" hidden></p>
        <div class="modal__actions">
          <button type="button" class="reserve-btn sm" id="confirmYes">実行する</button>
          <button type="button" class="reserve-btn ghost sm" id="confirmNo">やめる</button>
        </div>
      </div>
    </div>

    <div id="toast"></div>

    <script>
      // 顧客一覧＝read-only の adminListCustomers（Worker 経由・Cookie セッションで認可）。
      // 認証はサーバゲート（middleware）に一本化済み。このページは認証済みでのみ配信される。
      // PII 段階開示（一覧マスク／詳細は表示→コピー→自動再マスク）は ADR-0001 決定3 準拠。
      import { createAdminApi } from '../../../lib/admin-api.js';
      import { esc, createToast, loadingHtml, emptyHtml } from '../../../lib/admin-ui.js';

      const el = (id) => document.getElementById(id);
      const { apiPost, logout, handleForbidden } = createAdminApi();
      const toast = createToast(el);

      // アイコン（mock-2-customer.html 準拠）。目＝表示／四角＝コピー／時計＝自動再マスクの注記。
      const EYE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-6.5 10-6.5S22 12 22 12s-3.5 6.5-10 6.5S2 12 2 12z"/><circle cx="12" cy="12" r="2.6"/></svg>';
      const COPY = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="8.5" y="8.5" width="11" height="11" rx="2"/><path d="M5.5 15.5H5a1.5 1.5 0 01-1.5-1.5V5A1.5 1.5 0 015 3.5h9A1.5 1.5 0 0115.5 5v.5"/></svg>';
      const CLOCK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>';

      const REMASK_MS = 20000; // 放置で自動再マスクまでの目安（20秒）
      let remaskTimers = []; // 開示中の自動再マスクタイマ（連絡先が複数行になり得るため配列で管理）
      let customersData = [];   // GAS 取得の原本（行＝channel）
      let groupedData = [];     // person 単位にまとめた表示用（同一 person の複数 channel を1名に dedup）
      let viewData = [];        // 並び替え後の表示用（data-i はこちらの添字・person 単位）
      let sortKey = 'lastVisit'; // 既定＝最終来店（GAS も同順で返す）
      let sortDir = 'desc';
      // 手動マージ（統合）モードの状態。src/tgt は person の突合キー（personRef）で保持する。
      let mergeMode = false;
      let mergeSel = { src: null, tgt: null };

      // ---- 電話・メールの整形／マスク ----
      // 台帳の電話は正規化済み（数字のみ）。ハイフン付きの整形はここ（フロント）で行う。
      // 桁が想定外なら整形せずそのまま返す（作話しない）。
      function fmtPhone(d) {
        const s = String(d || '').replace(/[^0-9]/g, '');
        if (s.length === 11) return s.slice(0, 3) + '-' + s.slice(3, 7) + '-' + s.slice(7);
        return s;
      }
      function maskPhone(d) {
        const s = String(d || '').replace(/[^0-9]/g, '');
        if (s.length >= 7) return s.slice(0, 3) + '-****-' + s.slice(-4);
        return '****';
      }
      // 一覧セル用（**** を金みの stars で見せる。中身は数字のみ由来で安全だが esc は明示）。
      function maskPhoneCell(d) {
        const s = String(d || '').replace(/[^0-9]/g, '');
        if (s.length >= 7) return esc(s.slice(0, 3)) + '-<span class="stars">****</span>-' + esc(s.slice(-4));
        return '<span class="stars">****</span>';
      }
      function maskEmail(e) {
        const s = String(e || '');
        const at = s.indexOf('@');
        if (at < 1) return '****';
        const local = s.slice(0, at);
        const domain = s.slice(at + 1);
        const tld = domain.lastIndexOf('.') >= 0 ? domain.slice(domain.lastIndexOf('.')) : '';
        return local.slice(0, 1) + '***@****' + tld;
      }
      // 日付表示：GAS は yyyy-MM-dd で返す（ledgerDateStr_ で正規化済み）。念のため Date 文字列にも耐える。
      function fmtDate(v) {
        const s = String(v || '');
        if (!s) return '';
        const m = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
        if (m) return m[1] + '/' + m[2] + '/' + m[3];
        const d = new Date(s);
        if (!isNaN(d.getTime())) {
          const p = (n) => String(n).padStart(2, '0');
          return d.getFullYear() + '/' + p(d.getMonth() + 1) + '/' + p(d.getDate());
        }
        return s;
      }

      // ============================================================
      // 汎用確認モーダル（保存・統合の前段クッション）
      //   氏名編集・連絡先追加・統合の3用途で #confirmModal を1つ使い回す（重複排除＝分割統治）。
      //   呼び出し側は openConfirm() に「見出し・本文HTML・警告文（任意）・実行ラベル・実行ボタンの
      //   装い（任意）・実行処理 onOk」を渡すだけ。本文は innerHTML で流し込むため、可変値は必ず
      //   呼び出し側で esc() 済みにして渡す（属性/HTMLブレイクアウト防止）。
      //   実行中は両ボタンを無効化して二重送信を防ぎ、onOk 完了後は成否を問わず必ず閉じる。
      //   Esc・背景クリックで閉じる（実行中は閉じない＝安全側）。開いたら実行ボタンへフォーカス。
      // ============================================================
      let confirmOnOk = null;   // いま開いている確認モーダルの実行処理
      let confirmBusy = false;  // 実行中フラグ（二重送信・閉じ操作の抑止）
      function openConfirm({ title, bodyHtml, warn, okLabel, okClass, onOk }) {
        el('confirmTitle').textContent = title || '確認';
        el('confirmBody').innerHTML = bodyHtml || '';
        const warnEl = el('confirmWarn');
        if (warn) { warnEl.textContent = warn; warnEl.hidden = false; }
        else { warnEl.textContent = ''; warnEl.hidden = true; }
        const yes = el('confirmYes');
        yes.textContent = okLabel || '実行する';
        yes.className = 'reserve-btn sm' + (okClass ? ' ' + okClass : '');
        confirmOnOk = onOk || null;
        confirmBusy = false;
        yes.disabled = false; el('confirmNo').disabled = false;
        el('confirmModal').hidden = false;
        try { yes.focus({ preventScroll: true }); } catch (_) { yes.focus(); } // 開いたら実行ボタンへ
      }
      function closeConfirm() {
        if (confirmBusy) return;          // 実行中は閉じない（誤操作の安全側）
        el('confirmModal').hidden = true;
        confirmOnOk = null;
      }
      el('confirmYes').addEventListener('click', async () => {
        if (confirmBusy) return;          // 実行中の二重クリックは無視
        const fn = confirmOnOk;
        confirmBusy = true;
        el('confirmYes').disabled = true; el('confirmNo').disabled = true;
        try { if (fn) await fn(); }        // 実行処理は既存の保存フローそのもの（前段の確認だけ足す）
        finally {                          // 成功・失敗を問わず必ず閉じる（背後の状態表示を見せる）
          confirmBusy = false;
          el('confirmModal').hidden = true;
          confirmOnOk = null;
        }
      });
      el('confirmNo').addEventListener('click', closeConfirm);
      // 背景（オーバーレイ余白）クリックで閉じる＝誤タップ時の安全側（実行しない）。既存 mergeConfirm 準拠。
      el('confirmModal').addEventListener('click', (e) => { if (e.target === el('confirmModal')) closeConfirm(); });
      // Esc で閉じる（開いている・非実行中のときだけ）。
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !el('confirmModal').hidden) closeConfirm(); });

      // ============================================================
      // 顧客一覧
      // ============================================================
      async function loadCustomers() {
        el('listArea').innerHTML = loadingHtml();
        el('detailSection').hidden = true;
        el('listSection').hidden = false;
        clearRemask();
        let res;
        try {
          res = await apiPost('adminListCustomers', null, { silent: true });
        } catch (_) {
          el('listArea').innerHTML = emptyHtml('通信に失敗しました。時間をおいて再度お試しください。', { warn: true });
          return;
        }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (!res || !res.ok || !Array.isArray(res.customers)) {
          el('listArea').innerHTML = emptyHtml('顧客台帳を取得できませんでした。', { warn: true });
          return;
        }
        customersData = res.customers;
        groupedData = groupByPerson(customersData);
        applySortAndRender();
      }

      // 同一 person の複数 channel 行を1名にまとめる（連絡先編集・名寄せ後の重複表示を解消）。
      // 束ねるキーは GAS が純追加した opaque な personRef（personId の SHA-256・生の内部IDは出ない）。
      // personRef が無い（旧応答）ときは自 channel の突合キー key にフォールバック＝行ごとに一意＝
      // 従来どおり 1 行 1 名（回帰ゼロ）。ここは表示だけ・台帳/カレンダーには一切書かない。
      function groupByPerson(rows) {
        const map = new Map();
        const order = [];
        rows.forEach((r) => {
          const ref = r.personRef || r.key;
          if (!map.has(ref)) { map.set(ref, []); order.push(ref); }
          map.get(ref).push(r);
        });
        return order.map((ref) => mergePersonRows(ref, map.get(ref)));
      }

      // 連絡先の優先度（詳細・履歴突合の代表 channel を選ぶ）：電話→メール→LINE。
      const chanRank = (r) => (r.type === 'phone' ? 0 : r.type === 'email' ? 1 : 2);

      // 1 person にぶら下がる channel 行群を、表示用の1オブジェクトに畳む。
      function mergePersonRows(ref, rows) {
        // 代表 channel＝連絡先を持つものを優先（氏名/メモ/連絡先追加・履歴突合の起点キーに使う）。
        const rep = rows.slice().sort((a, b) => chanRank(a) - chanRank(b))[0];
        // 連絡先一覧（詳細で全 channel を見せる）。順序は電話→メール→LINE。
        const channels = rows.slice().sort((a, b) => chanRank(a) - chanRank(b))
          .map((r) => ({ type: r.type, phone: r.phone, email: r.email, key: r.key }));
        // 突合トークンは person の全 channel の和集合（GAS も和集合で返すが念のため union で堅牢化）。履歴 OR 突合用。
        const tokenSet = new Set();
        rows.forEach((r) => (r.matchTokens && r.matchTokens.length ? r.matchTokens : [r.key]).forEach((t) => { if (t) tokenSet.add(t); }));
        // 集約 stats は channel 行の値から近似（count=最大・firstVisit=最小・lastVisit=最大）。
        // ※Phase 3 の連絡先追加は新 channel へ stats をコピーするため通常は全 channel 同値。
        //   厳密な person 合算は person シートが正だが、一覧の dedup 表示にはこの近似で足りる（作話はしない）。
        let count = 0, first = '', last = '';
        rows.forEach((r) => {
          const c = Number(r.count || 0);
          if (c > count) count = c;
          const fv = String(r.firstVisit || ''); if (fv && (!first || fv < first)) first = fv;
          const lv = String(r.lastVisit || ''); if (lv && (!last || lv > last)) last = lv;
        });
        return {
          personRef: ref,
          name: rep.name,                 // person.displayName（全 channel 鏡写し済み＝どの行でも同値）
          count: count,
          firstVisit: first,
          lastVisit: last,
          note: rep.note || '',           // person メモ（全 channel 鏡写し済み）
          tag: count <= 1 ? '新規' : '常連',
          key: rep.key,                   // 代表 channel の突合トークン（氏名/メモ/連絡先追加・履歴の起点）
          type: rep.type,
          phone: rep.phone,
          email: rep.email,
          matchTokens: Array.from(tokenSet),
          channels: channels,
        };
      }

      // 並び替え（最終来店＝yyyy-MM-dd 文字列比較／来店回数＝数値）。原本を壊さずコピーを並べる。
      function sortCustomers(list) {
        const arr = list.slice();
        const dir = sortDir === 'asc' ? 1 : -1;
        arr.sort((a, b) => {
          let av, bv;
          if (sortKey === 'count') { av = a.count || 0; bv = b.count || 0; }
          else { av = a.lastVisit || ''; bv = b.lastVisit || ''; }
          if (av < bv) return -1 * dir;
          if (av > bv) return 1 * dir;
          return 0;
        });
        return arr;
      }
      function applySortAndRender() {
        viewData = sortCustomers(groupedData);
        renderList(viewData);
        updateSortUI();
        if (mergeMode) paintMergeSelection(); // 再描画後に統合の選択ハイライトを復元
      }
      function updateSortUI() {
        const bar = el('sortBar');
        if (!bar) return;
        bar.querySelectorAll('.sort-btn').forEach((b) => {
          const active = b.getAttribute('data-key') === sortKey;
          b.classList.toggle('is-active', active);
          const arrow = active ? (sortDir === 'asc' ? ' ▲' : ' ▼') : '';
          b.textContent = b.getAttribute('data-label') + arrow;
        });
      }

      function renderList(list) {
        el('listCount').textContent = list.length ? '（' + list.length + '名）' : '';
        if (!list.length) {
          el('listArea').innerHTML = emptyHtml('登録された顧客がまだありません（確定予約が入ると台帳に記録されます）。');
          return;
        }
        el('listArea').innerHTML = '<div class="clist">' + list.map((c, i) => {
          const tagCls = c.tag === '新規' ? 'first' : 'regular';
          const tag = '<span class="tag ' + tagCls + '">' + esc(c.tag) + '</span>';
          // メモ有りマーク（✎）。本文は一覧に出さない＝のぞき見耐性（本文は詳細パネルで表示）。
          const hasNote = !!(c.note && c.note.trim());
          const memoMark = hasNote ? '<span class="clist__memo" title="メモあり" aria-label="メモあり">✎</span>' : '';
          // 複数の連絡先（channel）を持つ person は「連絡先N件」チップを添える（まとめて1名で見えている合図）。
          // 折り返さない見出し行ではなく、折り返し可能なサブ行に置く（狭幅でのはみ出し回避）。
          const nCh = (c.channels && c.channels.length) || 1;
          const chip = nCh > 1 ? '<span class="clist__chip" title="連絡先が複数あります">連絡先 ' + esc(nCh) + ' 件</span>' : '';
          // 2段目：来店回数・最終来店・（連絡先チップ）・電話（phone 型のみ常にマスク／line・email 型は電話省略）。
          const dot = '<span class="clist__dot">·</span>';
          let sub = '<span class="clist__cnt">来店 <b>' + esc(c.count != null ? c.count : 0) + '</b> 回</span>'
            + dot + '<span class="clist__last">最終 ' + esc(c.lastVisit ? fmtDate(c.lastVisit) : '—') + '</span>'
            + chip;
          if (c.type === 'phone' && c.phone) sub += '<span class="clist__ph">' + maskPhoneCell(c.phone) + '</span>';
          return '<button type="button" class="clist__row" data-i="' + i + '" data-ref="' + esc(c.personRef || c.key) + '">'
            + '<span class="clist__head"><span class="clist__nm">' + esc(c.name || '（お名前未登録）') + '</span>' + tag + memoMark + '</span>'
            + '<span class="clist__sub">' + sub + '</span>'
            + '</button>';
        }).join('') + '</div>';
      }

      el('listArea').addEventListener('click', (e) => {
        const row = e.target.closest('.clist__row');
        if (!row) return;
        // 統合モード中はタップ＝選択（詳細は開かない）。通常はタップ＝詳細を開く。
        if (mergeMode) { toggleMergeSelect(row.getAttribute('data-ref')); return; }
        openDetail(Number(row.getAttribute('data-i')));
      });

      // ============================================================
      // 手動マージ（統合）— 店主が同じお客様の重複を1人にまとめる保険
      //   sourceKey/targetKey は person の代表 channel の突合トークン（GAS が rawKeyForHash_→personResolve_ で
      //   personId に解決し、source を target へ寄せる）。破壊的操作ゆえ実行前に必ず確認ダイアログを出す。
      // ============================================================
      function personByRef(ref) { return viewData.find((c) => (c.personRef || c.key) === ref) || null; }
      const refName = (ref) => { const p = personByRef(ref); return p ? (p.name || '（お名前未登録）') : '未選択'; };

      function enterMergeMode() {
        mergeMode = true; mergeSel = { src: null, tgt: null };
        closeDetail();                    // 詳細を開いていたら閉じて一覧へ
        el('mergeBar').hidden = false;
        el('listArea').classList.add('is-merge');
        el('mergeToggle').textContent = '統合をやめる';
        paintMergeSelection();
      }
      function exitMergeMode() {
        mergeMode = false; mergeSel = { src: null, tgt: null };
        el('mergeBar').hidden = true;
        closeConfirm();
        el('listArea').classList.remove('is-merge');
        el('mergeToggle').textContent = '顧客を統合';
        paintMergeSelection();
      }
      function toggleMergeSelect(ref) {
        if (!ref) return;
        if (mergeSel.src === ref) mergeSel.src = null;
        else if (mergeSel.tgt === ref) mergeSel.tgt = null;
        else if (!mergeSel.src) mergeSel.src = ref;
        else if (!mergeSel.tgt) mergeSel.tgt = ref;
        else mergeSel.tgt = ref;         // 両方選択済みなら統合先を差し替え
        paintMergeSelection();
      }
      // 選択ハイライト（行）＋バーの表示＋実行ボタンの活性を、現在の mergeSel に同期する。
      function paintMergeSelection() {
        el('listArea').querySelectorAll('.clist__row').forEach((row) => {
          const ref = row.getAttribute('data-ref');
          row.classList.toggle('is-src', mergeMode && ref === mergeSel.src);
          row.classList.toggle('is-tgt', mergeMode && ref === mergeSel.tgt);
        });
        el('mergeSrcNm').textContent = mergeSel.src ? refName(mergeSel.src) : '未選択';
        el('mergeTgtNm').textContent = mergeSel.tgt ? refName(mergeSel.tgt) : '未選択';
        el('mergeRun').disabled = !(mergeSel.src && mergeSel.tgt);
      }
      function openMergeConfirm() {
        if (!(mergeSel.src && mergeSel.tgt)) return;
        openConfirm({
          title: 'お客様を統合します',
          bodyHtml: '「' + esc(refName(mergeSel.src)) + '」を「' + esc(refName(mergeSel.tgt)) + '」に統合します。'
            + '統合元は統合先にまとめられ、これまでのご来店の記録は統合先に引き継がれます。',
          warn: '⚠ この操作は「元に戻す」のに手間がかかります。実行前に台帳（スプレッドシート）のバックアップをおすすめします。',
          okLabel: '統合する',
          okClass: 'decline', // 破壊的操作＝注意色の実行ボタン（既存 mergeConfirm と同じ装い）
          onOk: runMerge,
        });
      }
      async function runMerge() {
        const s = personByRef(mergeSel.src), t = personByRef(mergeSel.tgt);
        if (!s || !t) return;
        let res;
        try {
          res = await apiPost('adminMergeCustomers', { sourceKey: s.key, targetKey: t.key });
        } catch (_) { toast('統合に失敗しました'); return; }
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (!res || !res.ok) {
          const map = {
            same_customer: '同じお客様どうしは統合できません',
            not_found: 'お客様が見つかりませんでした',
            bad_request: '選択が正しくありません',
          };
          toast((res && map[res.error]) || '統合できませんでした');
          return;
        }
        if (res.unchanged) toast('すでに同じお客様でした');
        else toast('お客様を統合しました' + (res.count != null ? '（来店 ' + res.count + ' 回分を引き継ぎ）' : ''));
        exitMergeMode();
        loadCustomers();                 // 台帳の状態が変わる＝読み直して最新化（作話しない）
      }

      el('mergeToggle').addEventListener('click', () => { if (mergeMode) exitMergeMode(); else enterMergeMode(); });
      el('mergeCancel').addEventListener('click', exitMergeMode);
      el('mergeSwap').addEventListener('click', () => { const s = mergeSel.src; mergeSel.src = mergeSel.tgt; mergeSel.tgt = s; paintMergeSelection(); });
      el('mergeRun').addEventListener('click', openMergeConfirm);

      // 並び替えバー：同じキーは方向トグル、違うキーは降順から。
      el('sortBar').addEventListener('click', (e) => {
        const btn = e.target.closest('.sort-btn');
        if (!btn) return;
        const key = btn.getAttribute('data-key');
        if (key === sortKey) sortDir = (sortDir === 'asc' ? 'desc' : 'asc');
        else { sortKey = key; sortDir = 'desc'; }
        applySortAndRender();
      });

      // ============================================================
      // 詳細パネル（在ページ・PII 段階開示）
      // ============================================================
      function clearRemask() { remaskTimers.forEach(clearTimeout); remaskTimers = []; }

      function openDetail(i) {
        const c = viewData[i];
        if (!c) return;
        clearRemask();
        el('detailArea').innerHTML = detailHtml(c);
        el('listSection').hidden = true;
        el('detailSection').hidden = false;
        window.scrollTo({ top: 0, behavior: 'auto' });
        wireDetail();
        wireName(c); // お名前のインライン編集（wireMemo と同型・全 type で動かす）
        wireContact(c); // 連絡先の変更・追加（Phase 3・type 非依存＝LINE 客にも足せる）
        wireMemo(c); // メモ配線は別関数（wireDetail は line 型で早期 return するため全 type で動かす）
        loadVisits(c); // 来店履歴は詳細を開くたびに取りに行く（一覧段階で明細 PII を持たない＝段階開示）
      }
      function closeDetail() {
        clearRemask();
        el('detailSection').hidden = true;
        el('listSection').hidden = false;
      }

      // 来店履歴＝read-only の adminListConfirmed。c.key は台帳キーを GAS 側で SHA-256 化した opaque な
      // 突合トークン（生の識別子は出ない）で、そのまま echo するだけ。GAS が同じハッシュでイベントを突合し、
      // その顧客の来店だけを返す（他人の履歴は混ざらない）。0件・失敗は正直に示す。
      async function loadVisits(c) {
        const body = el('histBody');
        if (!body) return;
        if (!c.key) { // 突合トークンが無ければ履歴を引けない（作話しない）
          body.innerHTML = emptyHtml('来店履歴を表示できませんでした。');
          return;
        }
        let res;
        try {
          // その person が持つ全 channel の突合トークン（matchTokens）で OR 突合を頼む。GAS 側は matchTokens が
          // 非空なら OR、無ければ key で単一突合にフォールバック。Phase 1 は matchTokens=[key] ゆえ結果は同一。
          res = await apiPost('adminListConfirmed', { key: c.key, matchTokens: c.matchTokens }, { silent: true });
        } catch (_) {
          if (el('histBody') !== body) return; // 取得中に別の詳細へ切り替わっていたら破棄
          body.innerHTML = emptyHtml('来店履歴の取得に失敗しました。', { warn: true });
          return;
        }
        if (el('histBody') !== body) return; // レース対策：開いている詳細が変わっていたら反映しない
        if (res && res.error === 'forbidden') { handleForbidden(); return; }
        if (!res || !res.ok || !Array.isArray(res.visits)) {
          body.innerHTML = emptyHtml('来店履歴を取得できませんでした。', { warn: true });
          return;
        }
        renderVisits(body, res.visits);
      }

      function renderVisits(body, visits) {
        if (!visits.length) {
          body.innerHTML = emptyHtml('来店履歴がまだありません。');
          return;
        }
        body.innerHTML = '<ul class="hist__list">' + visits.map((v) => {
          const d = esc(fmtDate(v.date));
          const t = v.time ? '<span class="hist__time">' + esc(v.time) + '</span>' : '';
          return '<li class="hist__item">'
            + '<span class="hist__date">' + d + t + '</span>'
            + '<span class="hist__menu">' + esc(v.menuName || '') + '</span>'
            + '</li>';
        }).join('') + '</ul>';
      }

      // 連絡先フィールド（person 単位）。名寄せ後は同一 person が複数 channel（電話・メール・LINE）を
      // 持ち得るため、その person の全 channel を段階開示の行として並べる（phone/email は開示可・LINE は連絡先なし）。
      function contactFields(c) {
        const chans = (c.channels && c.channels.length)
          ? c.channels
          : [{ type: c.type, phone: c.phone, email: c.email }]; // 旧応答フォールバック
        const contactChans = chans.filter((ch) => (ch.type === 'phone' && ch.phone) || (ch.type === 'email' && ch.email));
        const hasLine = chans.some((ch) => !ch.phone && !ch.email); // LINE 等・連絡先を持たない channel の有無
        if (!contactChans.length) {
          return '<div class="field"><div class="field__lbl">連絡先</div>'
            + '<div class="field__note">LINE連携のお客様です（電話・メールは台帳にありません）。</div></div>';
        }
        let html = contactChans.map((ch) => (ch.type === 'phone' && ch.phone)
          ? piiField('電話番号', maskPhone(ch.phone), fmtPhone(ch.phone))
          : piiField('メール', maskEmail(ch.email), ch.email)
        ).join('');
        if (hasLine) html += '<div class="field"><div class="field__note">このほかに LINE 連携の連絡先があります。</div></div>';
        return html;
      }
      // 既定マスク→[表示]で開示＋[コピー]表示＋放置で自動再マスク（ADR-0001 決定3）。
      function piiField(label, masked, full) {
        return '<div class="field">'
          + '<div class="field__lbl">' + esc(label) + '</div>'
          + '<div class="pii-row">'
          +   '<span class="pii masked" data-full="' + esc(full) + '" data-mask="' + esc(masked) + '">' + esc(masked) + '</span>'
          +   '<span class="pii-actions">'
          +     '<button type="button" class="mini-btn reveal">' + EYE + '表示</button>'
          +     '<button type="button" class="mini-btn copy" hidden>' + COPY + 'コピー</button>'
          +   '</span>'
          + '</div>'
          + '<div class="reveal-note" hidden>' + CLOCK + '操作がなければ自動で再びマスクします</div>'
          + '</div>';
      }
      function metaField(label, val) {
        return '<div class="field"><div class="field__lbl">' + esc(label) + '</div>'
          + '<div class="field__val">' + esc(val) + '</div></div>';
      }
      // 連絡先の変更・追加（Phase 3・氏名編集 wireName と同型の ✎→保存）。
      // 「貼り替え」ではなく「新しい連絡先を追加（過去の履歴は引き継ぐ）」＝type 非依存で、
      // LINE 連携のお客様にも電話・メールを足せる。placeholder は一般例のみ（実顧客の連絡先は載せない）。
      function contactEditHtml(c) {
        return '<div class="field contact-edit">'
          + '<div class="contact-edit__head">'
          +   '<button type="button" class="mini-btn" id="contactEdit" aria-label="連絡先を変更・追加">✎ 連絡先を変更・追加</button>'
          + '</div>'
          + '<div class="contact-edit__row" id="contactEditRow" hidden>'
          +   '<div class="field__note">新しい連絡先を追加します（過去のご来店履歴は引き継がれます）。</div>'
          +   '<div class="contact-edit__inputs">'
          +     '<select id="contactType" class="contact-type" aria-label="連絡先の種類">'
          +       '<option value="phone">電話番号</option>'
          +       '<option value="email">メール</option>'
          +     '</select>'
          +     '<input type="text" id="contactValue" class="name-input" maxlength="254" placeholder="例）09012345678 / name@example.com" aria-label="新しい連絡先">'
          +   '</div>'
          +   '<div class="name-edit__bar">'
          +     '<button type="button" class="mini-btn" id="contactSave">保存</button>'
          +     '<button type="button" class="linkish" id="contactCancel">やめる</button>'
          +     '<span id="contactStatus" class="memo__status" role="status"></span>'
          +   '</div>'
          + '</div>'
          + '</div>';
      }
      function detailHtml(c) {
        const tagCls = c.tag === '新規' ? 'first' : 'regular';
        const tags = '<span class="tag ' + tagCls + '">' + esc(c.tag) + '</span>';
        const cnt = (c.count != null ? String(c.count) : '—');
        return ''
          + '<div class="panel-bar"><button type="button" class="linkish" id="detailBack">‹ 一覧へ戻る</button></div>'
          + '<p class="state-cap"><b>●</b> 連絡先は既定でマスク（必要なときだけ表示・放置で自動再マスク）</p>'
          + '<div class="krt">'
          // お名前は person.displayName を"正"に表示。✎編集→入力→保存（メモ編集 wireMemo と同型・最小実装）。
          // 入力初期値は esc()（属性ブレイクアウト防止）、maxlength は GAS CUSTOMER_NAME_MAX（100）と一致。
          +   '<div class="krt__top"><div class="krt__nameblock">'
          +       '<div class="krt__namerow"><div class="krt__name" id="custName">' + esc(c.name || '（お名前未登録）') + '</div>'
          +         '<button type="button" class="mini-btn" id="nameEdit" aria-label="お名前を編集">✎ 編集</button></div>'
          +       '<div class="name-edit" id="nameEditRow" hidden>'
          +         '<input type="text" id="nameInput" class="name-input" maxlength="100" value="' + esc(c.name || '') + '" placeholder="お名前・呼び名">'
          +         '<div class="name-edit__bar">'
          +           '<button type="button" class="mini-btn" id="nameSave">保存</button>'
          +           '<button type="button" class="linkish" id="nameCancel">やめる</button>'
          +           '<span id="nameStatus" class="memo__status" role="status"></span>'
          +         '</div>'
          +       '</div>'
          +     '</div>'
          +     '<div class="tags">' + tags + '</div></div>'
          +   contactFields(c)
          +   contactEditHtml(c)
          +   metaField('来店回数', (c.count != null ? c.count + ' 回' : '—'))
          +   metaField('初来店', c.firstVisit ? fmtDate(c.firstVisit) : '—')
          +   metaField('最終来店', c.lastVisit ? fmtDate(c.lastVisit) : '—')
          + '</div>'
          // 恒久メモ（1顧客1つ・上書き）。line 型（連絡先なし）でも表示する＝全 type で編集可。
          // textarea 初期値は esc()（</textarea> ブレイクアウト防止）・maxlength は GAS CUSTOMER_NOTE_MAX と一致。
          + '<div class="memo">'
          +   '<div class="memo__h">メモ <span class="memo__hint">店主用・お客様には表示されません</span></div>'
          +   '<textarea id="memoText" class="memo__ta" maxlength="2000" placeholder="アレルギー・好み・注意点など、次回に申し送りたいこと">' + esc(c.note || '') + '</textarea>'
          +   '<div class="memo__bar"><span id="memoStatus" class="memo__status" role="status"></span>'
          +     '<button type="button" class="mini-btn memo__save" id="memoSave">保存</button></div>'
          + '</div>'
          + '<div class="hist">'
          +   '<div class="hist__h">来店履歴 <span class="n">全 ' + esc(cnt) + ' 回</span></div>'
          +   '<div id="histBody">' + loadingHtml('来店履歴を読み込んでいます…') + '</div>'
          + '</div>';
      }

      function wireDetail() {
        const area = el('detailArea');
        const back = area.querySelector('#detailBack');
        if (back) back.addEventListener('click', closeDetail);
        // 連絡先が複数行になり得る（名寄せ後の複数 channel）ため、全 .pii-row を個別に配線する。
        area.querySelectorAll('.pii-row').forEach(wirePiiRow);
      }

      // 1つの連絡先開示行（.pii-row）の配線：[表示]で開示→[コピー]／放置で自動再マスク（ADR-0001 決定3）。
      // タイマは行ごとに持ち、remaskTimers（配列）で束ねて clearRemask 一括解除に載せる。
      function wirePiiRow(row) {
        const pii = row.querySelector('.pii');
        const revealBtn = row.querySelector('.reveal');
        const copyBtn = row.querySelector('.copy');
        const note = row.parentElement.querySelector('.reveal-note');
        if (!pii || !revealBtn || !copyBtn) return;
        let timer = null;
        function remask() {
          pii.textContent = pii.getAttribute('data-mask');
          pii.classList.add('masked');
          revealBtn.hidden = false; copyBtn.hidden = true; if (note) note.hidden = true;
          timer = null;
        }
        revealBtn.addEventListener('click', () => {
          pii.textContent = pii.getAttribute('data-full');
          pii.classList.remove('masked');
          revealBtn.hidden = true; copyBtn.hidden = false; if (note) note.hidden = false;
          timer = setTimeout(remask, REMASK_MS); // 放置で自動再マスク（この行のみ）
          remaskTimers.push(timer);
        });
        copyBtn.addEventListener('click', () => {
          const full = pii.getAttribute('data-full');
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(full).then(() => toast('コピーしました')).catch(() => toast('コピーできませんでした'));
          } else {
            toast('コピーに対応していない環境です');
          }
        });
      }

      // お名前編集の配線。person.displayName を店主が編集する（adminSetCustomerName・Worker 経由・Cookie セッション認可）。
      // ✎編集→入力→保存。成功時は同一オブジェクト参照の c.name を書き換えて applySortAndRender（一覧・詳細に即反映）。
      // 表示の"正"は GAS 側で person.displayName（無ければ channel.name）。次回 reload でも編集後の名前で返る。
      function wireName(c) {
        const area = el('detailArea');
        const editBtn = area.querySelector('#nameEdit');
        const editRow = area.querySelector('#nameEditRow');
        const input = area.querySelector('#nameInput');
        const saveBtn = area.querySelector('#nameSave');
        const cancelBtn = area.querySelector('#nameCancel');
        const nameEl = area.querySelector('#custName');
        const status = area.querySelector('#nameStatus');
        if (!editBtn || !editRow || !input || !saveBtn) return;
        const setStatus = (msg, cls) => { if (status) { status.textContent = msg; status.className = 'memo__status' + (cls ? ' ' + cls : ''); } };
        const openEdit = () => { editRow.hidden = false; editBtn.hidden = true; input.value = c.name || ''; input.focus(); input.select(); };
        const closeEdit = () => { editRow.hidden = true; editBtn.hidden = false; setStatus('', ''); };
        editBtn.addEventListener('click', openEdit);
        cancelBtn.addEventListener('click', closeEdit);
        // 実行本体＝従来の保存フローそのまま（挙動・エラー処理・成功後処理は不変）。二重送信は確認モーダル側で抑止。
        const doSaveName = async (v) => {
          setStatus('保存中…', '');
          let res;
          try {
            res = await apiPost('adminSetCustomerName', { key: c.key, name: v }, { silent: true });
          } catch (_) {
            setStatus('保存に失敗しました', 'is-warn');
            return;
          }
          if (res && res.error === 'forbidden') { handleForbidden(); return; }
          if (!res || !res.ok) {
            setStatus(res && res.error === 'too_long' ? '100文字以内で入力してください' : '保存できませんでした', 'is-warn');
            return;
          }
          c.name = v;                                  // 一覧・詳細は同一オブジェクト参照ゆえ即反映
          nameEl.textContent = v || '（お名前未登録）'; // 詳細の見出しを即更新
          editRow.hidden = true; editBtn.hidden = false;
          applySortAndRender();                        // 一覧の氏名を更新（並び順は氏名非依存で不変）
          setStatus('保存しました', 'is-ok');
          toast('お名前を保存しました');
        };
        // 「保存」押下→即 apiPost せず、まず確認モーダルで「何をどう変えるか」を提示する（前段クッション）。
        saveBtn.addEventListener('click', () => {
          const v = input.value;
          const cur = (c.name && c.name.trim()) ? c.name : '';
          openConfirm({
            title: 'お名前の保存',
            bodyHtml: cur
              ? 'お名前を『' + esc(cur) + '』→『' + esc(v) + '』に変更します。'
              : 'お名前を『' + esc(v) + '』に登録します。',
            okLabel: '保存する',
            onOk: () => doSaveName(v),
          });
        });
      }

      // 連絡先編集の配線（Phase 3）。adminSetCustomerContact（Worker 経由・Cookie セッション認可）で、
      // 新しい連絡先を「新 channel」として同じ person に追加する（旧 channel は履歴エイリアスとして残る）。
      // ✎→種類選択（電話/メール）→入力→保存。type 非依存ゆえ LINE 連携のお客様にも足せる。
      // 成功時は台帳の状態が変わる（channel が増える）ため、一覧を読み直して最新化する（作話しない）。
      function wireContact(c) {
        const area = el('detailArea');
        const editBtn = area.querySelector('#contactEdit');
        const editRow = area.querySelector('#contactEditRow');
        const typeSel = area.querySelector('#contactType');
        const input = area.querySelector('#contactValue');
        const saveBtn = area.querySelector('#contactSave');
        const cancelBtn = area.querySelector('#contactCancel');
        const status = area.querySelector('#contactStatus');
        if (!editBtn || !editRow || !typeSel || !input || !saveBtn) return;
        const setStatus = (msg, cls) => { if (status) { status.textContent = msg; status.className = 'memo__status' + (cls ? ' ' + cls : ''); } };
        typeSel.value = (c.type === 'email') ? 'email' : 'phone'; // 既定は現在の連絡先種別に寄せる
        const openEdit = () => { editRow.hidden = false; editBtn.hidden = true; input.value = ''; input.focus(); };
        const closeEdit = () => { editRow.hidden = true; editBtn.hidden = false; input.value = ''; setStatus('', ''); };
        editBtn.addEventListener('click', openEdit);
        cancelBtn.addEventListener('click', closeEdit);
        // 実行本体＝従来の保存フローそのまま（挙動・エラー処理・成功後処理は不変）。二重送信は確認モーダル側で抑止。
        const doSaveContact = async (contactType, value) => {
          setStatus('保存中…', '');
          let res;
          try {
            res = await apiPost('adminSetCustomerContact', { key: c.key, contactType, value }, { silent: true });
          } catch (_) {
            setStatus('保存に失敗しました', 'is-warn');
            return;
          }
          if (res && res.error === 'forbidden') { handleForbidden(); return; }
          if (!res || !res.ok) {
            const msgMap = {
              invalid_phone: '電話番号の形式が正しくありません（数字10〜11桁）',
              invalid_email: 'メールアドレスの形式が正しくありません',
              too_long: '入力が長すぎます',
              key_conflict: 'この連絡先は別のお客様が使用中のため追加できません',
              not_found: 'お客様が見つかりませんでした',
            };
            setStatus((res && msgMap[res.error]) || '保存できませんでした', 'is-warn');
            return;
          }
          setStatus('保存しました', 'is-ok');
          toast('連絡先を追加しました（過去のご来店履歴は引き継がれます）');
          loadCustomers(); // 新 channel が増える＝台帳の状態が変わるので一覧を最新化（一覧へ戻る）
        };
        // 「保存」押下→即 apiPost せず、まず確認モーダルで「何を追加するか」を提示する（前段クッション）。
        // 空入力は従来どおりモーダルを出さず即エラー表示（追加対象が無いため）。
        saveBtn.addEventListener('click', () => {
          const contactType = typeSel.value;
          const value = input.value.trim();
          if (!value) { setStatus('連絡先を入力してください', 'is-warn'); return; }
          const kind = contactType === 'email' ? 'メール' : '電話番号';
          openConfirm({
            title: '連絡先の追加',
            bodyHtml: 'この連絡先を追加します：〔' + esc(kind) + '〕' + esc(value) + '。過去のご来店履歴は引き継がれます。',
            okLabel: '保存する',
            onOk: () => doSaveContact(contactType, value),
          });
        });
      }

      // メモ保存の配線。wireDetail と分離＝line 型（連絡先なし）でも動くようにする。
      // 保存は adminSetCustomerNote（Worker 経由・Cookie セッションで認可）。成功時は同一オブジェクト
      // 参照の c.note を書き換えて applySortAndRender（一覧の ✎ マークが即反映・並び順は note 非依存で不変）。
      function wireMemo(c) {
        const area = el('detailArea');
        const ta = area.querySelector('#memoText');
        const saveBtn = area.querySelector('#memoSave');
        const status = area.querySelector('#memoStatus');
        if (!ta || !saveBtn) return;
        const setStatus = (msg, cls) => { if (status) { status.textContent = msg; status.className = 'memo__status' + (cls ? ' ' + cls : ''); } };
        saveBtn.addEventListener('click', async () => {
          saveBtn.disabled = true;
          setStatus('保存中…', '');
          let res;
          try {
            res = await apiPost('adminSetCustomerNote', { key: c.key, note: ta.value }, { silent: true });
          } catch (_) {
            saveBtn.disabled = false;
            setStatus('保存に失敗しました', 'is-warn');
            return;
          }
          saveBtn.disabled = false;
          if (res && res.error === 'forbidden') { handleForbidden(); return; }
          if (!res || !res.ok) {
            setStatus('保存できませんでした', 'is-warn');
            return;
          }
          c.note = ta.value;      // 一覧は同一オブジェクト参照ゆえ note 即反映
          applySortAndRender();
          setStatus('保存しました', 'is-ok');
          toast('メモを保存しました');
        });
      }

      // ---- ログアウト / 再読み込み ----
      el('logoutBtn').addEventListener('click', async () => {
        await logout();
        location.href = '/reserve/admin/login/';
      });
      el('reloadBtn').addEventListener('click', loadCustomers);

      // ---- 起動 ----
      // サーバゲート済み（middleware が Cookie を検証して通した）前提。顧客台帳を読み込む。
      loadCustomers();
    </script>
  </body>
</html>
