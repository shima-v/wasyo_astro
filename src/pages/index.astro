<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.12 }
  );

  document.querySelectorAll('.feature-card, .menu-block, .section-heading')
    .forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = `${i * 0.07}s`;
      observer.observe(el);
    });
</script>

<style>
  /* ============================================================
     リセット・CSS変数
  ============================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ── カラーパレット ── */
    --c-bg:           #FDF2F5;   /* 淡いピンク（ロゴ背景色） */
    --c-surface:      #FFFFFF;   /* 白（カード・テーブル） */
    --c-ink:          #2C1F3A;   /* 濃紫がかった黒（本文） */
    --c-muted:        #7A6080;   /* 紫みグレー（補助テキスト） */
    --c-border:       #E2D0D8;   /* ピンクがかったボーダー */
    --c-purple:       #8B6080;   /* メインモーヴ（ベージュ+マゼンタ） */
    --c-purple-lt:    #B09AB0;   /* 中間モーヴ */
    --c-purple-dk:    #3E2B4A;   /* 濃モーヴ（ホバー・セカンダリ） */
    --c-purple-pale:  #C8A8C4;   /* 薄モーヴ（装飾・補助） */
    --c-reserve:      #8B6080;   /* 予約ボタン色 */
    --c-reserve-hv:   #3E2B4A;   /* 予約ボタンホバー */
    --c-accent:       #C9A84C;   /* ゴールド（アクセント・ドット） */
    --c-brown:        #4A3728;   /* ダークブラウン（区切り・フッター） */
    --c-brown-lt:     #8B6A50;   /* ミディアムブラウン（ルーバーライン） */
    --c-glow:         rgba(201,168,76,0.12); /* ゴールドグロー */

    /* ── タイポ ── */
    --f-serif: 'Noto Serif JP', 'YuMincho', 'Yu Mincho', serif;
    --f-sans:  'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif;

    /* ── レイアウト ── */
    --max-w: 900px;
    --gap-section: 5rem;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--f-serif);
    background: var(--c-bg);
    color: var(--c-ink);
    line-height: 2.0;
    font-size: 18px;
  }

  /* 和紙テクスチャ：40px間隔の薄い縦罫線 */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 39px,
        rgba(74,55,40,0.04) 39px,
        rgba(74,55,40,0.04) 40px
      );
  }

  /* 画面四隅のオリエンタルグロー */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse 60% 40% at 0% 0%,   rgba(201,168,76,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 100% 100%, rgba(93,66,102,0.06) 0%, transparent 70%);
  }

  /* ============================================================
     格子・ルーバー区切り
  ============================================================ */
  .divider-koshi {
    height: 20px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      to right,
      transparent,
      rgba(74,55,40,0.08) 20%,
      rgba(74,55,40,0.08) 80%,
      transparent
    );
  }

  .divider-koshi::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent 0px,
      transparent 11px,
      rgba(139,106,80,0.25) 11px,
      rgba(139,106,80,0.25) 12px
    );
  }

  .divider-koshi::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: -18px 0 0 var(--c-accent), 18px 0 0 var(--c-accent);
  }

  /* ============================================================
     ヘッダー
  ============================================================ */
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 200;
    background: rgba(250, 246, 240, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--c-brown-lt);
  }

  .header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.65rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .header-logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-main {
    font-family: var(--f-serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--c-purple);
    letter-spacing: 0.06em;
  }

  .logo-sub {
    font-size: 0.65rem;
    color: var(--c-muted);
    letter-spacing: 0.15em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
  }

  /* タップ44px以上確保・フィードバック付きナビリンク */
  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    padding: 0 0.9em;
    color: var(--c-ink);
    text-decoration: none;
    font-family: var(--f-serif);
    letter-spacing: 0.1em;
    border-radius: 8px;
    transition: color 0.2s, background-color 0.2s;
  }

  .nav-link:hover { color: var(--c-purple); background-color: rgba(139,96,128,0.07); }
  .nav-link:active { background-color: rgba(139,96,128,0.18); opacity: 0.8; }

  /* ============================================================
     予約ボタン 共通
  ============================================================ */
  .reserve-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    text-decoration: none;
    font-family: var(--f-serif);
    font-weight: 600;
    letter-spacing: 0.1em;
    border-radius: 24px;
    transition: background 0.25s, transform 0.15s, box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }

  /* 内側から光が広がるホバーエフェクト */
  .reserve-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 130%, rgba(201,168,76,0.45) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .reserve-btn:hover::before { opacity: 1; }

  .reserve-btn::after {
    content: '›';
    font-size: 1.1em;
    font-weight: 300;
    position: relative;
    z-index: 1;
  }

  .reserve-btn > * { position: relative; z-index: 1; }

  /* ヒーロー内 */
  .reserve-btn--hero {
    padding: 1em 2.5em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 1rem;
    border: 2px solid rgba(255,255,255,0.3);
    box-shadow: 0 4px 24px rgba(0,0,0,0.25);
  }

  .reserve-btn--hero:hover {
    background: var(--c-reserve-hv);
    transform: translateY(-2px);
  }

  /* バナー内 */
  .reserve-btn--banner {
    padding: 0.85em 2em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 0.95rem;
  }

  .reserve-btn--banner:hover { background: var(--c-reserve-hv); transform: translateY(-1px); }

  /* メニュー下（大） */
  .reserve-btn--large {
    padding: 1.1em 3em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 1.05rem;
    box-shadow: 0 4px 20px rgba(139, 96, 128, 0.3);
  }

  .reserve-btn--large:hover { background: var(--c-reserve-hv); transform: translateY(-2px); }

  /* フッター内 */
  .reserve-btn--footer {
    padding: 0.8em 2em;
    background: transparent;
    color: rgba(255,255,255,0.85) !important;
    border: 1px solid rgba(255,255,255,0.4);
    font-size: 0.85rem;
  }

  .reserve-btn--footer:hover {
    background: rgba(255,255,255,0.1);
    color: #fff !important;
  }

  /* ============================================================
     ヒーロー
  ============================================================ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;

    /*
      ▼ 画像を使う場合 ——
      public/images/hero.jpg を配置して下の2行を有効にしてください:
      background-image: url('/wasyo_astro/images/hero.jpg');
      background-size: cover;
      background-position: center;
    */
    background: linear-gradient(
      150deg,
      #1F1130 0%,
      #3D2654 35%,
      #5D4266 60%,
      #7A5C8A 100%
    );
  }

  /* 和柄：斜め格子 */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(45deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 12px),
      repeating-linear-gradient(-45deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 12px);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 8, 5, 0.3);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    padding: 6rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  .hero-title {
    font-family: var(--f-serif);
    font-size: clamp(2.4rem, 10vw, 4.5rem);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-shadow: 0 2px 30px rgba(0,0,0,0.4);
    line-height: 1.5;
  }

  .hero-title ruby { ruby-align: center; }

  .hero-title rt {
    font-family: var(--f-serif);
    font-size: 0.3em;
    font-weight: 300;
    letter-spacing: 0.35em;
    color: rgba(255,255,255,0.65);
  }

  .hero-violane {
    font-family: var(--f-serif);
    font-size: clamp(1rem, 3vw, 1.3rem);
    font-weight: 300;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.75);
    margin-top: -0.3rem;
  }

  /* 巨大縦書き透過テキスト（左右に見切れる大胆デザイン） */
  .hero-bg-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    padding: 0;
  }

  .hero-bg-text-line {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-family: var(--f-serif);
    font-size: clamp(4rem, 18vw, 14rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.055);
    letter-spacing: 0.15em;
    white-space: nowrap;
    line-height: 1;
  }

  /* 左端の文字を少し画面外へはみ出させる */
  .hero-bg-text-line:nth-child(1) { transform: translateX(-18%); }
  /* 右端の文字も少し画面外へ */
  .hero-bg-text-line:nth-child(2) { transform: translateX(18%); }

  /* スクロール誘導 */
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.5);
  }

  .hero-scroll-label {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
  }

  .hero-scroll-line {
    display: block;
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollline 1.8s ease-in-out infinite;
  }

  @keyframes scrollline {
    0%   { opacity: 1; transform: scaleY(1) translateY(0); }
    100% { opacity: 0; transform: scaleY(0.5) translateY(50%); }
  }

  /* ============================================================
     予約バナー帯
  ============================================================ */
  .reserve-banner {
    background: var(--c-purple);
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .reserve-banner-text {
    color: rgba(255,255,255,0.85);
    font-size: 0.88rem;
    letter-spacing: 0.1em;
    font-family: var(--f-serif);
  }

  /* ============================================================
     セクション共通
  ============================================================ */
  .section-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--gap-section) 1.5rem;
  }

  .section-heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-heading-en {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    color: var(--c-purple-pale);
    margin-bottom: 0.6rem;
  }

  .section-heading-en::before,
  .section-heading-en::after {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-accent);
    flex-shrink: 0;
  }

  .section-heading-ja {
    font-family: var(--f-serif);
    font-size: clamp(1.4rem, 4vw, 1.75rem);
    font-weight: 600;
    color: var(--c-ink);
    letter-spacing: 0.12em;
    position: relative;
    display: inline-block;
    padding-bottom: 0.8rem;
  }

  .section-heading-ja::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 3.5rem;
    height: 2px;
    background: linear-gradient(to right, var(--c-purple), var(--c-accent));
  }

  /* ============================================================
     スクロールアニメーション
  ============================================================ */
  .feature-card,
  .menu-block,
  .section-heading {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .feature-card.is-visible,
  .menu-block.is-visible,
  .section-heading.is-visible {
    opacity: 1;
    transform: none;
  }

  /* ============================================================
     コンセプト
  ============================================================ */
  .concept {
    background: var(--c-surface);
    border-top: double 5px var(--c-purple);
    border-bottom: double 5px var(--c-purple);
    position: relative;
    overflow: hidden;
  }

  /* ソフトグロー */
  .concept::before {
    content: '';
    position: absolute;
    top: -80px; left: -80px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, var(--c-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .concept-text {
    text-align: center;
    font-family: var(--f-serif);
    font-size: clamp(1rem, 2.5vw, 1.1rem);
    line-height: 2.3;
    color: var(--c-muted);
    letter-spacing: 0.05em;
    max-width: 600px;
    margin: 0 auto;
  }

  .concept-text + .concept-text {
    margin-top: 1.8rem;
  }

  .concept-img {
    display: block;
    width: 100%;
    max-width: 720px;
    margin: 2.5rem auto 0;
    border-radius: 12px;
    box-shadow: 0 6px 30px rgba(0,0,0,0.12);
    object-fit: cover;
    aspect-ratio: 16/9;
  }

  /* ============================================================
     メニュー
  ============================================================ */
  .menu {
    background: var(--c-bg);
    position: relative;
    overflow: hidden;
  }

  .menu::after {
    content: '';
    position: absolute;
    bottom: -60px; right: -60px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(93,66,102,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .menu-block {
    margin-bottom: 3rem;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-top: 3px solid var(--c-purple);
    border-radius: 0 0 12px 12px;
    overflow: hidden;
  }

  .menu-block--set {
    border-top-color: var(--c-purple-dk);
  }

  .menu-block-header {
    padding: 1.1rem 1.4rem 0.8rem;
    background: #F7EEF2;
    border-bottom: 1px solid var(--c-border);
  }

  .menu-block-title {
    font-family: var(--f-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-purple);
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .menu-block--set .menu-block-title { color: var(--c-purple-dk); }

  .menu-block-title-note {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--c-muted);
    letter-spacing: 0.03em;
  }

  .set-badge {
    display: inline-block;
    padding: 0.1em 0.55em;
    background: var(--c-purple-dk);
    color: #fff;
    font-size: 0.65rem;
    font-family: var(--f-sans);
    font-weight: 600;
    letter-spacing: 0.1em;
    border-radius: 2px;
    vertical-align: middle;
  }

  .menu-block-desc {
    margin-top: 0.3rem;
    font-size: 0.9rem;
    color: var(--c-muted);
    letter-spacing: 0.04em;
  }

  .menu-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .menu-table th,
  .menu-table td {
    padding: 0.85em 1.4em;
    text-align: left;
    border-bottom: 1px solid var(--c-border);
  }

  .menu-table thead tr {
    background: var(--c-purple);
    color: #fff;
    font-family: var(--f-serif);
    font-weight: 400;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .menu-block--set .menu-table thead tr {
    background: var(--c-purple-dk);
  }

  .menu-table tbody tr:last-child td { border-bottom: none; }
  .menu-table tbody tr:nth-child(even) { background: #FAF0F5; }
  .menu-table tbody tr:hover { background: #F0E0EC; }

  .menu-table td:first-child {
    color: var(--c-ink);
    font-weight: 400;
  }

  .menu-table td:last-child {
    font-family: var(--f-serif);
    font-size: 1rem;
    color: var(--c-purple-dk);
    font-weight: 600;
    white-space: nowrap;
    text-align: right;
    padding-right: 1.6em;
  }

  .menu-reserve {
    text-align: center;
    padding: 0.5rem 0 1rem;
  }

  /* ============================================================
     アクセス
  ============================================================ -->
  .access {
    background: var(--c-surface);
    border-top: double 5px var(--c-purple);
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .access-info {
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 0.2rem 1.4rem;
  }

  .access-row {
    display: grid;
    grid-template-columns: 5.5em 1fr;
    gap: 0.4rem 0.8rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--c-border);
    font-size: 1rem;
  }

  .access-row:first-child { border-top: 1px solid var(--c-border); }

  /* 営業時間：テーブルを全幅で表示 */
  .access-row--full {
    grid-template-columns: 1fr;
  }

  .access-row--full dt {
    margin-bottom: 0.5rem;
  }

  .access-row dt {
    font-family: var(--f-serif);
    color: var(--c-purple);
    font-weight: 600;
    letter-spacing: 0.05em;
    white-space: nowrap;
    padding-top: 0.1em;
  }

  .access-row dd {
    color: var(--c-ink);
    line-height: 1.8;
  }

  .access-row dd small {
    font-size: 0.8em;
    color: var(--c-muted);
  }

  .access-row dd a {
    color: var(--c-purple-dk);
    text-decoration: none;
    font-weight: 600;
  }

  .access-map {
    border: 2px solid var(--c-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 20px rgba(0,0,0,0.1);
  }

  .hours-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1rem;
    margin: 0.2rem 0;
  }

  .hours-table th,
  .hours-table td {
    padding: 0.75em 1.2em;
    border: 1px solid var(--c-border);
    text-align: center;
    line-height: 1.5;
  }

  .hours-table thead tr {
    background: var(--c-purple);
    color: #fff;
    font-family: var(--f-serif);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
  }

  .hours-table tbody tr:nth-child(odd) { background: var(--c-surface); }
  .hours-table tbody tr:nth-child(even) { background: #FAF0F5; }

  .hours-table .closed-row td {
    color: var(--c-muted);
    font-style: italic;
  }

  .access-transport {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .access-transport li {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    font-size: 1rem;
    line-height: 1.6;
  }

  .access-transport .transport-icon {
    font-size: 1.2em;
    flex-shrink: 0;
  }

  /* ============================================================
     フッター
  ============================================================ */
  .site-footer {
    background: linear-gradient(135deg, #2A1A0E 0%, #1A0F24 100%);
    color: rgba(255,255,255,0.55);
    text-align: center;
    padding: 2.5rem 1.5rem;
    border-top: 3px solid var(--c-accent);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .footer-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .footer-logo-main {
    font-family: var(--f-serif);
    font-size: 1.5rem;
    color: rgba(255,255,255,0.9);
    letter-spacing: 0.2em;
  }

  .footer-logo-sub {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.45);
  }

  .footer-copy {
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  /* ============================================================
     施術の特徴
  ============================================================ */
  .features {
    background: var(--c-surface);
    border-top: double 5px var(--c-purple);
    border-bottom: double 5px var(--c-purple);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-top: 3px solid var(--c-purple);
    border-radius: 0 0 12px 12px;
    padding: 1.4rem 1.5rem;
  }

  .feature-card-title {
    font-family: var(--f-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--c-purple);
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }

  .feature-card-desc {
    font-size: 0.9rem;
    color: var(--c-muted);
    line-height: 1.9;
    letter-spacing: 0.04em;
  }

  /* ============================================================
     お客様の声
  ============================================================ */
  .review-block {
    padding: 1rem 1.4rem 1.2rem;
    background: #FAF0F5;
    border-top: 1px solid var(--c-border);
  }

  .review-quote {
    font-family: var(--f-serif);
    font-size: 0.88rem;
    color: var(--c-muted);
    line-height: 1.9;
    letter-spacing: 0.04em;
    border-left: 3px solid var(--c-purple-pale);
    padding-left: 0.8em;
    margin: 0.6rem 0 0.2rem;
  }

  .review-quote:first-child { margin-top: 0; }

  .review-author {
    font-size: 0.78rem;
    color: var(--c-purple-lt);
    text-align: right;
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }

  /* ============================================================
     メニュー3列（オイル・フット・ハンド）
  ============================================================ */
  .menu-trio {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .menu-trio .menu-block {
    margin-bottom: 0;
  }

  /* ============================================================
     アクセス：看板写真
  ============================================================ */
  .access-signboard {
    text-align: center;
    margin-bottom: 2rem;
  }

  .signboard-wrap {
    display: inline-block;
    position: relative;
  }

  .signboard-img {
    max-width: 320px;
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    display: block;
  }

  /* 強調バッジ：写真の下端に重なる */
  .signboard-badge {
    position: absolute;
    bottom: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--c-purple);
    color: #fff;
    font-family: var(--f-serif);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    padding: 0.45em 1.4em;
    border-radius: 0 0 10px 10px;
    white-space: nowrap;
    box-shadow: 0 3px 12px rgba(93,66,102,0.35);
  }

  /* ============================================================
     こんなお客様に
  ============================================================ */
  .for-whom {
    background: var(--c-surface);
    border-top: double 5px var(--c-purple);
    border-bottom: double 5px var(--c-purple);
  }

