  </body>
</html>

<style>
  /* ============================================================
     リセット・CSS変数
  ============================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ── カラーパレット ── */
    --c-bg:           #FDF2F5;   /* 淡いピンク（ロゴ背景色） */
    --c-surface:      #FFFFFF;   /* 白（カード・テーブル） */
    --c-ink:          #2C1F3A;   /* 濃紫がかった黒（本文） */
    --c-muted:        #7A6080;   /* 紫みグレー（補助テキスト） */
    --c-border:       #E2D0D8;   /* ピンクがかったボーダー */
    --c-purple:       #8B6080;   /* メインモーヴ（ベージュ+マゼンタ） */
    --c-purple-lt:    #B09AB0;   /* 中間モーヴ */
    --c-purple-dk:    #6B4860;   /* 濃いモーヴ（ホバー・セカンダリ） */
    --c-purple-pale:  #C8A8C4;   /* 薄モーヴ（装飾・補助） */
    --c-reserve:      #8B6080;   /* 予約ボタン色 */
    --c-reserve-hv:   #6B4860;   /* 予約ボタンホバー */
    --c-accent:       #F7E58E;   /* イエロー（アクセント・ドット） */

    /* ── タイポ ── */
    --f-serif: 'Noto Serif JP', 'YuMincho', 'Yu Mincho', serif;
    --f-sans:  'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif;

    /* ── レイアウト ── */
    --max-w: 900px;
    --gap-section: 5rem;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--f-serif);
    background: var(--c-bg);
    color: var(--c-ink);
    line-height: 2.0;
    font-size: 18px;
  }

  /* ============================================================
     ヘッダー
  ============================================================ */
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 200;
    background: rgba(255, 255, 255, 0.93);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.65rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .header-logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-main {
    font-family: var(--f-serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--c-purple);
    letter-spacing: 0.06em;
  }

  .logo-sub {
    font-size: 0.65rem;
    color: var(--c-muted);
    letter-spacing: 0.15em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.85rem;
  }

  .header-nav a {
    color: var(--c-ink);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .header-nav a:hover { color: var(--c-purple); }

  .nav-reserve {
    padding: 0.45em 1.1em;
    background: var(--c-reserve);
    color: #fff !important;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    transition: background 0.2s !important;
  }

  .nav-reserve:hover { background: var(--c-reserve-hv) !important; }

  /* ============================================================
     予約ボタン 共通
  ============================================================ */
  .reserve-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    text-decoration: none;
    font-family: var(--f-serif);
    font-weight: 600;
    letter-spacing: 0.1em;
    border-radius: 24px;
    transition: background 0.25s, transform 0.15s;
  }

  .reserve-btn::after {
    content: '›';
    font-size: 1.1em;
    font-weight: 300;
  }

  /* ヒーロー内 */
  .reserve-btn--hero {
    padding: 1em 2.5em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 1rem;
    border: 2px solid rgba(255,255,255,0.3);
    box-shadow: 0 4px 24px rgba(0,0,0,0.25);
  }

  .reserve-btn--hero:hover {
    background: var(--c-reserve-hv);
    transform: translateY(-2px);
  }

  /* バナー内 */
  .reserve-btn--banner {
    padding: 0.85em 2em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 0.95rem;
  }

  .reserve-btn--banner:hover { background: var(--c-reserve-hv); transform: translateY(-1px); }

  /* メニュー下（大） */
  .reserve-btn--large {
    padding: 1.1em 3em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 1.05rem;
    box-shadow: 0 4px 20px rgba(139, 96, 128, 0.3);
  }

  .reserve-btn--large:hover { background: var(--c-reserve-hv); transform: translateY(-2px); }

  /* フッター内 */
  .reserve-btn--footer {
    padding: 0.8em 2em;
    background: transparent;
    color: rgba(255,255,255,0.85) !important;
    border: 1px solid rgba(255,255,255,0.4);
    font-size: 0.85rem;
  }

  .reserve-btn--footer:hover {
    background: rgba(255,255,255,0.1);
    color: #fff !important;
  }

  /* ============================================================
     ヒーロー
  ============================================================ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;

    /*
