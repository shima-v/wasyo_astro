---
const base = import.meta.env.BASE_URL;
const salonName = "リラクゼーションサロン 和笑";
const salonNameReading = "わしょう";
const reserveUrl = "https://reserva.be/wasyou258";
const tel = "000-0000-0000"; // ← 実際の電話番号に変更
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="心と体を整える、至福のひとときを。もみほぐし・足つぼのリラクゼーションサロン 和笑（わしょう）。ネット予約受付中。" />
    <title>{salonName}（{salonNameReading}）| リラクゼーションサロン</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Noto+Sans+JP:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- ============================================================
         ヘッダー
    ============================================================ -->
    <header class="site-header">
      <div class="header-inner">
        <p class="header-logo">
          <span class="logo-main">和笑</span>
          <span class="logo-sub">リラクゼーションサロン</span>
        </p>
        <nav class="header-nav">
          <a href="#menu">メニュー</a>
          <a href="#access">アクセス</a>
          <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="nav-reserve">ネット予約</a>
        </nav>
      </div>
    </header>

    <!-- ============================================================
         ヒーロー（看板）
         画像を使う場合:
           public/images/hero.jpg を配置し、
           .hero の background-image コメントを外してください
    ============================================================ -->
    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <p class="hero-reading">{salonNameReading}</p>
        <h1 class="hero-title">和笑</h1>
        <p class="hero-tagline">心と体を整える、至福のひとときを。</p>
        <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--hero">
          ネット予約はこちら
        </a>
      </div>
      <div class="hero-scroll" aria-hidden="true">
        <span class="hero-scroll-line"></span>
        <span class="hero-scroll-label">SCROLL</span>
      </div>
    </section>

    <!-- ============================================================
         予約バナー（ヒーロー直下の帯）
    ============================================================ -->
    <div class="reserve-banner">
      <p class="reserve-banner-text">ご予約はかんたん・24時間いつでも</p>
      <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--banner">
        ネット予約はこちら
      </a>
    </div>

    <!-- ============================================================
         コンセプト
    ============================================================ -->
    <section class="concept" id="concept">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">CONCEPT</span>
          <h2 class="section-heading-ja">私たちの想い</h2>
        </div>
        <p class="concept-text">
          日々の疲れ、体のこり、心のざわめき——<br />
          「和笑」は、そんなあなたのためのサロンです。<br /><br />
          心と体を整える、至福のひとときを。<br />
          ふかぶかと息をついて、また明日へ歩き出す力を。
        </p>
        <!--
          コンセプト画像を使う場合:
          public/images/concept.jpg を配置してコメントを外す
        <img
          src={`${base}images/concept.jpg`}
          alt="サロンの内観"
          class="concept-img"
          loading="lazy"
          width="800"
          height="450"
        />
        -->
      </div>
    </section>

    <!-- ============================================================
         メニュー表
    ============================================================ -->
    <section class="menu" id="menu">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">MENU &amp; PRICE</span>
          <h2 class="section-heading-ja">メニュー・料金</h2>
        </div>

        <!-- もみほぐし -->
        <div class="menu-block">
          <div class="menu-block-header">
            <h3 class="menu-block-title">もみほぐし</h3>
            <p class="menu-block-desc">全身のこりをほぐす、基本のボディケア。</p>
          </div>
          <table class="menu-table">
            <thead>
              <tr><th>時間</th><th>料金（税込）</th></tr>
            </thead>
            <tbody>
              <tr><td>15分</td><td>¥1,000</td></tr>
              <tr><td>30分</td><td>¥2,000</td></tr>
              <tr><td>45分</td><td>¥3,000</td></tr>
              <tr><td>60分</td><td>¥4,000</td></tr>
            </tbody>
          </table>
        </div>

        <!-- 足つぼ -->
        <div class="menu-block">
          <div class="menu-block-header">
            <h3 class="menu-block-title">足つぼ<span class="menu-block-title-note">（足裏〜膝下）</span></h3>
            <p class="menu-block-desc">足裏から膝下をしっかりほぐし、全身をリセット。</p>
          </div>
          <table class="menu-table">
            <thead>
              <tr><th>時間</th><th>料金（税込）</th></tr>
            </thead>
            <tbody>
              <tr><td>20分</td><td>¥2,000</td></tr>
              <tr><td>30分</td><td>¥3,000</td></tr>
              <tr><td>45分</td><td>¥4,500</td></tr>
            </tbody>
          </table>
        </div>

        <!-- セットメニュー -->
        <div class="menu-block menu-block--set">
          <div class="menu-block-header">
            <h3 class="menu-block-title">
              <span class="set-badge">SET</span>
              セットメニュー
              <span class="menu-block-title-note">（もみほぐし＋足つぼ）</span>
            </h3>
            <p class="menu-block-desc">体と足、両方まとめてケアしたい方におすすめ。</p>
          </div>
          <table class="menu-table">
            <thead>
              <tr><th>時間</th><th>料金（税込）</th></tr>
            </thead>
            <tbody>
              <tr><td>45分</td><td>¥3,500</td></tr>
              <tr><td>60分</td><td>¥4,500</td></tr>
              <tr><td>75分</td><td>¥5,500</td></tr>
              <tr><td>90分</td><td>¥6,500</td></tr>
            </tbody>
          </table>
        </div>

        <!-- メニュー下の予約ボタン -->
        <div class="menu-reserve">
          <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--large">
            ネット予約はこちら
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         アクセス
    ============================================================ -->
    <section class="access" id="access">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">ACCESS</span>
          <h2 class="section-heading-ja">アクセス・営業情報</h2>
        </div>
        <div class="access-grid">
          <dl class="access-info">
            <div class="access-row">
              <dt>住所</dt>
              <dd>〒000-0000<br />○○県○○市○○町0-0-0</dd><!-- ← 変更 -->
            </div>
            <div class="access-row">
              <dt>電話</dt>
              <dd><a href={`tel:${tel}`}>{tel}</a></dd>
            </div>
            <div class="access-row">
              <dt>営業時間</dt>
              <dd>10:00 〜 21:00<br /><small>（最終受付 20:00）</small></dd><!-- ← 変更 -->
            </div>
            <div class="access-row">
              <dt>定休日</dt>
              <dd>不定休</dd><!-- ← 変更 -->
            </div>
            <div class="access-row">
              <dt>アクセス</dt>
              <dd>○○駅 徒歩○分</dd><!-- ← 変更 -->
            </div>
          </dl>
          <!-- Googleマップ: src の URL をご自身のものに変更してください -->
          <div class="access-map">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3240.827853475255!2d139.76703!3d35.68123!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzXCsDQwJzUyLjQiTiAxMznCsDQ2JzAxLjMiRQ!5e0!3m2!1sja!2sjp!4v0000000000"
              width="100%"
              height="320"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="和笑の地図"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         フッター
    ============================================================ -->
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-logo">
          <span class="footer-logo-main">和笑</span>
          <span class="footer-logo-sub">リラクゼーションサロン</span>
        </p>
        <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--footer">
          ネット予約はこちら
        </a>
        <p class="footer-copy">&copy; {new Date().getFullYear()} リラクゼーションサロン 和笑. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ============================================================
     リセット・CSS変数
  ============================================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* ── カラーパレット ── */
    --c-bg:         #f7f2eb;   /* 和紙ベージュ */
    --c-surface:    #fdfaf4;   /* 白磁 */
    --c-ink:        #2a1f14;   /* 墨茶 */
    --c-muted:      #7a6a58;   /* 薄墨 */
    --c-border:     #d9ccb5;   /* 枯草 */
    --c-green:      #3a5c38;   /* 深緑（メインカラー） */
    --c-green-lt:   #557850;   /* 若緑 */
    --c-brown:      #5c3d1e;   /* 濃茶（アクセント） */
    --c-brown-lt:   #8c6040;   /* 中茶 */
    --c-reserve:    #4a7c45;   /* 予約ボタン緑 */
    --c-reserve-hv: #3a6235;

    /* ── タイポ ── */
    --f-serif: 'Noto Serif JP', 'YuMincho', 'Yu Mincho', serif;
    --f-sans:  'Noto Sans JP', 'Hiragino Kaku Gothic ProN', sans-serif;

    /* ── レイアウト ── */
    --max-w: 900px;
    --gap-section: 5rem;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--f-sans);
    background: var(--c-bg);
    color: var(--c-ink);
    line-height: 1.8;
    font-size: 16px;
  }

  /* ============================================================
     ヘッダー
  ============================================================ */
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 200;
    background: rgba(253, 250, 244, 0.93);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.65rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .header-logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .logo-main {
    font-family: var(--f-serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--c-green);
    letter-spacing: 0.1em;
  }

  .logo-sub {
    font-size: 0.65rem;
    color: var(--c-muted);
    letter-spacing: 0.15em;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.85rem;
  }

  .header-nav a {
    color: var(--c-ink);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .header-nav a:hover { color: var(--c-green); }

  .nav-reserve {
    padding: 0.45em 1.1em;
    background: var(--c-reserve);
    color: #fff !important;
    border-radius: 2px;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    transition: background 0.2s !important;
  }

  .nav-reserve:hover { background: var(--c-reserve-hv) !important; }

  /* ============================================================
     予約ボタン 共通
  ============================================================ */
  .reserve-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    text-decoration: none;
    font-family: var(--f-serif);
    font-weight: 600;
    letter-spacing: 0.1em;
    border-radius: 2px;
    transition: background 0.25s, transform 0.15s;
  }

  .reserve-btn::after {
    content: '›';
    font-size: 1.1em;
    font-weight: 300;
  }

  /* ヒーロー内 */
  .reserve-btn--hero {
    padding: 1em 2.5em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 1rem;
    border: 2px solid rgba(255,255,255,0.3);
    box-shadow: 0 4px 24px rgba(0,0,0,0.25);
  }

  .reserve-btn--hero:hover {
    background: var(--c-reserve-hv);
    transform: translateY(-2px);
  }

  /* バナー内 */
  .reserve-btn--banner {
    padding: 0.85em 2em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 0.95rem;
  }

  .reserve-btn--banner:hover { background: var(--c-reserve-hv); transform: translateY(-1px); }

  /* メニュー下（大） */
  .reserve-btn--large {
    padding: 1.1em 3em;
    background: var(--c-reserve);
    color: #fff;
    font-size: 1.05rem;
    box-shadow: 0 4px 20px rgba(58, 92, 56, 0.3);
  }

  .reserve-btn--large:hover { background: var(--c-reserve-hv); transform: translateY(-2px); }

  /* フッター内 */
  .reserve-btn--footer {
    padding: 0.8em 2em;
    background: transparent;
    color: rgba(255,255,255,0.85) !important;
    border: 1px solid rgba(255,255,255,0.4);
    font-size: 0.85rem;
  }

  .reserve-btn--footer:hover {
    background: rgba(255,255,255,0.1);
    color: #fff !important;
  }

  /* ============================================================
     ヒーロー
  ============================================================ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;

    /*
      ▼ 画像を使う場合 ——
      public/images/hero.jpg を配置して下の2行を有効にしてください:
      background-image: url('/wasyo_astro/images/hero.jpg');
      background-size: cover;
      background-position: center;
    */
    background: linear-gradient(
      150deg,
      #1c3a1a 0%,
      #2d5028 35%,
      #3a5c38 60%,
      #5c3d1e 100%
    );
  }

  /* 和柄：斜め格子 */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(45deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 12px),
      repeating-linear-gradient(-45deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 12px);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 8, 5, 0.3);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    padding: 6rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  .hero-reading {
    font-family: var(--f-serif);
    font-size: 0.85rem;
    letter-spacing: 0.5em;
    color: rgba(255,255,255,0.7);
  }

  .hero-title {
    font-family: var(--f-serif);
    font-size: clamp(3.5rem, 14vw, 6rem);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-shadow: 0 2px 30px rgba(0,0,0,0.4);
    line-height: 1;
  }

  .hero-tagline {
    font-family: var(--f-serif);
    font-size: clamp(0.9rem, 2.5vw, 1.1rem);
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.88);
    padding: 0.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.3);
    border-bottom: 1px solid rgba(255,255,255,0.3);
  }

  /* スクロール誘導 */
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.5);
  }

  .hero-scroll-label {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
  }

  .hero-scroll-line {
    display: block;
    width: 1px;
    height: 2.5rem;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollline 1.8s ease-in-out infinite;
  }

  @keyframes scrollline {
    0%   { opacity: 1; transform: scaleY(1) translateY(0); }
    100% { opacity: 0; transform: scaleY(0.5) translateY(50%); }
  }

  /* ============================================================
     予約バナー帯
  ============================================================ */
  .reserve-banner {
    background: var(--c-brown);
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .reserve-banner-text {
    color: rgba(255,255,255,0.85);
    font-size: 0.88rem;
    letter-spacing: 0.1em;
    font-family: var(--f-serif);
  }

  /* ============================================================
     セクション共通
  ============================================================ */
  .section-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--gap-section) 1.5rem;
  }

  .section-heading {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-heading-en {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    color: var(--c-brown-lt);
    margin-bottom: 0.6rem;
  }

  .section-heading-ja {
    font-family: var(--f-serif);
    font-size: clamp(1.4rem, 4vw, 1.75rem);
    font-weight: 600;
    color: var(--c-ink);
    letter-spacing: 0.12em;
    position: relative;
    display: inline-block;
    padding-bottom: 0.8rem;
  }

  .section-heading-ja::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2.5rem;
    height: 2px;
    background: linear-gradient(to right, var(--c-green), var(--c-brown-lt));
  }

  /* ============================================================
     コンセプト
  ============================================================ */
  .concept {
    background: var(--c-surface);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
  }

  .concept-text {
    text-align: center;
    font-family: var(--f-serif);
    font-size: clamp(1rem, 2.5vw, 1.1rem);
    line-height: 2.3;
    color: var(--c-muted);
    letter-spacing: 0.05em;
    max-width: 600px;
    margin: 0 auto;
  }

  .concept-img {
    display: block;
    width: 100%;
    max-width: 720px;
    margin: 2.5rem auto 0;
    border-radius: 2px;
    box-shadow: 0 6px 30px rgba(0,0,0,0.12);
    object-fit: cover;
    aspect-ratio: 16/9;
  }

  /* ============================================================
     メニュー
  ============================================================ */
  .menu { background: var(--c-bg); }

  .menu-block {
    margin-bottom: 3rem;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-top: 3px solid var(--c-green);
    border-radius: 0 0 2px 2px;
    overflow: hidden;
  }

  .menu-block--set {
    border-top-color: var(--c-brown);
  }

  .menu-block-header {
    padding: 1.1rem 1.4rem 0.8rem;
    background: #f3ede3;
    border-bottom: 1px solid var(--c-border);
  }

  .menu-block-title {
    font-family: var(--f-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-green);
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .menu-block--set .menu-block-title { color: var(--c-brown); }

  .menu-block-title-note {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--c-muted);
    letter-spacing: 0.03em;
  }

  .set-badge {
    display: inline-block;
    padding: 0.1em 0.55em;
    background: var(--c-brown);
    color: #fff;
    font-size: 0.65rem;
    font-family: var(--f-sans);
    font-weight: 600;
    letter-spacing: 0.1em;
    border-radius: 2px;
    vertical-align: middle;
  }

  .menu-block-desc {
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: var(--c-muted);
    letter-spacing: 0.04em;
  }

  .menu-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .menu-table th,
  .menu-table td {
    padding: 0.85em 1.4em;
    text-align: left;
    border-bottom: 1px solid var(--c-border);
  }

  .menu-table thead tr {
