---
const _base = import.meta.env.BASE_URL;
const base = _base.endsWith('/') ? _base : _base + '/';
const salonName = "サロン和笑〜Violane〜";
const salonNameReading = "わしょう";
const reserveUrl = "https://reserva.be/wasyou258";
const tel = "080-6368-0753";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href={`${base}favicon.jpg`} />
    <link rel="apple-touch-icon" href={`${base}favicon.jpg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="富山県高岡市野村にあるリラクゼーションサロン和笑〜Violane〜。もみほぐしやオイルケア・フットケア・ハンドケアで至福のひとときを。女性が安心して通える和モダンな癒やし空間です。駐車場完備。" />
    <title>高岡市のマッサージならサロン和笑〜Violane〜 | 高岡駅車で9分</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HealthAndBeautyBusiness",
      "name": "サロン和笑〜Violane〜",
      "image": "https://shima-v.github.io/wasyo_astro/images/logo.jpg",
      "url": "https://shima-v.github.io/wasyo_astro/",
      "telephone": "080-6368-0753",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "野村1180-1",
        "addressLocality": "高岡市",
        "addressRegion": "富山県",
        "addressCountry": "JP"
      },
      "openingHoursSpecification": [
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"10:30","closes":"14:30"},
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"16:30","closes":"21:00"},
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday"],"opens":"10:30","closes":"14:30"},
        {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday"],"opens":"16:30","closes":"18:30"}
      ],
      "priceRange": "¥1,000〜¥6,500"
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Noto+Sans+JP:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- ============================================================
         ヘッダー
    ============================================================ -->
    <header class="site-header">
      <div class="header-inner">
        <p class="header-logo">
          <span class="logo-main">サロン和笑</span>
          <span class="logo-sub">〜Violane〜</span>
        </p>
        <nav class="header-nav">
          <a href="#menu">メニュー</a>
          <a href="#access">アクセス</a>
          <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="nav-reserve">ネット予約</a>
        </nav>
      </div>
    </header>

    <!-- ============================================================
         ヒーロー（看板）
         画像を使う場合:
           public/images/hero.jpg を配置し、
           .hero の background-image コメントを外してください
    ============================================================ -->
    <section class="hero">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <h1 class="hero-title">サロン<ruby>和笑<rt>わしょう</rt></ruby></h1>
        <p class="hero-violane">〜Violane〜</p>
        <p class="hero-tagline">心と体を整える、至福のひとときを。</p>
        <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--hero">
          ネット予約はこちら
        </a>
      </div>
      <div class="hero-scroll" aria-hidden="true">
        <span class="hero-scroll-line"></span>
        <span class="hero-scroll-label">SCROLL</span>
      </div>
    </section>

    <!-- ============================================================
         予約バナー（ヒーロー直下の帯）
    ============================================================ -->
    <div class="reserve-banner">
      <p class="reserve-banner-text">ご予約はかんたん・24時間いつでも</p>
      <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--banner">
        ネット予約はこちら
      </a>
    </div>

    <!-- ============================================================
         コンセプト
    ============================================================ -->
    <section class="concept" id="concept">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">CONCEPT</span>
          <h2 class="section-heading-ja">私の想い</h2>
        </div>
        <p class="concept-text">
          サロン和笑〜Violane〜は、女性のお客様に安心してお過ごしいただける、基本的に女性専用のサロンです。男性のお客様は、お知り合いの方からのご紹介に限り承っております。
        </p>
        <p class="concept-text">
          「ここに来てよかった」と毎回思っていただけるよう、心を込めた施術と、くつろげる空間づくりを大切にしています。
        </p>
        <img
          src={`${base}images/naisou.jpg`}
          alt="サロン和笑〜Violane〜の内装"
          class="concept-img"
          loading="lazy"
          width="800"
          height="450"
        />
      </div>
    </section>

    <!-- ============================================================
         施術の特徴
    ============================================================ -->
    <section class="features" id="features">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">FEATURES</span>
          <h2 class="section-heading-ja">施術の特徴</h2>
        </div>
        <div class="features-grid">
          <div class="feature-card">
            <h3 class="feature-card-title">もみほぐし</h3>
            <p class="feature-card-desc">全身の筋肉をほぐし、血行を促進。肩こり・腰痛・疲労回復に。圧の強弱はお好みに合わせます。</p>
          </div>
          <div class="feature-card">
            <h3 class="feature-card-title">オイルケア</h3>
            <p class="feature-card-desc">厳選アロマオイルを使ったトリートメント。心身の緊張をほぐし、肌にうるおいを。</p>
          </div>
          <div class="feature-card">
            <h3 class="feature-card-title">フットケア</h3>
            <p class="feature-card-desc">足裏から膝下を丁寧にほぐし、むくみや疲れをリセット。立ち仕事や歩き疲れの方に。</p>
          </div>
          <div class="feature-card">
            <h3 class="feature-card-title">ハンドケア</h3>
            <p class="feature-card-desc">手指・手首・前腕を丁寧にケア。パソコン作業や家事で疲れた手に癒やしを。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         メニュー表
    ============================================================ -->
    <section class="menu" id="menu">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">MENU &amp; PRICE</span>
          <h2 class="section-heading-ja">メニュー・料金</h2>
        </div>

        <!-- セットメニュー（1番人気） -->
        <div class="menu-block menu-block--set">
          <div class="menu-block-header">
            <h3 class="menu-block-title">
              <span class="set-badge">1番人気</span>
              セットメニュー
              <span class="menu-block-title-note">（もみほぐし＋オイルケアまたはフットケアまたはハンドケア）</span>
            </h3>
            <p class="menu-block-desc">もみほぐしとオイルケア・フットケア・ハンドケアを組み合わせた特別コース。</p>
          </div>
          <table class="menu-table">
            <thead>
              <tr><th>時間</th><th>料金（税込）</th></tr>
            </thead>
            <tbody>
              <tr><td>45分</td><td>¥3,500</td></tr>
              <tr><td>60分</td><td>¥4,500</td></tr>
              <tr><td>75分</td><td>¥5,500</td></tr>
              <tr><td>90分</td><td>¥6,500</td></tr>
            </tbody>
          </table>
          <div class="review-block">
            <blockquote class="review-quote">「肩と足が同時にほぐれて、一石二鳥！毎月来るのが楽しみです。」</blockquote>
            <p class="review-author">50代・女性</p>
            <blockquote class="review-quote">「長時間のデスクワーク後に来ると、別人のように体が楽になります。」</blockquote>
            <p class="review-author">40代・女性</p>
          </div>
        </div>

        <!-- もみほぐし -->
        <div class="menu-block">
          <div class="menu-block-header">
            <h3 class="menu-block-title">もみほぐし</h3>
            <p class="menu-block-desc">全身の筋肉をほぐし、血行を促進。肩こり・腰痛・疲労回復に。</p>
          </div>
          <table class="menu-table">
            <thead>
              <tr><th>時間</th><th>料金（税込）</th></tr>
            </thead>
            <tbody>
              <tr><td>15分</td><td>¥1,000</td></tr>
              <tr><td>30分</td><td>¥2,000</td></tr>
              <tr><td>45分</td><td>¥3,000</td></tr>
              <tr><td>60分</td><td>¥4,000</td></tr>
            </tbody>
          </table>
          <div class="review-block">
            <blockquote class="review-quote">「ひどい肩こりで来ましたが、施術後はすっきり。よく眠れるようになりました。」</blockquote>
            <p class="review-author">60代・女性</p>
            <blockquote class="review-quote">「力加減を調整してもらえて、痛気持ちいい絶妙な施術でした。」</blockquote>
            <p class="review-author">30代・女性</p>
          </div>
        </div>

        <!-- オイルケア・フットケア・ハンドケア -->
        <div class="menu-trio">
          <div class="menu-block">
            <div class="menu-block-header">
              <h3 class="menu-block-title">オイルケア</h3>
              <p class="menu-block-desc">厳選アロマオイルで心身の緊張をほぐします。</p>
            </div>
            <table class="menu-table">
              <thead>
                <tr><th>時間</th><th>料金（税込）</th></tr>
              </thead>
              <tbody>
                <tr><td>●分</td><td>¥●,●●●</td></tr>
              </tbody>
            </table>
            <div class="review-block">
              <blockquote class="review-quote">「オイルの香りに包まれてすっかりリラックス。肌もしっとりしました。」</blockquote>
              <p class="review-author">40代・女性</p>
            </div>
          </div>
          <div class="menu-block">
            <div class="menu-block-header">
              <h3 class="menu-block-title">フットケア</h3>
              <p class="menu-block-desc">足裏から膝下を丁寧にほぐし、むくみをリセット。</p>
            </div>
            <table class="menu-table">
              <thead>
                <tr><th>時間</th><th>料金（税込）</th></tr>
              </thead>
              <tbody>
                <tr><td>●分</td><td>¥●,●●●</td></tr>
              </tbody>
            </table>
            <div class="review-block">
              <blockquote class="review-quote">「むくんでいた足が帰りには別人のように軽くなりました！」</blockquote>
              <p class="review-author">60代・女性</p>
            </div>
          </div>
          <div class="menu-block">
            <div class="menu-block-header">
              <h3 class="menu-block-title">ハンドケア</h3>
              <p class="menu-block-desc">手指・手首・前腕を丁寧にケアします。</p>
            </div>
            <table class="menu-table">
              <thead>
                <tr><th>時間</th><th>料金（税込）</th></tr>
              </thead>
              <tbody>
                <tr><td>●分</td><td>¥●,●●●</td></tr>
              </tbody>
            </table>
            <div class="review-block">
              <blockquote class="review-quote">「手指のこわばりがほぐれ、あたたかくなりました。」</blockquote>
              <p class="review-author">50代・女性</p>
            </div>
          </div>
        </div>

        <!-- メニュー下の予約ボタン -->
        <div class="menu-reserve">
          <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--large">
            ネット予約はこちら
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         アクセス
    ============================================================ -->
    <section class="access" id="access">
      <div class="section-inner">
        <div class="section-heading">
          <span class="section-heading-en">ACCESS</span>
          <h2 class="section-heading-ja">アクセス・営業情報</h2>
        </div>
        <div class="access-signboard">
          <img src={`${base}images/logo.jpg`} alt="サロン和笑〜Violane〜の看板" class="signboard-img" loading="lazy" />
          <p class="signboard-caption">この看板が目印です</p>
        </div>
        <div class="access-grid">
          <dl class="access-info">
            <div class="access-row">
              <dt>住所</dt>
              <dd>富山県高岡市野村1180-1</dd>
            </div>
            <div class="access-row">
              <dt>電話</dt>
              <dd><a href={`tel:${tel}`}>{tel}</a></dd>
            </div>
            <div class="access-row access-row--full">
              <dt>営業時間</dt>
              <dd>
                <table class="hours-table">
                  <thead>
                    <tr><th>曜日</th><th>午前の部</th><th>午後の部</th></tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>月〜金</td>
                      <td>10:30〜14:30</td>
                      <td>16:30〜21:00</td>
                    </tr>
                    <tr>
                      <td>土</td>
                      <td>10:30〜14:30</td>
                      <td>16:30〜18:30</td>
                    </tr>
                    <tr class="closed-row">
                      <td>日・祝・第4火</td>
                      <td colspan="2">定休日</td>
                    </tr>
                  </tbody>
                </table>
              </dd>
            </div>
            <div class="access-row">
              <dt>定休日</dt>
              <dd>日曜・祝日・第4火曜日・他</dd>
            </div>
            <div class="access-row">
              <dt>受付</dt>
              <dd>9:30〜18:00<br /><small>（閉店3時間前まで）</small></dd>
            </div>
            <div class="access-row">
              <dt>アクセス</dt>
              <dd>
                <ul class="access-transport">
                  <li><span class="transport-icon">&#128663;</span>JR高岡駅から<strong>車で9分</strong></li>
                  <li><span class="transport-icon">&#128644;</span>越中中川駅から<strong>徒歩12分</strong></li>
                  <li><span class="transport-icon">&#128652;</span>バス停「野村」から<strong>徒歩9分</strong></li>
                </ul>
              </dd>
            </div>
          </dl>
          <div class="access-map">
            <iframe
              src="https://maps.google.com/maps?q=富山県高岡市野村1180-1&output=embed&hl=ja"
              width="100%"
              height="360"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="サロン和笑〜Violane〜の地図"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         フッター
    ============================================================ -->
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-logo">
          <span class="footer-logo-main">サロン和笑</span>
          <span class="footer-logo-sub">〜Violane〜</span>
        </p>
        <a href={reserveUrl} target="_blank" rel="noopener noreferrer" class="reserve-btn reserve-btn--footer">
          ネット予約はこちら
        </a>
        <a href="https://lin.ee/7ZvbqEb" target="_blank" rel="noopener noreferrer" class="line-btn">
          LINE でご予約・お問い合わせ
        </a>
